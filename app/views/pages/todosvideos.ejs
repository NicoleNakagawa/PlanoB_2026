<!DOCTYPE html>
<html class="light" lang="pt-BR">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>PlanoB - Meus Vídeos</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface": "#f7f5ff",
            "primary": "#0058ba",
            "secondary": "#00647b",
            "on-primary": "#f0f2ff",
            "on-surface": "#232c51",
            "on-surface-variant": "#505a81",
            "surface-container-lowest": "#ffffff",
            "surface-container-low": "#efefff",
            "surface-container": "#e4e7ff",
            "surface-container-highest": "#d5dbff",
            "outline": "#6c759e",
            "outline-variant": "#a2abd7",
            "tertiary-fixed": "#ffd709",
            "on-tertiary-fixed": "#453900",
            "error": "#b31b25"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"]
          }
        }
      }
    }
  </script>

  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .logo-header {
      font-size: 2.7rem;
      line-height: 1;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    h4,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    .avatar-placeholder .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    .video-card:hover img {
      transform: scale(1.08);
    }


    .drop-area {
      border: 2px dashed #a2abd7;
      background:
        radial-gradient(circle at top right, rgba(0, 88, 186, 0.08), transparent 35%),
        #efefff;
      transition: all 0.25s ease;
    }

    .drop-area:hover,
    .drop-area.drag-over {
      border-color: #0058ba;
      background:
        radial-gradient(circle at top right, rgba(0, 88, 186, 0.14), transparent 35%),
        #e4e7ff;
      transform: translateY(-2px);
    }

    .preview-video {
      display: none;
    }

    @media (max-width: 768px) {
      html,
      body {
        overflow-x: hidden;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      header.fixed a.logo-header {
        font-size: 1.45rem;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 16px 135px !important;
      }

      article.hero-videos-prof {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.hero-videos-prof h1 {
        font-size: 2rem !important;
        line-height: 1.1 !important;
      }

      section.card-mobile,
      article.card-mobile {
        padding: 22px !important;
        border-radius: 26px !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 52px;
        border-radius: 18px;
      }

      nav[aria-label="Navegação mobile"] a[aria-current="page"] {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
      }
    }

    @media (max-width: 420px) {
      main {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }

      nav[aria-label="Navegação mobile"] em {
        font-size: 8px !important;
      }
    }


    .notification-menu {
      position: relative;
      display: flex;
      align-items: center;
    }

    .notification-button {
      position: relative;
      width: 40px;
      height: 40px;
      padding: 8px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .notification-popup {
      position: absolute;
      top: 48px;
      right: 0;
      width: 300px;
      max-width: calc(100vw - 24px);
      background: #ffffff;
      border: 1px solid #e4e7ff;
      border-radius: 22px;
      box-shadow: 0 18px 45px rgba(35, 44, 81, 0.18);
      padding: 12px;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(-8px);
      transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s ease;
      z-index: 99999;
    }

    .notification-popup.open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateY(0);
    }

    .notification-arrow {
      position: absolute;
      top: -7px;
      right: 18px;
      width: 14px;
      height: 14px;
      background: #ffffff;
      border-left: 1px solid #e4e7ff;
      border-top: 1px solid #e4e7ff;
      transform: rotate(45deg);
    }

    .notification-badge {
      position: absolute;
      top: -3px;
      right: -3px;
      min-width: 18px;
      height: 18px;
      padding: 0 5px;
      border-radius: 999px;
      background: #b31b25;
      color: #ffffff;
      font-size: 9px;
      font-weight: 900;
      line-height: 18px;
      display: none;
      align-items: center;
      justify-content: center;
    }

    .notification-badge.active {
      display: flex;
    }

    .notification-list {
      max-height: 260px;
      overflow-y: auto;
    }

    .notification-list::-webkit-scrollbar {
      width: 5px;
    }

    .notification-list::-webkit-scrollbar-thumb {
      background: #a2abd7;
      border-radius: 999px;
    }

    @media (max-width: 640px) {
      .notification-popup {
        right: -52px;
        width: 280px;
      }

      .notification-arrow {
        right: 66px;
      }
    }

  </style>
  <link rel="stylesheet" href="/css/transicao-paginas.css">
</head>

<body class="bg-surface text-on-surface min-h-screen">

  <%
    const professorSeguro = typeof professor !== 'undefined' && professor ? professor : {}
    const nomeProfessor = professorSeguro.nome ? professorSeguro.nome.split(' ')[0] : 'Professor'
    const videosSeguros = typeof videos !== 'undefined' && videos ? videos : []
    const categoriasSeguras = typeof categorias !== 'undefined' && categorias ? categorias : []
    const estatisticasSeguras = typeof estatisticas !== 'undefined' && estatisticas ? estatisticas : {
      total_videos: 0,
      duracao_total: 0,
      total_exclusivos: 0
    }
    const filtrosSeguros = typeof filtros !== 'undefined' && filtros ? filtros : {
      busca: '',
      categoria: 'todos'
    }

    function segundosParaMinutos(segundos) {
      const valor = Number(segundos) || 0
      if (valor <= 0) return '0 min'
      const minutos = Math.floor(valor / 60)
      const resto = valor % 60

      if (minutos <= 0) return resto + 's'
      if (resto === 0) return minutos + ' min'

      return minutos + 'm ' + resto + 's'
    }

    function dataFormatada(data) {
      if (!data) return 'Sem data'
      return new Date(data).toLocaleDateString('pt-BR')
    }
  %>

  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">
    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <a href="/painelprofessor" class="font-headline logo-font logo-header text-primary no-underline">PlanoB</a>
    </nav>

    <form action="/todosvideos" method="GET" class="hidden md:flex items-center bg-surface-container-low px-4 py-2 rounded-full">
      <i class="material-symbols-outlined text-outline text-sm not-italic" aria-hidden="true">search</i>
      <label for="top-search" class="sr-only">Buscar vídeos</label>
      <input
        id="top-search"
        name="busca"
        value="<%= filtrosSeguros.busca %>"
        class="bg-transparent border-none focus:ring-0 text-sm w-48 ml-2"
        placeholder="Buscar vídeos..."
        type="search"
      />
      <input type="hidden" name="categoria" value="<%= filtrosSeguros.categoria %>">
    </form>

    <menu class="flex items-center gap-4 p-0 m-0 list-none">
      <li class="notification-menu">
        <button
          id="notification-button"
          type="button"
          class="notification-button hover:bg-surface-container transition-colors active:scale-95"
          aria-label="Abrir notificações"
          aria-expanded="false"
          aria-controls="notification-popup"
        >
          <i class="material-symbols-outlined text-on-surface not-italic" aria-hidden="true">notifications</i>

          <em id="notification-badge" class="notification-badge not-italic">
            0
          </em>
        </button>

        <section id="notification-popup" class="notification-popup" aria-label="Notificações">
          <b class="notification-arrow font-normal" aria-hidden="true"></b>

          <header class="flex items-center justify-between gap-3 px-2 pb-3 border-b border-surface-container">
            <h2 class="text-sm font-black text-on-surface">
              Notificações
            </h2>

            <a href="/feedbackprofessor?status=pendentes" class="text-xs font-black text-primary hover:underline">
              Ver todas
            </a>
          </header>

          <section id="notification-content" class="notification-list pt-3">
            <article class="rounded-2xl bg-surface-container-low p-4 text-center">
              <i class="material-symbols-outlined text-primary text-4xl not-italic mb-2" aria-hidden="true">hourglass_empty</i>

              <p class="text-sm font-bold text-on-surface">
                Carregando...
              </p>
            </article>
          </section>
        </section>
      </li>

      <li>
        <a href="/perfilprofessor" class="p-1 rounded-full bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center" aria-label="Perfil do professor">
          <% if (professorSeguro.foto) { %>
            <img src="<%= professorSeguro.foto %>" alt="Foto do professor" class="w-10 h-10 rounded-full object-cover">
          <% } else { %>
            <em class="w-10 h-10 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden not-italic">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </em>
          <% } %>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] flex-col gap-2 py-8 z-40 mt-16">
    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <% if (professorSeguro.foto) { %>
          <img class="w-12 h-12 rounded-full object-cover" src="<%= professorSeguro.foto %>" alt="Foto de perfil do professor" />
        <% } else { %>
          <em class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden not-italic" aria-label="Professor sem foto">
            <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
          </em>
        <% } %>

        <figcaption>
          <p class="text-sm font-bold text-on-surface">
            <%= nomeProfessor %>
          </p>
          <p class="text-xs text-on-surface-variant">
            <%= professorSeguro.cref ? 'CREF ' + professorSeguro.cref : 'Professor PlanoB' %>
          </p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/painelprofessor">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">dashboard</i>
        <em class="not-italic">Dashboard</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/todosalunos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">groups</i>
        <em class="not-italic">Meus Alunos</em>
      </a>

      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="/todosvideos" aria-current="page">
        <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">video_library</i>
        <em class="not-italic">Meus Vídeos</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/feedbackprofessor">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
        <em class="not-italic">Feedbacks</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/perfilprofessor">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">person</i>
        <em class="not-italic">Perfil</em>
      </a>
    </nav>

    <footer class="mt-auto px-4 pb-8 flex flex-col gap-2">
      <a href="#novo-video" class="w-full bg-primary text-on-primary rounded-full py-4 font-bold shadow-lg shadow-primary/30 flex items-center justify-center gap-2 active:scale-95 transition-transform">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">add_circle</i>
        Novo Vídeo
      </a>

      <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:text-error rounded-full hover:bg-surface-container transition-colors text-sm" href="/logout">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i>
        <em class="not-italic">Sair</em>
      </a>
    </footer>
  </aside>

  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <article class="hero-videos-prof md:col-span-12 relative overflow-hidden rounded-3xl bg-primary p-8 md:p-12 text-white shadow-2xl">
        <section class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
          <hgroup class="max-w-2xl">
            <mark class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md text-xs font-bold uppercase tracking-widest mb-4 text-white">
              Biblioteca do Professor
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              MEUS VÍDEOS.
            </h1>

            <p class="text-lg opacity-90 max-w-xl">
              Adicione, edite, visualize e remova os vídeos que seus alunos verão na plataforma.
            </p>
          </hgroup>

          <figure class="flex flex-col items-center gap-4 bg-white/10 backdrop-blur-xl p-6 md:p-8 rounded-3xl border border-white/10 w-full max-w-[240px] mx-auto md:mx-0 md:w-auto m-0">
            <span class="w-28 h-28 rounded-full bg-white/15 flex items-center justify-center">
              <i class="material-symbols-outlined text-white text-7xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">video_library</i>
            </span>

            <figcaption class="text-sm font-black uppercase tracking-widest text-center">
              <%= estatisticasSeguras.total_videos %> vídeos ativos
            </figcaption>
          </figure>
        </section>

        <b class="absolute -right-20 -bottom-20 w-96 h-96 bg-[#80deff] opacity-10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        <b class="absolute -left-20 -top-20 w-64 h-64 bg-white opacity-5 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
      </article>

      <% if (erro) { %>
        <section class="md:col-span-12 bg-red-50 text-error rounded-3xl p-5 font-bold text-center" role="alert">
          <%= erro %>
        </section>
      <% } %>

      <% if (sucesso) { %>
        <section class="md:col-span-12 bg-green-50 text-green-700 rounded-3xl p-5 font-bold text-center" role="status">
          <%= sucesso %>
        </section>
      <% } %>

      <section class="md:col-span-12 grid grid-cols-1 sm:grid-cols-3 gap-6">
        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-6 shadow-sm flex items-center gap-4">
          <figure class="w-14 h-14 rounded-2xl bg-primary/10 text-primary flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">movie_filter</i>
          </figure>
          <section>
            <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Total de vídeos</p>
            <strong class="text-3xl font-black headline text-on-surface"><%= estatisticasSeguras.total_videos %></strong>
          </section>
        </article>

        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-6 shadow-sm flex items-center gap-4">
          <figure class="w-14 h-14 rounded-2xl bg-tertiary-fixed/20 text-on-tertiary-fixed flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">workspace_premium</i>
          </figure>
          <section>
            <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Exclusivos</p>
            <strong class="text-3xl font-black headline text-on-surface"><%= estatisticasSeguras.total_exclusivos || 0 %></strong>
          </section>
        </article>

        <article class="card-mobile bg-primary rounded-3xl p-6 shadow-xl shadow-primary/20 flex items-center gap-4 text-white">
          <figure class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">schedule</i>
          </figure>
          <section>
            <p class="text-xs font-black uppercase tracking-widest text-white/70">Tempo total</p>
            <strong class="text-3xl font-black headline text-white"><%= segundosParaMinutos(estatisticasSeguras.duracao_total) %></strong>
          </section>
        </article>
      </section>

      <section id="novo-video" class="card-mobile md:col-span-12 bg-surface-container-lowest rounded-3xl p-8 shadow-sm">
        <header class="mb-6">
          <h2 class="text-2xl font-extrabold headline text-on-surface">Adicionar novo vídeo</h2>
          <p class="text-sm text-on-surface-variant mt-1">
            Arraste o arquivo do vídeo, selecione no computador ou informe uma URL externa.
          </p>
        </header>

        <form action="/professor/videos/criar" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-12 gap-5">

          <section class="md:col-span-5">
            <label
              id="drop-area"
              for="arquivo_video"
              class="drop-area min-h-[360px] rounded-[2rem] flex flex-col items-center justify-center text-center p-8 cursor-pointer"
            >
              <span class="w-24 h-24 rounded-full bg-primary text-white flex items-center justify-center shadow-xl shadow-primary/20 mb-6">
                <i class="material-symbols-outlined text-6xl not-italic" aria-hidden="true">cloud_upload</i>
              </span>

              <strong id="drop-title" class="text-2xl font-black headline text-on-surface">
                Arraste o vídeo aqui
              </strong>

              <span id="drop-subtitle" class="text-sm text-on-surface-variant mt-3 max-w-xs">
                ou clique para selecionar um arquivo MP4, WEBM, OGG ou MOV.
              </span>

              <small class="text-xs font-bold text-primary mt-5">
                Tamanho máximo configurado: 300MB
              </small>

              <input
                id="arquivo_video"
                name="arquivo_video"
                type="file"
                accept="video/mp4,video/webm,video/ogg,video/quicktime"
                class="sr-only"
              />
            </label>

            <video id="preview-video" class="preview-video w-full mt-5 rounded-3xl bg-black" controls></video>

            <p class="text-xs text-on-surface-variant mt-4 leading-relaxed">
              Você também pode informar uma URL externa no campo ao lado. No Render, para projetos profissionais, o ideal é depois usar Cloudinary, Firebase Storage ou S3 para armazenar vídeos.
            </p>
          </section>

          <section class="md:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-4 content-start">
            <label class="md:col-span-2">
              <span class="text-xs font-black uppercase tracking-widest text-on-surface-variant block mb-2">Título</span>
              <input
                name="titulo"
                required
                class="w-full rounded-2xl border-none bg-surface-container-low px-5 py-4 focus:ring-2 focus:ring-primary"
                placeholder="Ex: Treino de pernas completo"
              />
            </label>

            <label>
              <span class="text-xs font-black uppercase tracking-widest text-on-surface-variant block mb-2">Categoria</span>
              <input
                name="categoria"
                class="w-full rounded-2xl border-none bg-surface-container-low px-5 py-4 focus:ring-2 focus:ring-primary"
                placeholder="Força, Cardio..."
              />
            </label>

            <label>
              <span class="text-xs font-black uppercase tracking-widest text-on-surface-variant block mb-2">Nível</span>
              <select name="nivel" class="w-full rounded-2xl border-none bg-surface-container-low px-5 py-4 focus:ring-2 focus:ring-primary">
                <option value="iniciante">Iniciante</option>
                <option value="intermediario">Intermediário</option>
                <option value="avancado">Avançado</option>
              </select>
            </label>


            <label class="md:col-span-2">
              <span class="text-xs font-black uppercase tracking-widest text-on-surface-variant block mb-2">URL do vídeo, caso não envie arquivo</span>
              <input
                name="video_url"
                class="w-full rounded-2xl border-none bg-surface-container-low px-5 py-4 focus:ring-2 focus:ring-primary"
                placeholder="https://.../video.mp4"
              />
            </label>



            <label class="md:col-span-2">
              <span class="text-xs font-black uppercase tracking-widest text-on-surface-variant block mb-2">Descrição</span>
              <textarea
                name="descricao"
                rows="5"
                class="w-full rounded-2xl border-none bg-surface-container-low px-5 py-4 focus:ring-2 focus:ring-primary resize-none"
                placeholder="Descreva o exercício, objetivo e cuidados..."
              ></textarea>
            </label>

            <button type="submit" class="md:col-span-2 bg-primary text-white rounded-full px-8 py-5 font-black shadow-lg shadow-primary/20 active:scale-95 transition-transform inline-flex items-center justify-center gap-2">
              Enviar vídeo
              <i class="material-symbols-outlined not-italic" aria-hidden="true">send</i>
            </button>
          </section>

        </form>
      </section>

      <section class="card-mobile md:col-span-12 bg-surface-container-low rounded-3xl p-8 flex flex-col gap-6">
        <header class="flex flex-col lg:flex-row lg:items-center justify-between gap-4">
          <hgroup>
            <h2 class="text-2xl font-extrabold headline text-on-surface">Biblioteca de vídeos</h2>
            <p class="text-sm text-on-surface-variant mt-1">
              Clique em um vídeo para abrir, assistir e editar informações.
            </p>
          </hgroup>

          <form action="/todosvideos" method="GET" class="flex flex-col md:flex-row gap-3">
            <input
              name="busca"
              value="<%= filtrosSeguros.busca %>"
              type="search"
              placeholder="Buscar vídeo"
              class="rounded-full border-none bg-surface-container-lowest px-5 py-3 focus:ring-2 focus:ring-primary min-w-[220px]"
            />

            <select name="categoria" class="rounded-full border-none bg-surface-container-lowest px-5 py-3 focus:ring-2 focus:ring-primary">
              <option value="todos" <%= filtrosSeguros.categoria === 'todos' ? 'selected' : '' %>>Todas</option>
              <% categoriasSeguras.forEach(function(cat) { %>
                <option value="<%= cat.categoria %>" <%= filtrosSeguros.categoria === cat.categoria ? 'selected' : '' %>>
                  <%= cat.categoria %>
                </option>
              <% }) %>
            </select>

            <button type="submit" class="bg-primary text-white rounded-full px-6 py-3 font-bold active:scale-95 transition-transform">
              Filtrar
            </button>
          </form>
        </header>

        <% if (videosSeguros.length > 0) { %>
          <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
            <% videosSeguros.forEach(function(video) { %>
              <article class="video-card bg-surface-container-lowest rounded-3xl overflow-hidden shadow-sm group hover:shadow-xl transition-all hover:-translate-y-1">
                <a href="/editarvideos/<%= video.id_video %>" class="block text-inherit no-underline">
                  <figure class="relative aspect-video overflow-hidden m-0 bg-surface-container-highest">
                    <% if (video.thumbnail) { %>
                      <img alt="<%= video.titulo %>" class="w-full h-full object-cover transition-transform duration-500" src="<%= video.thumbnail %>">
                    <% } else { %>
                      <span class="w-full h-full flex items-center justify-center">
                        <i class="material-symbols-outlined text-primary text-7xl not-italic" aria-hidden="true">play_circle</i>
                      </span>
                    <% } %>

                    <figcaption class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                      <i class="material-symbols-outlined text-white text-5xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">play_arrow</i>
                    </figcaption>

                    <footer class="absolute bottom-3 left-3 right-3 flex justify-between items-center pointer-events-none">
                      <mark class="<%= video.exclusivo ? 'bg-tertiary-fixed text-on-tertiary-fixed' : 'bg-surface-container-lowest text-on-surface' %> text-[10px] font-black px-2 py-1 rounded uppercase">
                        <%= video.exclusivo ? 'Premium' : 'Geral' %>
                      </mark>
                      <time class="text-white text-xs font-bold bg-black/60 px-2 py-1 rounded">
                        <%= segundosParaMinutos(video.duracao_seg) %>
                      </time>
                    </footer>
                  </figure>
                </a>

                <section class="p-5">
                  <h3 class="font-black text-on-surface mb-1 line-clamp-1"><%= video.titulo %></h3>
                  <p class="text-on-surface-variant text-xs mb-3 line-clamp-2">
                    <%= video.descricao || 'Sem descrição cadastrada.' %>
                  </p>

                  <nav class="flex justify-between pt-3 border-t border-surface-container items-center">
                    <small class="text-[10px] font-bold text-primary uppercase tracking-widest">
                      <%= video.categoria || 'Sem categoria' %> · <%= video.nivel || 'Livre' %>
                    </small>

                    <section class="flex gap-1">
                      <a href="/editarvideos/<%= video.id_video %>" class="p-2 text-primary hover:bg-primary/10 rounded-full transition-colors" aria-label="Editar vídeo">
                        <i class="material-symbols-outlined text-sm not-italic" aria-hidden="true">edit</i>
                      </a>

                      <form action="/professor/videos/<%= video.id_video %>/excluir" method="POST" onsubmit="return confirm('Deseja remover este vídeo?')">
                        <button type="submit" class="p-2 text-error hover:bg-error/10 rounded-full transition-colors" aria-label="Excluir vídeo">
                          <i class="material-symbols-outlined text-sm not-italic" aria-hidden="true">delete</i>
                        </button>
                      </form>
                    </section>
                  </nav>

                  <p class="text-[10px] text-on-surface-variant mt-3">
                    Criado em <%= dataFormatada(video.criado_em) %>
                  </p>
                </section>
              </article>
            <% }) %>
          </section>
        <% } else { %>
          <section class="bg-surface-container-lowest rounded-3xl p-10 text-center">
            <i class="material-symbols-outlined text-primary text-6xl not-italic mb-4" aria-hidden="true">video_library</i>
            <h3 class="text-2xl font-black headline text-on-surface">Nenhum vídeo encontrado</h3>
            <p class="text-on-surface-variant mt-2">
              Adicione seu primeiro vídeo usando o formulário acima.
            </p>
          </section>
        <% } %>
      </section>

    </section>
  </main>

  <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex justify-around items-end px-4 pb-6 pt-2 bg-[#f7f5ff]/90 backdrop-blur-lg shadow-[0_-10px_40px_rgba(35,44,81,0.08)] rounded-t-[32px]" aria-label="Navegação mobile">
    <a href="/painelprofessor" class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">dashboard</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Início</em>
    </a>

    <a href="/todosalunos" class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">groups</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Alunos</em>
    </a>

    <a href="#novo-video" class="bg-primary text-white w-14 h-14 rounded-full shadow-lg shadow-primary/40 -mt-8 flex items-center justify-center active:scale-95 transition-transform" aria-label="Adicionar novo vídeo">
      <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">add</i>
    </a>

    <a href="/todosvideos" class="flex flex-col items-center justify-center text-[#0058ba] opacity-100 p-3 rounded-[18px] bg-[#d5dbff]" aria-current="page">
      <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">video_library</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Vídeos</em>
    </a>

    <a href="/feedbackprofessor" class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Feedback</em>
    </a>
  </nav>


  <script>
    const dropArea = document.getElementById('drop-area')
    const inputVideo = document.getElementById('arquivo_video')
    const dropTitle = document.getElementById('drop-title')
    const dropSubtitle = document.getElementById('drop-subtitle')
    const previewVideo = document.getElementById('preview-video')
    const duracaoInput = document.getElementById('duracao_seg')

    function aplicarArquivo(file) {
      if (!file) return

      dropTitle.textContent = file.name
      dropSubtitle.textContent = `${(file.size / 1024 / 1024).toFixed(1)} MB selecionado`

      const url = URL.createObjectURL(file)
      previewVideo.src = url
      previewVideo.style.display = 'block'

      previewVideo.onloadedmetadata = () => {
        if (duracaoInput && previewVideo.duration && !Number.isNaN(previewVideo.duration)) {
          duracaoInput.value = Math.round(previewVideo.duration)
        }
      }
    }

    if (dropArea && inputVideo) {
      inputVideo.addEventListener('change', () => {
        aplicarArquivo(inputVideo.files[0])
      })

      ;['dragenter', 'dragover'].forEach(evento => {
        dropArea.addEventListener(evento, (event) => {
          event.preventDefault()
          dropArea.classList.add('drag-over')
        })
      })

      ;['dragleave', 'drop'].forEach(evento => {
        dropArea.addEventListener(evento, (event) => {
          event.preventDefault()
          dropArea.classList.remove('drag-over')
        })
      })

      dropArea.addEventListener('drop', (event) => {
        const file = event.dataTransfer.files[0]

        if (!file) return

        const dataTransfer = new DataTransfer()
        dataTransfer.items.add(file)
        inputVideo.files = dataTransfer.files

        aplicarArquivo(file)
      })
    }

  </script>

<script>
  const notificationButton = document.getElementById('notification-button')
  const notificationPopup = document.getElementById('notification-popup')
  const notificationBadge = document.getElementById('notification-badge')
  const notificationContent = document.getElementById('notification-content')

  function textoSeguro(valor) {
    return String(valor || '').replace(/[&<>"']/g, (char) => {
      const mapa = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;'
      }

      return mapa[char]
    })
  }

  function montarNotificacaoVazia() {
    if (!notificationContent) return

    notificationContent.innerHTML = `
      <article class="rounded-2xl bg-surface-container-low p-4 text-center">
        <i class="material-symbols-outlined text-primary text-4xl not-italic mb-2" aria-hidden="true">notifications_off</i>

        <p class="text-sm font-black text-on-surface">
          Não há notificações no momento.
        </p>

        <p class="text-xs text-on-surface-variant mt-1">
          Novos feedbacks aparecerão aqui.
        </p>
      </article>
    `
  }

  function montarNotificacoes(lista) {
    if (!notificationContent) return

    if (!lista || lista.length === 0) {
      montarNotificacaoVazia()
      return
    }

    notificationContent.innerHTML = lista.slice(0, 5).map((item) => {
      const aluno = textoSeguro(item.aluno || item.aluno_nome || 'Aluno')
      const texto = textoSeguro(item.texto || 'Enviou um novo feedback.')
      const data = item.enviado_em
        ? new Date(item.enviado_em).toLocaleDateString('pt-BR')
        : 'Agora'

      return `
        <a href="/feedbackprofessor?status=pendentes&aluno=${item.id_aluno || ''}" class="block rounded-2xl p-3 hover:bg-surface-container-low transition-colors">
          <article class="flex items-start gap-3">
            <figure class="w-10 h-10 rounded-2xl bg-primary/10 text-primary flex items-center justify-center m-0 shrink-0">
              <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
            </figure>

            <section class="min-w-0 flex-1">
              <h3 class="text-sm font-black text-on-surface truncate">
                ${aluno}
              </h3>

              <p class="text-xs text-on-surface-variant line-clamp-2 mt-1">
                ${texto}
              </p>

              <time class="text-[10px] font-bold text-primary mt-2 block">
                ${data}
              </time>
            </section>
          </article>
        </a>
      `
    }).join('')
  }

  async function carregarNotificacoes() {
    if (!notificationBadge || !notificationContent) return

    try {
      const resposta = await fetch('/api/professor/feedbacks', {
        headers: {
          Accept: 'application/json'
        }
      })

      const resultado = await resposta.json()
      const lista = resultado.data || []

      if (lista.length > 0) {
        notificationBadge.textContent = lista.length > 9 ? '9+' : lista.length
        notificationBadge.classList.add('active')
      } else {
        notificationBadge.textContent = '0'
        notificationBadge.classList.remove('active')
      }

      montarNotificacoes(lista)
    } catch (erro) {
      notificationBadge.classList.remove('active')

      notificationContent.innerHTML = `
        <article class="rounded-2xl bg-red-50 p-4 text-center">
          <i class="material-symbols-outlined text-error text-4xl not-italic mb-2" aria-hidden="true">error</i>

          <p class="text-sm font-black text-error">
            Erro ao carregar notificações.
          </p>
        </article>
      `
    }
  }

  if (notificationButton && notificationPopup) {
    notificationButton.addEventListener('click', async (event) => {
      event.preventDefault()
      event.stopPropagation()

      const vaiAbrir = !notificationPopup.classList.contains('open')

      notificationPopup.classList.toggle('open')
      notificationButton.setAttribute('aria-expanded', String(vaiAbrir))

      if (vaiAbrir) {
        await carregarNotificacoes()
      }
    })

    notificationPopup.addEventListener('click', (event) => {
      event.stopPropagation()
    })

    document.addEventListener('click', () => {
      notificationPopup.classList.remove('open')
      notificationButton.setAttribute('aria-expanded', 'false')
    })

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        notificationPopup.classList.remove('open')
        notificationButton.setAttribute('aria-expanded', 'false')
      }
    })

    carregarNotificacoes()
    setInterval(carregarNotificacoes, 30000)
  }
</script>
  <script src="/js/transicao-paginas.js"></script>
</body>
</html>