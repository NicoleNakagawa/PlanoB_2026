<!DOCTYPE html>
<html class="light" lang="pt-BR">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>PlanoB - Painel do Professor</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface-bright": "#f7f5ff",
            "tertiary-dim": "#5e4e00",
            "error": "#b31b25",
            "surface-dim": "#cad2ff",
            "outline-variant": "#a2abd7",
            "on-secondary": "#e2f6ff",
            "surface-container-highest": "#d5dbff",
            "inverse-primary": "#4a8eff",
            "surface": "#f7f5ff",
            "primary": "#0058ba",
            "outline": "#6c759e",
            "inverse-on-surface": "#929bc6",
            "error-container": "#fb5151",
            "surface-variant": "#d5dbff",
            "primary-fixed": "#6c9fff",
            "primary-container": "#6c9fff",
            "secondary-fixed-dim": "#37d4ff",
            "on-error": "#ffefee",
            "on-tertiary": "#fff2cd",
            "on-surface-variant": "#505a81",
            "tertiary-fixed-dim": "#efc900",
            "surface-container-high": "#dde1ff",
            "secondary-dim": "#00576c",
            "on-secondary-fixed-variant": "#00586d",
            "on-tertiary-container": "#5b4b00",
            "tertiary-fixed": "#ffd709",
            "on-primary-fixed": "#000000",
            "on-primary": "#f0f2ff",
            "on-error-container": "#570008",
            "secondary-fixed": "#80deff",
            "secondary-container": "#80deff",
            "on-tertiary-fixed": "#453900",
            "primary-fixed-dim": "#5091ff",
            "surface-container": "#e4e7ff",
            "primary-dim": "#004da4",
            "on-background": "#232c51",
            "surface-container-lowest": "#ffffff",
            "inverse-surface": "#020a2f",
            "tertiary-container": "#ffd709",
            "on-tertiary-fixed-variant": "#665500",
            "on-primary-container": "#00214e",
            "surface-container-low": "#efefff",
            "secondary": "#00647b",
            "on-primary-fixed-variant": "#002a60",
            "on-secondary-container": "#004e61",
            "on-surface": "#232c51",
            "surface-tint": "#0058ba",
            "background": "#f7f5ff",
            "on-secondary-fixed": "#003a48",
            "error-dim": "#9f0519",
            "tertiary": "#6c5a00"
          },
          borderRadius: {
            DEFAULT: "0.25rem",
            lg: "0.5rem",
            xl: "0.75rem",
            full: "9999px"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"],
            label: ["Manrope"]
          }
        }
      }
    }
  </script>

  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .logo-header {
      font-size: 2.7rem;
      line-height: 1;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    h4,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    .avatar-placeholder .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    progress {
      appearance: none;
      -webkit-appearance: none;
    }

    progress::-webkit-progress-bar {
      background: #d5dbff;
      border-radius: 999px;
    }

    progress::-webkit-progress-value {
      background: #0058ba;
      border-radius: 999px;
    }

    progress::-moz-progress-bar {
      background: #0058ba;
      border-radius: 999px;
    }

    @media (max-width: 768px) {
      html,
      body {
        width: 100%;
        overflow-x: hidden;
      }

      body {
        background: #f7f5ff;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      header.fixed a.logo-header,
      header.fixed strong.logo-header {
        font-size: 1.45rem;
        line-height: 1;
      }

      header.fixed menu {
        gap: 8px;
      }

      header.fixed button,
      header.fixed a {
        padding: 8px;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 16px 135px !important;
      }

      article.hero-professor {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.hero-professor h1 {
        font-size: 2rem !important;
        line-height: 1.1 !important;
      }

      article.hero-professor p {
        font-size: 0.95rem !important;
      }

      section.card-mobile,
      article.card-mobile {
        padding: 22px !important;
        border-radius: 26px !important;
      }

      section.tabela-alunos table {
        min-width: 760px;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 58px;
        border-radius: 18px;
      }

      nav[aria-label="Navegação mobile"] a[aria-current="page"] {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
      }

      nav[aria-label="Navegação mobile"] a:hover {
        color: #0058ba !important;
        opacity: 1 !important;
      }
    }

    @media (max-width: 420px) {
      main {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }

      article.hero-professor h1 {
        font-size: 1.75rem !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding-left: 6px !important;
        padding-right: 6px !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 52px;
        padding: 10px 4px !important;
      }

      nav[aria-label="Navegação mobile"] em {
        font-size: 8px !important;
      }
    }
  </style>
</head>

<body class="bg-surface text-on-surface">

  <%
    const professorSeguro = typeof professor !== 'undefined' && professor ? professor : {}
    const estatisticasSeguras = typeof estatisticas !== 'undefined' && estatisticas ? estatisticas : {
      total_alunos: 0,
      total_videos: 0,
      feedbacks_pendentes: 0,
      media_progressao: 0
    }

    const alunosSeguros = typeof alunos !== 'undefined' && alunos ? alunos : []
    const videosSeguros = typeof videos !== 'undefined' && videos ? videos : []

    function segundosParaMinutos(segundos) {
      const valor = Number(segundos) || 0
      if (valor <= 0) return '0 min'
      const minutos = Math.round(valor / 60)
      return minutos + ' min'
    }

    function dataFormatada(data) {
      if (!data) return 'Sem data'
      return new Date(data).toLocaleDateString('pt-BR')
    }

    function calcularProgressoAluno(aluno) {
      const dias = Number(aluno.dias_treinados) || 0
      const meta = Number(aluno.meta_dias) || 5
      if (meta <= 0) return 0
      return Math.min(Math.round((dias / meta) * 100), 100)
    }

    function statusAluno(aluno) {
      const treinos = Number(aluno.total_treinos) || 0
      const dias = Number(aluno.dias_treinados) || 0

      if (dias > 0) return 'Ativo'
      if (treinos > 0) return 'Em pausa'
      return 'Novo'
    }

    function classeStatusAluno(aluno) {
      const status = statusAluno(aluno)

      if (status === 'Ativo') return 'bg-emerald-500'
      if (status === 'Em pausa') return 'bg-yellow-500'
      return 'bg-outline'
    }
  %>

  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">

    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <a href="/painelprofessor" class="font-headline logo-font logo-header text-primary no-underline">PlanoB</a>
    </nav>

    <form action="/todosalunos" method="GET" class="hidden md:flex items-center bg-surface-container-low px-4 py-2 rounded-full">
      <i class="material-symbols-outlined text-outline text-sm not-italic" aria-hidden="true">search</i>
      <label for="top-search" class="sr-only">Buscar alunos</label>
      <input
        id="top-search"
        name="busca"
        class="bg-transparent border-none focus:ring-0 text-sm w-48 ml-2"
        placeholder="Buscar alunos..."
        type="search"
      />
    </form>

    <menu class="flex items-center gap-4 p-0 m-0 list-none">
      <li>
        <a href="/feedbackprofessor" class="relative p-2 rounded-full hover:bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center" aria-label="Feedbacks pendentes">
          <i class="material-symbols-outlined text-on-background not-italic" aria-hidden="true">notifications</i>

          <% if (Number(estatisticasSeguras.feedbacks_pendentes) > 0) { %>
            <span class="absolute -top-1 -right-1 min-w-5 h-5 px-1 rounded-full bg-error text-white text-[10px] font-black flex items-center justify-center">
              <%= estatisticasSeguras.feedbacks_pendentes %>
            </span>
          <% } %>
        </a>
      </li>

      <li>
        <a href="/painelprofessor" class="p-1 rounded-full bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center" aria-label="Perfil do professor">
          <% if (professorSeguro.foto) { %>
            <img src="<%= professorSeguro.foto %>" alt="Foto do professor" class="w-10 h-10 rounded-full object-cover">
          <% } else { %>
            <span class="w-10 h-10 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </span>
          <% } %>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] dark:bg-[#12141c] flex-col gap-2 py-8 z-40 mt-16">

    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <picture>
          <% if (professorSeguro.foto) { %>
            <img
              class="w-12 h-12 rounded-full object-cover"
              src="<%= professorSeguro.foto %>"
              alt="Foto de perfil do professor"
            />
          <% } else { %>
            <span class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden" aria-label="Professor sem foto">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </span>
          <% } %>
        </picture>

        <figcaption>
          <p class="text-sm font-bold text-on-surface">Portal do Professor</p>
          <p class="text-xs text-on-surface-variant">
            <%= professorSeguro.nome ? professorSeguro.nome.split(' ')[0] : 'Bem-vindo' %>
          </p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="/painelprofessor" aria-current="page">
        <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">dashboard</i>
        <em class="not-italic">Dashboard</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/todosalunos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">groups</i>
        <em class="not-italic">Meus Alunos</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/todosvideos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">video_library</i>
        <em class="not-italic">Meus Vídeos</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/feedbackprofessor">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
        <em class="not-italic">Feedbacks</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/editarexercicios">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">edit_note</i>
        <em class="not-italic">Editar Exercícios</em>
      </a>
    </nav>

    <footer class="mt-auto px-4 pb-8 flex flex-col gap-2">
      <a href="/todosvideos" class="w-full bg-primary text-on-primary rounded-full py-4 font-bold shadow-lg shadow-primary/30 flex items-center justify-center gap-2 active:scale-95 transition-transform">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">add_circle</i>
        Novo Conteúdo
      </a>

      <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:text-error rounded-full hover:bg-surface-container transition-colors text-sm"
         href="/logout">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i>
        <em class="not-italic">Sair</em>
      </a>
    </footer>
  </aside>

  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <article class="hero-professor md:col-span-12 relative overflow-hidden rounded-3xl bg-primary p-8 md:p-12 text-white shadow-2xl">

        <section class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">

          <hgroup class="max-w-2xl">
            <mark class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md text-xs font-bold uppercase tracking-widest mb-4 text-white">
              Dashboard do Professor
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              OLÁ, <%= professorSeguro.nome ? professorSeguro.nome.split(' ')[0].toUpperCase() : 'PROFESSOR' %>.
            </h1>

            <p class="text-lg opacity-90 max-w-xl">
              Acompanhe seus alunos, evolução semanal, vídeos publicados e feedbacks recebidos dentro do PlanoB.
            </p>
          </hgroup>

          <figure class="flex flex-col items-center gap-4 bg-white/10 backdrop-blur-xl p-6 md:p-8 rounded-3xl border border-white/10 w-full max-w-[240px] mx-auto md:mx-0 md:w-auto m-0">
            <% if (professorSeguro.foto) { %>
              <img src="<%= professorSeguro.foto %>" alt="Foto do professor" class="w-28 h-28 rounded-full object-cover border-4 border-white/30">
            <% } else { %>
              <span class="w-28 h-28 rounded-full bg-white/15 flex items-center justify-center">
                <i class="material-symbols-outlined text-white text-8xl not-italic" style="font-variation-settings:'FILL' 1,'wght' 300,'GRAD' 0,'opsz' 48" aria-hidden="true">account_circle</i>
              </span>
            <% } %>

            <figcaption class="text-sm font-black uppercase tracking-widest text-center">
              <%= professorSeguro.cref ? 'CREF ' + professorSeguro.cref : 'Professor PlanoB' %>
            </figcaption>
          </figure>

        </section>

        <b class="absolute -right-20 -bottom-20 w-96 h-96 bg-secondary-fixed opacity-10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        <b class="absolute -left-20 -top-20 w-64 h-64 bg-white opacity-5 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
      </article>

      <% if (typeof erro !== 'undefined' && erro) { %>
        <section class="md:col-span-12 bg-red-50 text-error rounded-3xl p-5 font-bold text-center" role="alert">
          <%= erro %>
        </section>
      <% } %>

      <section class="md:col-span-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-6 shadow-sm flex items-center gap-4">
          <figure class="w-14 h-14 rounded-2xl bg-primary/10 text-primary flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">groups</i>
          </figure>

          <section>
            <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Alunos ativos</p>
            <data value="<%= estatisticasSeguras.total_alunos %>" class="text-3xl font-black headline text-on-surface">
              <%= estatisticasSeguras.total_alunos %>
            </data>
          </section>
        </article>

        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-6 shadow-sm flex items-center gap-4">
          <figure class="w-14 h-14 rounded-2xl bg-secondary/10 text-secondary flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">movie_filter</i>
          </figure>

          <section>
            <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Vídeos publicados</p>
            <data value="<%= estatisticasSeguras.total_videos %>" class="text-3xl font-black headline text-on-surface">
              <%= estatisticasSeguras.total_videos %>
            </data>
          </section>
        </article>

        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-6 shadow-sm flex items-center gap-4">
          <figure class="w-14 h-14 rounded-2xl bg-tertiary-fixed/20 text-on-tertiary-fixed flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">auto_graph</i>
          </figure>

          <section>
            <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Progressão média</p>
            <data value="<%= estatisticasSeguras.media_progressao %>" class="text-3xl font-black headline text-on-surface">
              <%= estatisticasSeguras.media_progressao %>%
            </data>
          </section>
        </article>

        <article class="card-mobile bg-primary rounded-3xl p-6 shadow-xl shadow-primary/20 flex items-center gap-4 text-white">
          <figure class="w-14 h-14 rounded-2xl bg-white/20 text-white flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">forum</i>
          </figure>

          <section>
            <p class="text-xs font-black uppercase tracking-widest text-white/70">Feedbacks novos</p>
            <data value="<%= estatisticasSeguras.feedbacks_pendentes %>" class="text-3xl font-black headline text-white">
              <%= estatisticasSeguras.feedbacks_pendentes %>
            </data>
          </section>
        </article>

      </section>

      <section class="card-mobile md:col-span-8 bg-surface-container-lowest rounded-3xl p-8 shadow-sm tabela-alunos">

        <header class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
          <hgroup>
            <h2 class="text-2xl font-extrabold headline text-on-surface">Meus Alunos</h2>
            <p class="text-sm text-on-surface-variant mt-1">
              Alunos vinculados às suas fichas de treino ativas.
            </p>
          </hgroup>

          <a class="inline-flex items-center justify-center gap-2 bg-primary text-white px-6 py-3 rounded-full font-bold shadow-lg shadow-primary/20 active:scale-95 transition-transform" href="/todosalunos">
            Ver todos
            <i class="material-symbols-outlined not-italic" aria-hidden="true">arrow_forward</i>
          </a>
        </header>

        <% if (alunosSeguros.length > 0) { %>
          <section class="overflow-x-auto">
            <table class="w-full text-left border-separate border-spacing-y-3">
              <thead>
                <tr class="text-on-surface-variant text-xs uppercase tracking-widest">
                  <th class="px-4 py-2">Aluno</th>
                  <th class="px-4 py-2">Progresso</th>
                  <th class="px-4 py-2">Treinos</th>
                  <th class="px-4 py-2">Status</th>
                  <th class="px-4 py-2 text-right">Ação</th>
                </tr>
              </thead>

              <tbody class="text-sm">
                <% alunosSeguros.forEach(function(alunoItem) { %>
                  <%
                    const progressoAluno = calcularProgressoAluno(alunoItem)
                    const status = statusAluno(alunoItem)
                    const classeStatus = classeStatusAluno(alunoItem)
                  %>

                  <tr class="bg-surface-container-low hover:bg-surface-container-highest transition-colors">
                    <td class="px-4 py-4 rounded-l-3xl">
                      <article class="flex items-center gap-3">
                        <figure class="w-11 h-11 rounded-full overflow-hidden m-0 avatar-placeholder flex items-center justify-center shrink-0">
                          <% if (alunoItem.foto_perfil) { %>
                            <img alt="Foto de <%= alunoItem.nome %>" src="<%= alunoItem.foto_perfil %>" class="w-full h-full object-cover">
                          <% } else { %>
                            <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
                          <% } %>
                        </figure>

                        <hgroup>
                          <p class="font-black text-on-surface"><%= alunoItem.nome %></p>
                          <p class="text-xs text-on-surface-variant">
                            <%= alunoItem.plano || 'Sem plano' %>
                          </p>
                        </hgroup>
                      </article>
                    </td>

                    <td class="px-4 py-4">
                      <section class="flex items-center gap-3 min-w-[140px]">
                        <progress class="flex-1 h-3 rounded-full overflow-hidden" value="<%= progressoAluno %>" max="100">
                          <%= progressoAluno %>%
                        </progress>
                        <strong class="w-10 text-xs font-black text-primary"><%= progressoAluno %>%</strong>
                      </section>
                    </td>

                    <td class="px-4 py-4">
                      <p class="font-black text-on-surface"><%= alunoItem.total_treinos || 0 %></p>
                      <p class="text-xs text-on-surface-variant">
                        <%= alunoItem.tempo_total_min || 0 %> min semana
                      </p>
                    </td>

                    <td class="px-4 py-4">
                      <section class="inline-flex items-center gap-2 bg-surface-container-lowest px-3 py-2 rounded-full">
                        <i class="h-2 w-2 rounded-full <%= classeStatus %> inline-block"></i>
                        <b class="text-xs font-black"><%= status %></b>
                      </section>
                    </td>

                    <td class="px-4 py-4 text-right rounded-r-3xl">
                      <a href="/visaoperfilaluno?id_aluno=<%= alunoItem.id_aluno %>" class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary/10 text-primary hover:bg-primary hover:text-white transition-colors" aria-label="Ver perfil do aluno">
                        <i class="material-symbols-outlined not-italic" aria-hidden="true">visibility</i>
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </section>
        <% } else { %>
          <section class="bg-surface-container-low rounded-3xl p-8 text-center">
            <i class="material-symbols-outlined text-primary text-6xl not-italic mb-3" aria-hidden="true">groups</i>
            <h3 class="text-xl font-black headline text-on-surface">Nenhum aluno vinculado ainda</h3>
            <p class="text-sm text-on-surface-variant mt-2">
              Quando um aluno for associado a uma ficha sua, ele aparecerá aqui.
            </p>
          </section>
        <% } %>
      </section>

      <aside class="md:col-span-4 flex flex-col gap-6">

        <article class="card-mobile bg-primary rounded-3xl p-8 text-white relative overflow-hidden shadow-xl shadow-primary/30">
          <i class="material-symbols-outlined text-white text-8xl opacity-10 not-italic absolute -top-4 -right-4" aria-hidden="true">insights</i>

          <p class="inline-flex items-center gap-2 bg-white/15 rounded-full px-4 py-2 text-xs font-black uppercase tracking-widest mb-6">
            <i class="material-symbols-outlined not-italic text-sm" aria-hidden="true">trending_up</i>
            Evolução geral
          </p>

          <h2 class="text-2xl font-extrabold headline mb-2">Progressão média</h2>

          <p class="text-white/80 text-sm leading-relaxed mb-8">
            Média de conclusão semanal dos alunos vinculados às suas fichas ativas.
          </p>

          <strong class="text-6xl font-black block">
            <%= estatisticasSeguras.media_progressao %>%
          </strong>

          <small class="text-white/70 font-bold uppercase tracking-widest">da meta semanal</small>
        </article>

        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-8 shadow-sm flex flex-col gap-5">
          <header class="flex items-center justify-between">
            <h2 class="text-xl font-extrabold headline">Atalhos</h2>
            <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">bolt</i>
          </header>

          <nav class="flex flex-col gap-3" aria-label="Atalhos do professor">
            <a href="/feedbackprofessor" class="flex items-center justify-between gap-4 bg-surface-container-low rounded-2xl p-4 hover:bg-surface-container-highest transition-colors">
              <span class="flex items-center gap-3">
                <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">forum</i>
                <b class="text-sm">Responder feedbacks</b>
              </span>
              <strong class="text-xs text-primary"><%= estatisticasSeguras.feedbacks_pendentes %></strong>
            </a>

            <a href="/todosvideos" class="flex items-center justify-between gap-4 bg-surface-container-low rounded-2xl p-4 hover:bg-surface-container-highest transition-colors">
              <span class="flex items-center gap-3">
                <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">video_library</i>
                <b class="text-sm">Gerenciar vídeos</b>
              </span>
              <i class="material-symbols-outlined text-outline not-italic" aria-hidden="true">arrow_forward</i>
            </a>

            <a href="/editarexercicios" class="flex items-center justify-between gap-4 bg-surface-container-low rounded-2xl p-4 hover:bg-surface-container-highest transition-colors">
              <span class="flex items-center gap-3">
                <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">edit_note</i>
                <b class="text-sm">Editar exercícios</b>
              </span>
              <i class="material-symbols-outlined text-outline not-italic" aria-hidden="true">arrow_forward</i>
            </a>
          </nav>
        </article>

      </aside>

      <section class="card-mobile md:col-span-12 bg-surface-container-low rounded-3xl p-8 flex flex-col gap-6">

        <header class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <hgroup>
            <h2 class="text-2xl font-extrabold headline text-on-surface">Biblioteca de Vídeos</h2>
            <p class="text-sm text-on-surface-variant mt-1">
              Últimos vídeos cadastrados pelo professor.
            </p>
          </hgroup>

          <a href="/todosvideos" class="inline-flex items-center justify-center gap-2 bg-primary text-white px-6 py-3 rounded-full font-bold shadow-lg shadow-primary/20 active:scale-95 transition-transform">
            Gerenciar vídeos
            <i class="material-symbols-outlined not-italic" aria-hidden="true">arrow_forward</i>
          </a>
        </header>

        <% if (videosSeguros.length > 0) { %>
          <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 list-none p-0 m-0">
            <% videosSeguros.forEach(function(video) { %>
              <li class="bg-surface-container-lowest rounded-3xl overflow-hidden shadow-sm group hover:shadow-lg transition-all">
                <figure class="relative aspect-video overflow-hidden m-0 bg-surface-container-highest">
                  <% if (video.thumbnail) { %>
                    <img
                      alt="Thumbnail do vídeo <%= video.titulo %>"
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                      src="<%= video.thumbnail %>"
                    />
                  <% } else { %>
                    <span class="w-full h-full flex items-center justify-center">
                      <i class="material-symbols-outlined text-primary text-6xl not-italic" aria-hidden="true">play_circle</i>
                    </span>
                  <% } %>

                  <figcaption class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                    <i class="material-symbols-outlined text-white text-4xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">play_arrow</i>
                  </figcaption>

                  <time class="absolute bottom-2 right-2 bg-black/70 text-white text-[10px] font-bold px-2 py-1 rounded">
                    <%= segundosParaMinutos(video.duracao_seg) %>
                  </time>
                </figure>

                <section class="p-4">
                  <h3 class="font-black text-on-surface line-clamp-1"><%= video.titulo %></h3>
                  <p class="text-xs text-on-surface-variant mt-1">
                    <%= video.categoria || 'Sem categoria' %> • <%= video.nivel || 'Nível livre' %>
                  </p>

                  <time datetime="<%= video.criado_em %>" class="text-xs text-on-surface-variant block mt-2 mb-3">
                    <%= dataFormatada(video.criado_em) %>
                  </time>

                  <nav class="flex justify-between pt-3 border-t border-surface-container">
                    <a href="/editarexercicios?id_video=<%= video.id_video %>" class="flex items-center gap-1 text-primary text-xs font-bold hover:underline">
                      <i class="material-symbols-outlined text-sm not-italic" aria-hidden="true">edit</i>
                      Editar
                    </a>

                    <a href="/todosvideos" class="flex items-center gap-1 text-on-surface-variant text-xs font-bold hover:text-primary">
                      <i class="material-symbols-outlined text-sm not-italic" aria-hidden="true">visibility</i>
                      Ver
                    </a>
                  </nav>
                </section>
              </li>
            <% }) %>

            <li>
              <a href="/todosvideos" class="bg-surface-container-low border-2 border-dashed border-outline-variant rounded-3xl flex flex-col items-center justify-center min-h-[220px] group cursor-pointer hover:bg-surface-container transition-all h-full">
                <figure class="w-12 h-12 bg-surface-container-lowest rounded-full flex items-center justify-center text-primary shadow-sm group-hover:scale-110 transition-transform mb-3 m-0">
                  <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">add</i>
                </figure>
                <strong class="text-on-surface-variant text-sm">Adicionar Vídeo</strong>
              </a>
            </li>
          </ul>
        <% } else { %>
          <section class="bg-surface-container-lowest rounded-3xl p-8 text-center">
            <i class="material-symbols-outlined text-primary text-6xl not-italic mb-3" aria-hidden="true">video_library</i>
            <h3 class="text-xl font-black headline text-on-surface">Nenhum vídeo cadastrado ainda</h3>
            <p class="text-sm text-on-surface-variant mt-2">
              Cadastre seus vídeos para que eles apareçam aqui no painel.
            </p>

            <a href="/todosvideos" class="inline-flex items-center justify-center gap-2 bg-primary text-white px-6 py-3 rounded-full font-bold mt-5">
              Adicionar vídeo
              <i class="material-symbols-outlined not-italic" aria-hidden="true">add</i>
            </a>
          </section>
        <% } %>

      </section>

    </section>
  </main>

  <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex justify-around items-end px-4 pb-6 pt-2 bg-[#f7f5ff]/90 backdrop-blur-lg shadow-[0_-10px_40px_rgba(35,44,81,0.08)] rounded-t-[32px]"
       aria-label="Navegação mobile">

    <a href="/painelprofessor"
       class="flex flex-col items-center justify-center text-[#0058ba] opacity-100 p-3 rounded-[18px] bg-[#d5dbff]"
       aria-current="page">
      <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">dashboard</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Início</em>
    </a>

    <a href="/todosalunos"
       class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">groups</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Alunos</em>
    </a>

    <a href="/todosvideos"
       class="bg-primary text-white w-14 h-14 rounded-full shadow-lg shadow-primary/40 -mt-8 flex items-center justify-center active:scale-95 transition-transform"
       aria-label="Adicionar ou gerenciar conteúdo">
      <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">add</i>
    </a>

    <a href="/todosvideos"
       class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">video_library</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Vídeos</em>
    </a>

    <a href="/feedbackprofessor"
       class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Feedback</em>
    </a>

  </nav>

</body>
</html>