<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>PlanoB Pro - Painel do Professor</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface-tint": "#0058ba",
            "surface-container-high": "#dde1ff",
            "tertiary": "#6c5a00",
            "surface-container": "#e4e7ff",
            "primary-container": "#6c9fff",
            "on-primary-fixed": "#000000",
            "on-secondary-fixed": "#003a48",
            "primary-dim": "#004da4",
            "outline": "#6c759e",
            "primary-fixed": "#6c9fff",
            "secondary-fixed-dim": "#37d4ff",
            "on-primary-container": "#00214e",
            "surface-dim": "#cad2ff",
            "secondary-dim": "#00576c",
            "on-error-container": "#570008",
            "on-tertiary-container": "#5b4b00",
            "background": "#f7f5ff",
            "error-dim": "#9f0519",
            "on-secondary-container": "#004e61",
            "error-container": "#fb5151",
            "tertiary-dim": "#5e4e00",
            "outline-variant": "#a2abd7",
            "on-surface-variant": "#505a81",
            "tertiary-fixed-dim": "#efc900",
            "surface-bright": "#f7f5ff",
            "tertiary-fixed": "#ffd709",
            "error": "#b31b25",
            "inverse-surface": "#020a2f",
            "surface-container-lowest": "#ffffff",
            "primary-fixed-dim": "#5091ff",
            "on-primary-fixed-variant": "#002a60",
            "on-secondary-fixed-variant": "#00586d",
            "surface-variant": "#d5dbff",
            "on-surface": "#232c51",
            "on-tertiary-fixed": "#453900",
            "on-secondary": "#e2f6ff",
            "surface-container-highest": "#d5dbff",
            "inverse-primary": "#4a8eff",
            "on-error": "#ffefee",
            "tertiary-container": "#ffd709",
            "on-tertiary": "#fff2cd",
            "secondary-container": "#80deff",
            "surface-container-low": "#efefff",
            "on-primary": "#f0f2ff",
            "on-tertiary-fixed-variant": "#665500",
            "inverse-on-surface": "#929bc6",
            "surface": "#f7f5ff",
            "primary": "#0058ba",
            "secondary-fixed": "#80deff",
            "on-background": "#232c51",
            "secondary": "#00647b"
          },
          borderRadius: {
            DEFAULT: "0.25rem",
            lg: "0.5rem",
            xl: "0.75rem",
            full: "9999px"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"],
            label: ["Manrope"]
          }
        }
      }
    }
  </script>

  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }
    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }
    .logo-header { font-size: 2.7rem; line-height: 1; }
    body { font-family: 'Manrope', sans-serif; }
    h1, h2, h3, h4 { font-family: 'Lexend', sans-serif; }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }
    .action-gradient { background: linear-gradient(135deg, #0058ba 0%, #6c9fff 100%); }

    @media (max-width: 768px) {
      html, body { width: 100%; overflow-x: hidden; }
      main { margin-left: 0 !important; padding: 88px 16px 120px !important; }
      nav[aria-label="Navegação mobile"] a[aria-current="page"],
      nav[aria-label="Navegação mobile"] a.ativo {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
        border-radius: 18px;
      }
    }
  </style>
</head>

<body class="bg-surface text-on-surface min-h-screen">

  <!-- Header -->
  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">
    <nav class="flex items-center gap-4" aria-label="Identificação">
      <strong class="font-headline logo-font logo-header text-primary">PlanoB</strong>
    </nav>

    <section class="hidden md:flex items-center bg-surface-container-low px-4 py-2 rounded-full">
      <i class="material-symbols-outlined text-outline text-sm not-italic" aria-hidden="true">search</i>
      <label for="top-search" class="sr-only">Buscar alunos</label>
      <input id="top-search" class="bg-transparent border-none focus:ring-0 text-sm w-48 ml-2" placeholder="Buscar alunos..." type="search"/>
    </section>

    <menu class="flex items-center gap-2 p-0 m-0">
      <li>
        <button class="p-2 rounded-full hover:bg-surface-container transition-colors" aria-label="Notificações">
          <i class="material-symbols-outlined text-on-background not-italic" aria-hidden="true">notifications</i>
        </button>
      </li>
      <li>
        <figure class="h-9 w-9 rounded-full overflow-hidden border-2 border-primary/20 m-0">
          <img alt="Foto do professor" class="w-full h-full object-cover"
               src="https://lh3.googleusercontent.com/aida-public/AB6AXuC-kiaRQYK7av_KMT9U2SDRD1NM2IGc--Kg1YlIKK1R-W7ljjtsw-N-jVurdmUlRJXaZo5z6SzADa4_DsYyeFBfdpSPu5gVaeVzeFbnrDWWfBBRQ1VCOz9kK-7cS9aWLwcZRGVacdSz_UQthSRccjvezgaCUt7DZBacdnmvtEpnooa6nNewiCtyLW0w51AeHOq_3OGOMdzIOD3ICgFVZ36UqQ486f7DnbQcy7Q-PLy7wmKYOW5PpnGC8KvX7lUWGg9shAKAL2rcw_ft"/>
        </figure>
      </li>
    </menu>
    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <!-- Sidebar Desktop -->
  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] flex-col gap-2 py-8 z-40 mt-16">
    <header class="px-6 mb-6">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <picture>
          <img class="w-12 h-12 rounded-full object-cover"
               src="https://lh3.googleusercontent.com/aida-public/AB6AXuC-kiaRQYK7av_KMT9U2SDRD1NM2IGc--Kg1YlIKK1R-W7ljjtsw-N-jVurdmUlRJXaZo5z6SzADa4_DsYyeFBfdpSPu5gVaeVzeFbnrDWWfBBRQ1VCOz9kK-7cS9aWLwcZRGVacdSz_UQthSRccjvezgaCUt7DZBacdnmvtEpnooa6nNewiCtyLW0w51AeHOq_3OGOMdzIOD3ICgFVZ36UqQ486f7DnbQcy7Q-PLy7wmKYOW5PpnGC8KvX7lUWGg9shAKAL2rcw_ft"
               alt="Foto de perfil do professor"/>
        </picture>
        <figcaption>
          <p class="text-sm font-bold text-on-surface">Portal do Professor</p>
          <p class="text-xs text-on-surface-variant">Bem-vindo de volta</p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-primary/20 px-4 py-3 flex items-center gap-3 active:scale-95"
         href="/painelprofessor" aria-current="page">
        <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">dashboard</i>
        <em class="not-italic font-medium">Dashboard</em>
      </a>
      <a class="text-on-surface hover:bg-surface-container/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all"
         href="/todosalunos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">groups</i>
        <em class="not-italic font-medium">Meus Alunos</em>
      </a>
      <a class="text-on-surface hover:bg-surface-container/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all"
         href="/todosvideos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">video_library</i>
        <em class="not-italic font-medium">Meus Vídeos</em>
      </a>
      <a class="text-on-surface hover:bg-surface-container/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all"
         href="#">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">assignment</i>
        <em class="not-italic font-medium">Avaliações</em>
      </a>
      <a class="text-on-surface hover:bg-surface-container/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all"
         href="#">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">settings</i>
        <em class="not-italic font-medium">Configurações</em>
      </a>
    </nav>

    <footer class="mt-auto px-4 pb-8 flex flex-col gap-2">
      <button class="w-full bg-primary text-on-primary rounded-full py-4 font-bold shadow-lg shadow-primary/30 flex items-center justify-center gap-2 active:scale-95 transition-transform">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">add_circle</i>
        Novo Conteúdo
      </button>
      <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:text-error rounded-full hover:bg-surface-container transition-colors text-sm"
         href="#">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i>
        <em class="not-italic">Sair</em>
      </a>
    </footer>
  </aside>

  <!-- Main -->
  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto space-y-8">

      <!-- Bento Header -->
      <header class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- CTA Principal Upload -->
        <article class="md:col-span-2 action-gradient p-8 rounded-3xl text-white relative overflow-hidden flex flex-col justify-center min-h-[280px]">
          <section class="relative z-10 max-w-md">
            <h1 class="text-3xl font-headline font-bold mb-3 leading-tight">Envie novas aulas em segundos.</h1>
            <p class="text-blue-100 mb-6 text-sm">Arraste seus vídeos para a biblioteca e organize suas turmas com precisão.</p>
            <label class="group relative bg-white/10 hover:bg-white/20 border-2 border-dashed border-white/30 rounded-2xl p-8 flex flex-col items-center justify-center cursor-pointer transition-all">
              <i class="material-symbols-outlined text-5xl mb-2 transition-transform group-hover:-translate-y-1 not-italic" aria-hidden="true">cloud_upload</i>
              <strong class="text-lg">Solte o vídeo aqui</strong>
              <small class="text-blue-200 mt-1">ou clique para selecionar (até 2GB)</small>
              <input type="file" class="hidden" accept="video/*"/>
            </label>
          </section>
          <b class="absolute -right-20 -bottom-20 w-80 h-80 bg-white/10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        </article>

        <!-- Mini Stats -->
        <section class="flex flex-col gap-4">
          <article class="bg-surface-container-lowest p-6 rounded-3xl shadow-sm flex items-center gap-4">
            <figure class="bg-primary/10 text-primary p-3 rounded-2xl m-0">
              <i class="material-symbols-outlined text-3xl not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">groups</i>
            </figure>
            <section>
              <h4 class="text-sm text-on-surface-variant font-medium">Alunos Ativos</h4>
              <data value="1240" class="text-2xl font-headline font-bold">1.240</data>
            </section>
          </article>
          <article class="bg-surface-container-lowest p-6 rounded-3xl shadow-sm flex items-center gap-4">
            <figure class="bg-secondary/10 text-secondary p-3 rounded-2xl m-0">
              <i class="material-symbols-outlined text-3xl not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">movie_filter</i>
            </figure>
            <section>
              <h4 class="text-sm text-on-surface-variant font-medium">Vídeos</h4>
              <data value="48" class="text-2xl font-headline font-bold">48</data>
            </section>
          </article>
          <article class="bg-surface-container-lowest p-6 rounded-3xl shadow-sm flex items-center gap-4">
            <figure class="bg-tertiary-container/50 text-tertiary p-3 rounded-2xl m-0">
              <i class="material-symbols-outlined text-3xl not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">auto_graph</i>
            </figure>
            <section>
              <h4 class="text-sm text-on-surface-variant font-medium">Conclusão Média</h4>
              <data value="76" class="text-2xl font-headline font-bold">76%</data>
            </section>
          </article>
        </section>
      </header>

      <!-- Tabela de Alunos -->
      <section class="bg-surface-container-lowest rounded-3xl p-6 shadow-sm">
        <header class="flex justify-between items-center mb-6">
          <section class="flex items-center gap-3">
            <b class="w-2 h-8 bg-primary rounded-full font-normal" aria-hidden="true"></b>
            <h3 class="text-xl font-bold font-headline">Meus Alunos</h3>
          </section>
          <a class="text-primary font-bold text-sm flex items-center gap-1 hover:underline group" href="/todosalunos">
            Ver Todos
            <i class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform not-italic" aria-hidden="true">arrow_forward_ios</i>
          </a>
        </header>

        <section class="overflow-x-auto">
          <table class="w-full text-left border-separate border-spacing-y-2">
            <thead>
              <tr class="text-on-surface-variant text-xs uppercase tracking-wider">
                <th class="px-4 py-2">Estudante</th>
                <th class="px-4 py-2">Progresso</th>
                <th class="px-4 py-2">Status</th>
                <th class="px-4 py-2 text-right">Ações</th>
              </tr>
            </thead>
            <tbody class="text-sm">
              <tr class="hover:bg-surface-container-low transition-colors">
                <td class="px-4 py-3 rounded-l-2xl">
                  <article class="flex items-center gap-3">
                    <figure class="w-10 h-10 rounded-full bg-surface-container overflow-hidden m-0">
                      <img alt="Ana Clara" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCOU0aUPaOLRZzrrdHUs04eihb_UNxSsmbqYgBLBpS7UftLd0iGYTIRLJ6V9cAnVqyOMh7j2NnyNEMDoZeEb8JTjywn6XxZym36Txykxt9ACP0oJxFl5DMdOX2PJQ8eZ7_6Gf5LxxxxBE3amKs6lyUhf91kpoMeAvmhZu95Y_fXBB7EGRnlF_xdVhDAuD8qDvr-QM8W_C6Obs_dNp9X6b9Orcw2kqtA-d2fJBqZrjRy7q9nZEAya6p4RebWrh6TRUt3ImmHm6hEA3kl"/>
                    </figure>
                    <hgroup>
                      <p class="font-bold text-on-surface">Ana Clara Silva</p>
                      <p class="text-xs text-on-surface-variant">Plano Lazuli</p>
                    </hgroup>
                  </article>
                </td>
                <td class="px-4 py-3">
                  <section class="flex items-center gap-3">
                    <progress class="flex-1 h-2 min-w-[80px] appearance-none" value="85" max="100" style="accent-color:#0058ba"></progress>
                    <strong class="w-8 text-xs font-bold text-primary">85%</strong>
                  </section>
                </td>
                <td class="px-4 py-3">
                  <section class="flex items-center gap-1.5">
                    <i class="h-2 w-2 rounded-full bg-emerald-500 inline-block"></i>
                    <b class="text-xs font-bold">Ativo</b>
                  </section>
                </td>
                <td class="px-4 py-3 text-right rounded-r-2xl">
                  <button class="text-on-surface-variant hover:text-primary p-2 rounded-full hover:bg-surface-container transition-colors">
                    <i class="material-symbols-outlined not-italic" aria-hidden="true">more_vert</i>
                  </button>
                </td>
              </tr>
            </tbody>
          </table>
        </section>
      </section>

      <!-- Biblioteca de Vídeos -->
      <section class="space-y-4">
        <header class="flex items-center gap-3">
          <b class="w-2 h-8 bg-secondary rounded-full font-normal" aria-hidden="true"></b>
          <h3 class="text-xl font-bold font-headline">Biblioteca de Vídeos</h3>
        </header>

        <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <article class="bg-surface-container-lowest rounded-3xl overflow-hidden shadow-sm group hover:shadow-lg transition-all">
            <figure class="relative aspect-video overflow-hidden m-0">
              <img alt="Thumbnail do vídeo"
                   class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                   src="https://lh3.googleusercontent.com/aida-public/AB6AXuDYW4lYK1KF2OYkl-77anASJD1c4zyYSV6otvc5MqAPpAQcbHTT-ATFataDkZcL5qfF3s8hUTobSG-osLT3AFNl0GqqQJXkADH1wwV62NYR1i9CkUMITAV7q1w85vH1W38xUjbxXvB6_0IrPOWoI8muGUaIzZsdbAsrzoehQyGZ0W-KW4J0I1oq1Eqzr6dA27RXE9PCsmp8cky62n2jd_SvHNCO5B3tFZ-zlX2bgDpsSCeOEV97Ipd90Iu9kLRcT3mwrmxlna6ziQub"/>
              <figcaption class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <i class="material-symbols-outlined text-white text-4xl not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">play_arrow</i>
              </figcaption>
              <time class="absolute bottom-2 right-2 bg-black/70 text-white text-[10px] font-bold px-2 py-1 rounded">12:45</time>
            </figure>
            <section class="p-4">
              <h4 class="font-bold text-on-surface line-clamp-1">Fundamentos do Agachamento</h4>
              <time datetime="2024-01-12" class="text-xs text-on-surface-variant block mb-3">12 Jan, 2024</time>
              <nav class="flex justify-between pt-3 border-t border-surface-container">
                <a href="/editarexercicios" class="flex items-center gap-1 text-primary text-xs font-bold hover:underline">
                  <i class="material-symbols-outlined text-sm not-italic" aria-hidden="true">edit</i> Editar
                </a>
                <button class="flex items-center gap-1 text-error text-xs font-bold hover:underline">
                  <i class="material-symbols-outlined text-sm not-italic" aria-hidden="true">delete</i> Excluir
                </button>
              </nav>
            </section>
          </article>

          <!-- Card Adicionar Vídeo -->
          <label class="bg-surface-container-low border-2 border-dashed border-outline-variant rounded-3xl flex flex-col items-center justify-center min-h-[220px] group cursor-pointer hover:bg-surface-container transition-all">
            <figure class="w-12 h-12 bg-surface-container-lowest rounded-full flex items-center justify-center text-primary shadow-sm group-hover:scale-110 transition-transform mb-3 m-0">
              <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">add</i>
            </figure>
            <strong class="text-on-surface-variant text-sm">Adicionar Vídeo</strong>
            <input type="file" class="hidden" accept="video/*"/>
          </label>
        </section>
      </section>

    </section>
  </main>

  <!-- Menu Mobile com botão + centralizado -->
  <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex justify-around items-end px-4 pb-6 pt-2
              bg-[#f7f5ff]/90 backdrop-blur-lg shadow-[0_-10px_40px_rgba(35,44,81,0.08)] rounded-t-[32px]"
       aria-label="Navegação mobile">

    <a href="/painelprofessor"
       class="mobile-link flex flex-col items-center justify-center text-[#232c51] opacity-100 p-3 rounded-[18px] bg-[#d5dbff]"
       aria-current="page" data-page="painelprofessor">
      <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">dashboard</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Início</em>
    </a>

    <a href="/todosalunos"
       class="mobile-link flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity"
       data-page="todosalunos">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">groups</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Alunos</em>
    </a>

    <!-- Botão + central -->
    <button class="bg-primary text-white w-14 h-14 rounded-full shadow-lg shadow-primary/40 -mt-8 flex items-center justify-center active:scale-95 transition-transform"
            aria-label="Adicionar novo conteúdo">
      <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">add</i>
    </button>

    <a href="/todosvideos"
       class="mobile-link flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity"
       data-page="todosvideos">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">video_library</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Vídeos</em>
    </a>

    <a href="#"
       class="mobile-link flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity"
       data-page="perfil">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">person</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Perfil</em>
    </a>
  </nav>

  <script src="/js/validacoes.js"></script>
</body>
</html>
