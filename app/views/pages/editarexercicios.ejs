<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>PlanoB - Editar Exercício</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script id="tailwind-config">
    tailwind.config = {
      darkMode:"class",
      theme:{ extend:{
        colors:{
          "surface-tint":"#0058ba","surface-container-high":"#dde1ff","tertiary":"#6c5a00",
          "surface-container":"#e4e7ff","primary-container":"#6c9fff","primary-dim":"#004da4",
          "outline":"#6c759e","primary-fixed":"#6c9fff","on-primary-container":"#00214e",
          "surface-dim":"#cad2ff","secondary-dim":"#00576c","background":"#f7f5ff",
          "on-secondary-container":"#004e61","error-container":"#fb5151","tertiary-dim":"#5e4e00",
          "outline-variant":"#a2abd7","on-surface-variant":"#505a81","tertiary-fixed-dim":"#efc900",
          "surface-bright":"#f7f5ff","tertiary-fixed":"#ffd709","error":"#b31b25",
          "inverse-surface":"#020a2f","surface-container-lowest":"#ffffff","primary-fixed-dim":"#5091ff",
          "surface-variant":"#d5dbff","on-surface":"#232c51","surface-container-highest":"#d5dbff",
          "inverse-primary":"#4a8eff","tertiary-container":"#ffd709","on-tertiary":"#fff2cd",
          "secondary-container":"#80deff","surface-container-low":"#efefff","on-primary":"#f0f2ff",
          "inverse-on-surface":"#929bc6","surface":"#f7f5ff","primary":"#0058ba",
          "on-background":"#232c51","secondary":"#00647b","on-tertiary-fixed":"#453900",
          "on-tertiary-container":"#5b4b00","on-tertiary-fixed-variant":"#665500",
          "on-error":"#ffefee","on-error-container":"#570008","error-dim":"#9f0519"
        },
        borderRadius:{ DEFAULT:"0.25rem", lg:"0.5rem", xl:"0.75rem", full:"9999px" },
        fontFamily:{ headline:["Lexend"], body:["Manrope"], label:["Manrope"] }
      }}
    }
  </script>
  <style>
    @font-face { font-family:'Baumans'; src:url('/fonts/Baumans-Regular.ttf') format('truetype'); }
    .logo-font { font-family:'Baumans',sans-serif !important; font-weight:400 !important; letter-spacing:0.02em; }
    .logo-header { font-size:2.7rem; line-height:1; }
    body { font-family:'Manrope',sans-serif; }
    h1,h2,h3,h4 { font-family:'Lexend',sans-serif; }
    .material-symbols-outlined { font-variation-settings:'FILL' 0,'wght' 400,'GRAD' 0,'opsz' 24; vertical-align:middle; }
    .action-gradient { background:linear-gradient(135deg,#0058ba 0%,#6c9fff 100%); }
    @media (max-width:768px) {
      html,body { overflow-x:hidden; }
      main { margin-left:0 !important; padding:88px 16px 120px !important; }
    }
  </style>
</head>
<body class="bg-surface text-on-surface min-h-screen">

  <!-- Header -->
  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">
    <strong class="font-headline logo-font logo-header text-primary">PlanoB</strong>
    <menu class="flex items-center gap-3 p-0 m-0">
      <li><button class="px-6 py-2 rounded-full border border-outline-variant/30 text-on-surface font-semibold hover:bg-surface-container transition-colors active:scale-95 text-sm">Cancelar</button></li>
      <li><button class="px-8 py-2 rounded-full action-gradient text-white font-bold shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all active:scale-95 text-sm">Salvar Alterações</button></li>
    </menu>
    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <!-- Sidebar Desktop -->
  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] flex-col gap-2 py-8 z-40 mt-16">
    <header class="px-6 mb-6">
      <figure class="flex items-center gap-3 m-0">
        <picture><img class="w-12 h-12 rounded-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC-kiaRQYK7av_KMT9U2SDRD1NM2IGc--Kg1YlIKK1R-W7ljjtsw-N-jVurdmUlRJXaZo5z6SzADa4_DsYyeFBfdpSPu5gVaeVzeFbnrDWWfBBRQ1VCOz9kK-7cS9aWLwcZRGVacdSz_UQthSRccjvezgaCUt7DZBacdnmvtEpnooa6nNewiCtyLW0w51AeHOq_3OGOMdzIOD3ICgFVZ36UqQ486f7DnbQcy7Q-PLy7wmKYOW5PpnGC8KvX7lUWGg9shAKAL2rcw_ft" alt="Professor"/></picture>
        <figcaption><p class="text-sm font-bold text-on-surface">Portal do Professor</p><p class="text-xs text-on-surface-variant">Bem-vindo de volta</p></figcaption>
      </figure>
    </header>
    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="text-on-surface hover:bg-surface-container/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all" href="/painelprofessor"><i class="material-symbols-outlined not-italic" aria-hidden="true">dashboard</i><em class="not-italic font-medium">Dashboard</em></a>
      <a class="text-on-surface hover:bg-surface-container/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all" href="/todosalunos"><i class="material-symbols-outlined not-italic" aria-hidden="true">groups</i><em class="not-italic font-medium">Meus Alunos</em></a>
      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-primary/20 px-4 py-3 flex items-center gap-3" href="/todosvideos" aria-current="page"><i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">video_library</i><em class="not-italic font-medium">Meus Vídeos</em></a>
      <a class="text-on-surface hover:bg-surface-container/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all" href="#"><i class="material-symbols-outlined not-italic" aria-hidden="true">assignment</i><em class="not-italic font-medium">Avaliações</em></a>

    </nav>
    <footer class="mt-auto px-4 pb-8 flex flex-col gap-2">
      <button class="w-full bg-primary text-on-primary rounded-full py-4 font-bold shadow-lg shadow-primary/30 flex items-center justify-center gap-2 active:scale-95 transition-transform"><i class="material-symbols-outlined not-italic" aria-hidden="true">add_circle</i>Novo Conteúdo</button>
      <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:text-error rounded-full hover:bg-surface-container transition-colors text-sm" href="#"><i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i><em class="not-italic">Sair</em></a>
    </footer>
  </aside>

  <!-- Main -->
  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 lg:px-12 min-h-screen">

    <!-- Page Header -->
    <section class="max-w-6xl mx-auto mb-8">
      <nav class="flex items-center gap-2 text-sm text-on-surface-variant mb-2" aria-label="Breadcrumb">
        <a href="/todosvideos" class="hover:text-primary transition-colors">Vídeos</a>
        <i class="material-symbols-outlined text-xs not-italic" aria-hidden="true">chevron_right</i>
        <em class="text-primary font-semibold not-italic" aria-current="page">Editar Exercício</em>
      </nav>
      <h1 class="text-4xl md:text-5xl font-black text-on-surface tracking-tight leading-tight uppercase">Editar Exercício</h1>
    </section>

    <!-- Editor Grid -->
    <article class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8">

      <!-- Esquerda: Preview + Upload -->
      <section class="lg:col-span-5 space-y-6">
        <figure class="relative group aspect-video rounded-2xl overflow-hidden bg-surface-container-highest shadow-xl m-0">
          <img class="w-full h-full object-cover" alt="Preview do exercício"
               src="https://lh3.googleusercontent.com/aida-public/AB6AXuBCrD3OmtjFwpKNFYU8gCMCG6tjQviowsRyMfntMdnN1Djdx_xYvj9MvFxOwqRXyfCf_6EjiDDxx155OmOF9SgKvjR_2SevCd6XpyeVl8gbUC8ZLUbWajcspF2M7oTdbS6SBrsPc1K5SVeS8pxtiCbkh_5D_XKUThtBO1Ytxa5Mvxb9_ho2wNsPWMtgSc2Wn3VsvWsG9z9KIAIUGEYYXWvt5Xoffeya4tOr9oicveNvI-d-f8DvTn2QxBN211VWuFDKBwrNBw4ksw34"/>
          <aside class="absolute inset-0 bg-black/40 flex items-center justify-center group-hover:bg-black/20 transition-all" aria-hidden="true">
            <button class="w-16 h-16 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center border border-white/30 hover:scale-110 transition-transform" aria-label="Reproduzir vídeo">
              <i class="material-symbols-outlined text-white text-4xl not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">play_arrow</i>
            </button>
          </aside>
          <figcaption class="absolute bottom-3 right-3 flex gap-2">
            <mark class="bg-primary/90 text-white text-xs font-bold px-3 py-1 rounded-full">00:45</mark>
            <mark class="bg-black/60 text-white text-xs font-bold px-3 py-1 rounded-full">HD 1080p</mark>
          </figcaption>
        </figure>

        <section class="bg-surface-container-lowest p-6 rounded-3xl border border-outline-variant/10">
          <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
            <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">cloud_upload</i>
            Mídia do Exercício
          </h3>
          <ul class="flex flex-col gap-3 list-none p-0 m-0">
            <li>
              <button class="w-full py-4 rounded-2xl border-2 border-dashed border-primary/30 flex flex-col items-center hover:bg-primary/5 transition-colors group">
                <i class="material-symbols-outlined text-primary mb-2 group-hover:scale-110 transition-transform not-italic" aria-hidden="true">upload_file</i>
                <strong class="text-sm font-bold text-primary">Substituir Vídeo</strong>
                <small class="text-xs text-on-surface-variant mt-1">MP4, MOV ou AVI (Max. 500MB)</small>
              </button>
            </li>
            <li class="flex items-center justify-between p-3 bg-surface-container-low rounded-xl">
              <figure class="flex items-center gap-3 m-0">
                <picture class="w-10 h-10 rounded-lg bg-surface-container-highest flex items-center justify-center" aria-hidden="true">
                  <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">image</i>
                </picture>
                <figcaption>
                  <p class="text-xs font-bold">Thumbnail Sugerida</p>
                  <p class="text-[10px] text-on-surface-variant">Automático do vídeo</p>
                </figcaption>
              </figure>
              <button class="text-xs font-bold text-primary hover:underline">Alterar</button>
            </li>
          </ul>
        </section>
      </section>

      <!-- Direita: Formulário -->
      <section class="lg:col-span-7">
        <form class="bg-surface-container-lowest rounded-3xl p-8 shadow-sm border border-outline-variant/10 space-y-6" novalidate>

          <fieldset class="space-y-2">
            <legend class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Título do Exercício</legend>
            <input id="exercise-title" class="w-full bg-surface-container-low border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-primary/20 text-on-surface font-semibold text-lg transition-all"
                   type="text" value="Agachamento Terra com Barra (Deadlift)"/>
          </fieldset>

          <fieldset class="space-y-2">
            <legend class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Descrição / Instruções</legend>
            <textarea id="exercise-description" class="w-full bg-surface-container-low border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-primary/20 text-on-surface text-sm leading-relaxed transition-all" rows="4">Mantenha os pés afastados na largura dos ombros. Flexione os quadris e joelhos para segurar a barra. Mantenha a coluna neutra enquanto levanta o peso usando a força das pernas e glúteos.</textarea>
          </fieldset>

          <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <fieldset class="space-y-2">
              <legend class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Categoria</legend>
              <label for="exercise-category" class="relative block">
                <select id="exercise-category" class="w-full appearance-none bg-surface-container-low border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-primary/20 text-on-surface font-medium transition-all">
                  <option>Força</option><option>Cardio</option><option>Flexibilidade</option><option>Mobilidade</option><option>HIIT</option>
                </select>
                <i class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant not-italic" aria-hidden="true">expand_more</i>
              </label>
            </fieldset>

            <fieldset class="space-y-2">
              <legend class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Duração Recomendada</legend>
              <section class="flex items-center bg-surface-container-low rounded-2xl px-6 py-4">
                <input id="exercise-duration" class="bg-transparent border-none focus:ring-0 w-full text-on-surface font-medium" type="number" value="45" min="1" aria-describedby="duration-unit"/>
                <output id="duration-unit" class="text-on-surface-variant font-bold text-xs uppercase whitespace-nowrap">Segundos</output>
              </section>
            </fieldset>
          </section>

          <fieldset class="space-y-3">
            <legend class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Nível de Dificuldade</legend>
            <ol class="grid grid-cols-3 gap-4 list-none p-0 m-0">
              <li>
                <label class="flex flex-col items-center gap-2 p-4 rounded-2xl bg-surface-container-low border-2 border-transparent hover:border-primary/20 transition-all cursor-pointer has-[:checked]:bg-primary/10 has-[:checked]:border-primary">
                  <input type="radio" name="difficulty" value="iniciante" class="sr-only"/>
                  <i class="material-symbols-outlined text-green-600 not-italic" aria-hidden="true">signal_cellular_alt_1_bar</i>
                  <b class="text-xs font-bold">Iniciante</b>
                </label>
              </li>
              <li>
                <label class="flex flex-col items-center gap-2 p-4 rounded-2xl bg-primary/10 border-2 border-primary cursor-pointer has-[:checked]:bg-primary/10 has-[:checked]:border-primary">
                  <input type="radio" name="difficulty" value="intermediario" class="sr-only" checked/>
                  <i class="material-symbols-outlined text-primary not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">signal_cellular_alt_2_bar</i>
                  <b class="text-xs font-bold text-primary">Intermediário</b>
                </label>
              </li>
              <li>
                <label class="flex flex-col items-center gap-2 p-4 rounded-2xl bg-surface-container-low border-2 border-transparent hover:border-primary/20 transition-all cursor-pointer has-[:checked]:bg-primary/10 has-[:checked]:border-primary">
                  <input type="radio" name="difficulty" value="avancado" class="sr-only"/>
                  <i class="material-symbols-outlined text-red-600 not-italic" aria-hidden="true">signal_cellular_alt</i>
                  <b class="text-xs font-bold">Avançado</b>
                </label>
              </li>
            </ol>
          </fieldset>

          <section class="flex gap-4 pt-2">
            <button type="button" class="flex-1 py-4 rounded-full border border-outline-variant/30 text-on-surface font-semibold hover:bg-surface-container transition-colors active:scale-95">Cancelar</button>
            <button type="submit" class="flex-1 py-4 rounded-full action-gradient text-white font-bold shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all active:scale-95">Salvar Alterações</button>
          </section>
        </form>
      </section>
    </article>
  </main>

  <!-- Menu Mobile Professor com botão + -->
  <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex justify-around items-end px-4 pb-6 pt-2
              bg-[#f7f5ff]/90 backdrop-blur-lg shadow-[0_-10px_40px_rgba(35,44,81,0.08)] rounded-t-[32px]"
       aria-label="Navegação mobile">
    <a href="/painelprofessor" class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">dashboard</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Início</em>
    </a>
    <a href="/todosalunos" class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">groups</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Alunos</em>
    </a>
    <button class="bg-primary text-white w-14 h-14 rounded-full shadow-lg shadow-primary/40 -mt-8 flex items-center justify-center active:scale-95 transition-transform" aria-label="Salvar e adicionar">
      <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">save</i>
    </button>
    <a href="/todosvideos" class="flex flex-col items-center justify-center text-[#0058ba] p-3 rounded-[18px] bg-[#d5dbff]" aria-current="page">
      <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">video_library</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Vídeos</em>
    </a>
    <a href="#" class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">person</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Perfil</em>
    </a>
  </nav>

</body>
</html>
