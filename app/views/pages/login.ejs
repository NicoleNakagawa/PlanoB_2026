<!DOCTYPE html>
<html lang="pt-BR" class="light">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>PlanoB - Login</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;700;800;900&family=Manrope:wght@400;500;600;700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" />

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#0058ba",
            "primary-container": "#6c9fff",
            "primary-dim": "#004da4",
            "on-primary": "#f0f2ff",
            surface: "#f7f5ff",
            "on-surface": "#232c51",
            "on-surface-variant": "#505a81",
            "surface-container": "#e4e7ff",
            "surface-container-low": "#efefff",
            "surface-container-high": "#dde1ff",
            "surface-container-highest": "#d5dbff",
            "surface-container-lowest": "#ffffff",
            "outline-variant": "#a2abd7",
            outline: "#6c759e",
            "tertiary-fixed": "#ffd709",
            error: "#b31b25"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"]
          }
        }
      }
    }
  </script>

  <style>

    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    body {
      font-family: "Manrope", sans-serif;
    }

    h1,
    h2,
    h3,
    .headline {
      font-family: "Lexend", sans-serif;
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .material-symbols-outlined {
      font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
      vertical-align: middle;
    }

    @media (max-width: 1023px) {
      main {
        min-height: 100vh;
      }
    }

    @media (max-width: 640px) {
      section.form-area {
        padding: 2rem 1.25rem !important;
      }

      h1.page-title {
        font-size: 2.25rem !important;
      }
    }
  </style>
  <link rel="stylesheet" href="/css/transicao-paginas.css">
</head>

<body class="min-h-screen overflow-x-hidden bg-surface text-on-surface">

  <%
    const erroSeguro = typeof erro !== 'undefined' ? erro : null
    const sucessoSeguro = typeof sucesso !== 'undefined' ? sucesso : null
  %>

  <main class="grid min-h-screen w-full bg-surface-container-lowest lg:grid-cols-2 xl:grid-cols-[1.05fr_0.95fr]">

    <aside class="relative hidden overflow-hidden bg-primary-dim lg:flex">
      <picture>
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuApM84iwpJg_o7rWHbCNIQ6LsC4v-8Dii4gGIySlGzqDyYjy-w6jczrcYJViEUZ0w_wz8IOfpuSxj2KeqxlgweD1l0myH_zi0RPM5ZMLmDUHMDHGVQQZLnqeXc6n6hfe64E6bH_UJlUSXFmjk4Ok5cpLgzKVBgT2I4f856cjUsNuIi-aJq6rNf1qoNcn-t4lkkV2vnTyKcSpAz3Us6A0WGGTBPMyty4z_txondCIcAdyr4yFPvA0NrZvwVCi8OyT5KJL6sL_eNHbvCg"
          alt="Atleta treinando na plataforma PlanoB"
          class="absolute inset-0 h-full w-full object-cover opacity-80 mix-blend-overlay"
        />
      </picture>

      <b class="absolute inset-0 bg-gradient-to-tr from-primary/90 via-primary/70 to-primary-container/20 font-normal" aria-hidden="true"></b>

      <header class="relative z-10 flex h-full w-full flex-col justify-end p-12 xl:p-20">
        <p class="mb-5 text-sm font-black tracking-widest text-tertiary-fixed">PLANO B</p>

        <h1 class="headline max-w-2xl text-6xl font-black leading-[1.05] tracking-tighter text-on-primary xl:text-7xl 2xl:text-8xl">
          ACESSE SUA JORNADA
        </h1>

        <p class="mt-6 max-w-xl text-lg font-semibold leading-relaxed text-on-primary/85 xl:text-xl">
          Entre com seu e-mail e senha. O sistema reconhece automaticamente se você é aluno ou professor.
        </p>
      </header>
    </aside>

    <section class="form-area flex min-h-screen w-full flex-col bg-surface-container-lowest px-8 py-10 md:px-16 lg:px-20 xl:px-28 2xl:px-36">

      <nav aria-label="Navegação de retorno">
        <a href="/home" class="group inline-flex items-center gap-2 text-xs font-black uppercase tracking-widest text-primary transition-opacity hover:opacity-80">
          <i class="material-symbols-outlined text-lg transition-transform group-hover:-translate-x-1 not-italic" aria-hidden="true">arrow_back</i>
          Voltar
        </a>
      </nav>

      <header class="mt-10 flex items-center justify-between">
        <h2 class="logo-font text-3xl text-primary md:text-4xl">PlanoB</h2>

      </header>

      <section class="mx-auto flex w-full max-w-[30rem] flex-1 flex-col justify-center py-10">

        <header class="mb-10">
          <h3 class="page-title headline text-4xl font-black tracking-tight text-on-surface md:text-5xl">
            Bem-vindo de volta
          </h3>

          <p class="mt-3 text-base font-semibold leading-relaxed text-on-surface-variant">
            Use suas credenciais para acessar sua conta de aluno ou professor.
          </p>
        </header>

        <% if (erroSeguro) { %>
          <p class="mb-5 rounded-2xl bg-red-50 px-4 py-3 text-center text-sm font-bold text-error" role="alert">
            <%= erroSeguro %>
          </p>
        <% } %>

        <% if (sucessoSeguro) { %>
          <p class="mb-5 rounded-2xl bg-green-50 px-4 py-3 text-center text-sm font-bold text-green-700" role="status">
            <%= sucessoSeguro %>
          </p>
        <% } %>

        <form class="space-y-6" action="/login" method="POST" data-form="login" aria-label="Formulário de login único" novalidate>

          <fieldset class="space-y-2">
            <legend class="sr-only">Dados de acesso</legend>

            <label for="email" class="ml-1 block text-sm font-bold text-on-surface-variant">
              E-mail
            </label>

            <article class="relative">
              <i class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline not-italic" aria-hidden="true">mail</i>

              <input
                id="email"
                name="email"
                type="email"
                placeholder="nome@exemplo.com"
                autocomplete="email"
                class="w-full rounded-2xl border-none bg-surface-container-highest py-4 pl-12 pr-4 text-on-surface transition-all placeholder:text-outline focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary"
                required
              />
            </article>
          </fieldset>

          <fieldset class="space-y-2">
            <legend class="sr-only">Senha</legend>

            <header class="flex items-center justify-between px-1">
              <label for="password" class="text-sm font-bold text-on-surface-variant">
                Senha
              </label>

              <a href="#" class="text-sm font-bold text-primary transition-colors hover:text-primary-dim">
                Esqueceu a senha?
              </a>
            </header>

            <article class="relative">
              <i class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline not-italic" aria-hidden="true">lock</i>

              <input
                id="password"
                name="password"
                type="password"
                placeholder="••••••••"
                autocomplete="current-password"
                class="w-full rounded-2xl border-none bg-surface-container-highest py-4 pl-12 pr-12 text-on-surface transition-all placeholder:text-outline focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary"
                required
              />

              <button
                type="button"
                class="absolute right-4 top-1/2 -translate-y-1/2 text-outline transition-colors hover:text-primary"
                aria-label="Mostrar ou ocultar senha"
                data-password-toggle="password"
              >
                <i class="material-symbols-outlined not-italic" aria-hidden="true">visibility</i>
              </button>
            </article>
          </fieldset>

          <label for="remember" class="flex cursor-pointer items-center gap-3 px-1">
            <input
              id="remember"
              name="remember"
              type="checkbox"
              class="h-5 w-5 rounded border-outline-variant text-primary focus:ring-primary"
            />

            <em class="text-sm font-semibold text-on-surface-variant not-italic">
              Lembrar de mim
            </em>
          </label>

          <button
            type="submit"
            class="w-full rounded-full bg-gradient-to-r from-primary to-primary-container py-4 text-lg font-black text-on-primary shadow-lg shadow-primary/25 transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]"
          >
            Entrar na Plataforma
          </button>
        </form>

        <footer class="mt-10 text-center">
          <p class="text-sm font-semibold text-on-surface-variant">
            Ainda não tem uma conta?
          </p>

          <nav class="mt-4 flex flex-col gap-3 sm:flex-row sm:justify-center" aria-label="Links de cadastro">
            <a href="/cadastroaluno" class="rounded-full bg-surface-container px-5 py-3 text-sm font-black text-primary transition-colors hover:bg-surface-container-high">
              Criar conta de aluno
            </a>

            <a href="/cadastroprofessor" class="rounded-full bg-surface-container px-5 py-3 text-sm font-black text-primary transition-colors hover:bg-surface-container-high">
              Criar conta de professor
            </a>
          </nav>
        </footer>

      </section>
    </section>

  </main>

  <script>
    document.querySelectorAll('[data-password-toggle]').forEach((button) => {
      button.addEventListener('click', () => {
        const inputId = button.getAttribute('data-password-toggle')
        const input = document.getElementById(inputId)
        const icon = button.querySelector('.material-symbols-outlined')

        if (!input || !icon) return

        const isPassword = input.type === 'password'

        input.type = isPassword ? 'text' : 'password'
        icon.textContent = isPassword ? 'visibility_off' : 'visibility'
      })
    })
  </script>

  <script src="/js/validacoes.js"></script>
</body>
  
<script src="/js/transicao-paginas.js"></script>
  
</html>