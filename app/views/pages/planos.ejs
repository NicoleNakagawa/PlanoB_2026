  <nav class="lg:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-2 bg-[#f7f5ff]/90 dark:bg-[#1a1b26]/90 backdrop-blur-lg shadow-[0_-10px_40px_rgba(35,44,81,0.08)] rounded-t-[32px]" aria-label="Navegação mobile">

    <a href="/home" class="mobile-link flex flex-col items-center justify-center text-[#232c51] dark:text-[#d5dbff] opacity-60 p-3 hover:opacity-100 transition-opacity" data-page="home">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">home</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Início</em>
    </a>

    <a href="/planos" class="mobile-link flex flex-col items-center justify-center text-[#232c51] dark:text-[#d5dbff] opacity-60 p-3 hover:opacity-100 transition-opacity" data-page="planos">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">stars</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Planos</em>
    </a>

    <a href="/suporte" class="mobile-link flex flex-col items-center justify-center text-[#232c51] dark:text-[#d5dbff] opacity-60 p-3 hover:opacity-100 transition-opacity" data-page="suporte">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">support_agent</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Suporte</em>
    </a>

    <a href="/loginaluno" class="mobile-link flex flex-col items-center justify-center text-[#232c51] dark:text-[#d5dbff] opacity-60 p-3 hover:opacity-100 transition-opacity" data-page="loginaluno">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">person</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Perfil</em>
    </a>

  </nav>

  <script>
    const paginaAtual = window.location.pathname.split("/").pop().replace(".html", "") || "home"
    const linksMobile = document.querySelectorAll(".mobile-link")

    linksMobile.forEach(link => {
      const paginaDoLink = link.dataset.page

      if (paginaAtual === paginaDoLink) {
        link.classList.add("ativo")
        link.setAttribute("aria-current", "page")
      }
    })


    const cardsPlanos = document.querySelectorAll(".plan-card-clickable")

    cardsPlanos.forEach(card => {
      card.addEventListener("click", event => {
        if (event.target.closest("a, button")) return

        const destino = card.dataset.href
        if (destino) {
          window.location.href = destino
        }
      })

      card.addEventListener("keydown", event => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault()

          const destino = card.dataset.href
          if (destino) {
            window.location.href = destino
          }
        }
      })
    })
  </script>

</body>
</html>