<!DOCTYPE html>

<html lang="pt-BR">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Streak | PlanoB</title>
<link href="/css/progressosemanal.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;700;800&amp;family=Manrope:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<style>
        .streak-hero { display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 40px 20px; }
        .streak-fogo { font-size: 72px; line-height: 1; }
        .streak-numero { font-size: 80px; font-weight: 800; color: #ff6a00; line-height: 1; }
        .streak-label { font-size: 18px; color: #888; font-weight: 500; }
        .streak-maximo { font-size: 14px; color: #aaa; }
        .descontos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; margin-top: 24px; }
        .desconto-card { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 16px; padding: 20px; display: flex; flex-direction: column; gap: 8px; }
        .desconto-card.desbloqueado { border-color: #ff6a00; }
        .desconto-card.usado { opacity: 0.5; }
        .desconto-pct { font-size: 32px; font-weight: 800; color: #ff6a00; }
        .desconto-codigo { font-family: monospace; font-size: 13px; background: #0d0d1f; padding: 4px 10px; border-radius: 6px; color: #ccc; width: fit-content; }
        .desconto-dias { font-size: 12px; color: #888; }
        .desconto-badge { font-size: 11px; padding: 3px 10px; border-radius: 99px; width: fit-content; }
        .badge-desbloqueado { background: #ff6a0022; color: #ff6a00; }
        .badge-usado { background: #33333355; color: #888; }
        .badge-bloqueado { background: #1a1a2e; color: #555; border: 1px solid #333; }
    
    /* Ajustes gerais de responsividade */
    img, video { max-width: 100%; height: auto; }
    a, button { -webkit-tap-highlight-color: transparent; }
    @media (max-width: 768px) {
      body { overflow-x: hidden; }
      main { max-width: 100%; }
      .hide-mobile { display: none !important; }
    }
</style>
</head>
<body>
<header class="topo">
<a class="logo" href="/painelfree">PlanoB</a>
<nav class="menu-desktop">
<a href="/painelfree">Dashboard</a>
<a href="/videosfree">Vídeos</a>
<a href="/progressosemanal">Evolução</a>
<a class="ativo" href="/streakprogress">Streak</a>
</nav>
<nav class="acoes-topo">
<a aria-label="Streak" href="/streakprogress">
<i class="material-symbols-outlined">local_fire_department</i>
</a>
<a aria-label="Suporte" href="/suporte">
<i class="material-symbols-outlined">support_agent</i>
</a>
<a aria-label="Perfil" class="avatar" href="/painelfree">
<img alt="Foto de perfil" src="/img/imagem6.jpg"/>
</a>
</nav>
</header>
<main class="conteudo">
<section class="cabecalho-pagina">
<article class="brilho"></article>
<h1>Sua <strong>ofensiva</strong></h1>
<p>Treine todos os dias e desbloqueie descontos exclusivos no seu plano.</p>
</section>
<section class="grade-principal">
<article class="card" style="grid-column: 1 / -1; text-align: center;">
<section class="streak-hero">
<section class="streak-fogo">🔥</section>
<section class="streak-numero" id="streak-atual">—</section>
<section class="streak-label">dias consecutivos</section>
<section class="streak-maximo" id="streak-maximo"></section>
</section>
</article>
<article class="card" style="grid-column: 1 / -1;">
<header class="card-cabecalho">
<h2>Recompensas de Ofensiva</h2>
<p>Acumule dias e ganhe descontos automáticos na renovação.</p>
</header>
<section class="descontos-grid" id="descontos-grid">
<p style="color:#888;">Carregando...</p>
</section>
</article>
</section>
</main>
<script>
        async function carregarStreak() {
            try {
                const res = await fetch('/api/aluno/streak')
                const data = await res.json()
                if (!data.ok) throw new Error(data.erro)

                const streak = data.streak
                const descontos = data.descontos || []

                if (streak) {
                    document.getElementById('streak-atual').textContent = streak.streak_atual
                    document.getElementById('streak-maximo').textContent = `Recorde: ${streak.streak_maximo} dias`
                } else {
                    document.getElementById('streak-atual').textContent = '0'
                    document.getElementById('streak-maximo').textContent = 'Nenhum treino registrado ainda.'
                }

                const recompensas = [
                    { dias: 10,  pct: 5,  codigo: 'OFENSIVA10' },
                    { dias: 40,  pct: 20, codigo: 'OFENSIVA40' },
                    { dias: 50,  pct: 35, codigo: 'OFENSIVA50' },
                    { dias: 90,  pct: 50, codigo: 'OFENSIVA90' },
                ]

                const streakAtual = streak ? streak.streak_atual : 0
                const grid = document.getElementById('descontos-grid')

                grid.innerHTML = recompensas.map(r => {
                    const descBD = descontos.find(d => d.codigo === r.codigo)
                    const desbloqueado = descBD || streakAtual >= r.dias
                    const usado = descBD && descBD.usado

                    let badgeClass = 'badge-bloqueado'
                    let badgeTexto = `🔒 ${r.dias} dias`
                    let cardClass = ''

                    if (usado) {
                        badgeClass = 'badge-usado'
                        badgeTexto = '✓ Já utilizado'
                        cardClass = 'usado'
                    } else if (desbloqueado) {
                        badgeClass = 'badge-desbloqueado'
                        badgeTexto = '🔥 Disponível!'
                        cardClass = 'desbloqueado'
                    }

                    return `
                        <section class="desconto-card ${cardClass}">
                            <section class="desconto-pct">${r.pct}% OFF</section>
                            <section class="desconto-codigo">${r.codigo}</section>
                            <section class="desconto-dias">A partir de ${r.dias} dias de ofensiva</section>
                            <section class="desconto-badge ${badgeClass}">${badgeTexto}</section>
                        </section>
                    `
                }).join('')

            } catch (err) {
                console.error(err)
                document.getElementById('streak-atual').textContent = '—'
                document.getElementById('descontos-grid').innerHTML =
                    '<p style="color:#e55;">Erro ao carregar dados. Tente recarregar a página.</p>'
            }
        }

        carregarStreak()
    </script>
</body>
</html>
