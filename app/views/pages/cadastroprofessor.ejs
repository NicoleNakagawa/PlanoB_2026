<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;700;800;900&family=Manrope:wght@400;500;600;700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" />

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "secondary-fixed-dim": "#37d4ff",
            "on-background": "#232c51",
            "surface-variant": "#d5dbff",
            "tertiary-dim": "#5e4e00",
            "on-secondary": "#e2f6ff",
            "surface-container-highest": "#d5dbff",
            "primary-fixed-dim": "#5091ff",
            "error-dim": "#9f0519",
            "on-error": "#ffefee",
            "on-primary-fixed": "#000000",
            "on-error-container": "#570008",
            "tertiary-container": "#ffd709",
            "tertiary-fixed-dim": "#efc900",
            "on-secondary-container": "#004e61",
            "secondary-fixed": "#80deff",
            "on-tertiary": "#fff2cd",
            "tertiary-fixed": "#ffd709",
            "primary-fixed": "#6c9fff",
            "surface-container": "#e4e7ff",
            "inverse-primary": "#4a8eff",
            "primary-dim": "#004da4",
            "on-surface-variant": "#505a81",
            "on-primary-fixed-variant": "#002a60",
            error: "#b31b25",
            "secondary-dim": "#00576c",
            "primary-container": "#6c9fff",
            "outline-variant": "#a2abd7",
            "inverse-on-surface": "#929bc6",
            "surface-container-low": "#efefff",
            primary: "#0058ba",
            "on-surface": "#232c51",
            "on-tertiary-container": "#5b4b00",
            "on-secondary-fixed-variant": "#00586d",
            "surface-bright": "#f7f5ff",
            "secondary-container": "#80deff",
            "on-tertiary-fixed": "#453900",
            "inverse-surface": "#020a2f",
            "on-primary": "#f0f2ff",
            tertiary: "#6c5a00",
            "surface-tint": "#0058ba",
            "surface-container-high": "#dde1ff",
            outline: "#6c759e",
            background: "#f7f5ff",
            surface: "#f7f5ff",
            "on-primary-container": "#00214e",
            "on-secondary-fixed": "#003a48",
            "surface-container-lowest": "#ffffff",
            "error-container": "#fb5151",
            "surface-dim": "#cad2ff",
            secondary: "#00647b",
            "on-tertiary-fixed-variant": "#665500"
          },
          borderRadius: {
            DEFAULT: "0.25rem",
            lg: "0.5rem",
            xl: "0.75rem",
            full: "9999px"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"],
            label: ["Manrope"]
          }
        }
      }
    };
  </script>

  <style>
    body { font-family: "Manrope", sans-serif; background-color: #f7f5ff; }
    .lexend { font-family: "Lexend", sans-serif; }
    .material-symbols-outlined {
      font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
    }
  </style>
</head>

<body class="bg-surface text-on-surface min-h-screen flex flex-col overflow-x-hidden md:flex-row">

  <aside class="relative hidden min-h-screen items-end overflow-hidden bg-primary p-12 lg:flex lg:w-1/2">

    <figure class="absolute inset-0 z-0">
      <picture>
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBaNKWU83BjSeH5JM-mF9NETJdhy3zWqQOlvvbzje0CugF7ehtJy0Hkr018ReltRh8a5PnZ3NQIeeOy4iMti-UlSJNRL0CCIhaEivYIklGcdgOrMyjvU2HlxtY_kGTIL2fEaacg_-8BErmZ1a-zJlMMD1gwYJFGVYGSHUO9yserMuaEPiNkggW0kgbXiSgsz_1YjVYrCjP6Rqayo8cKzpey22qrXR7rmtEHbmFTLtPYtNjRhplHYrmFQbkU1vyIx--MRmYALWdSKOG0"
          alt="Treinador fitness em academia"
          class="h-full w-full object-cover opacity-80 mix-blend-multiply"
        />
      </picture>
      <figcaption class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/30 to-transparent" aria-hidden="true"></figcaption>
    </figure>

    <header class="relative z-10 max-w-xl">
      <h1 class="lexend mb-4 text-7xl font-black leading-tight tracking-tighter text-on-primary">
        MOLDANDO O <br />
        FUTURO DO <br />
        FITNESS
      </h1>
      <p class="max-w-md border-l-4 border-tertiary-container pl-6 text-xl font-medium leading-relaxed text-on-primary/80">
        Junte-se à nossa elite de treinadores. Transforme vidas com precisão arquitetônica e tecnologia de ponta.
      </p>
    </header>

  </aside>

  <main class="relative flex min-h-screen w-full flex-col overflow-y-auto bg-surface-container-lowest p-8 md:p-16 lg:w-1/2 lg:p-24">

    <nav class="mb-8" aria-label="Navegação de retorno">
      <a
        href="/home"
        class="group inline-flex items-center gap-2 text-on-surface-variant transition-colors duration-200 hover:text-primary"
      >
        <i class="material-symbols-outlined text-xl transition-transform group-hover:-translate-x-1 not-italic" aria-hidden="true">arrow_back</i>
        <strong class="lexend text-xs font-bold uppercase tracking-widest">Voltar</strong>
      </a>
    </nav>

    <header class="mb-16 flex items-center justify-between">
      <h2 class="lexend text-3xl font-black tracking-tighter text-primary">PlanoB</h2>

      <nav class="flex w-48 rounded-full bg-surface-container p-1 shadow-sm" aria-label="Tipo de usuário">
        <a
          href="/cadastroaluno"
          class="flex-1 rounded-full py-2 text-center text-xs font-bold text-on-surface-variant transition-all duration-300 hover:text-on-surface"
        >
          Aluno
        </a>
        <button
          type="button"
          class="flex-1 rounded-full bg-primary py-2 text-xs font-bold text-on-primary shadow-sm"
          aria-current="true"
        >
          Professor
        </button>
      </nav>
    </header>

    <section class="mx-auto w-full max-w-md">

      <header class="mb-10">
        <h3 class="lexend mb-2 text-4xl font-extrabold tracking-tight text-on-surface">Crie sua conta</h3>
        <p class="font-medium text-on-surface-variant">Preencha os dados abaixo para começar sua jornada profissional.</p>
      </header>

      <form class="space-y-6" action="/cadastroprofessor" method="POST" data-form="cadastroprofessor" aria-label="Formulário de cadastro de professor" novalidate>

        <fieldset class="space-y-2">
          <legend class="sr-only">Nome</legend>
          <label for="name" class="ml-1 text-sm font-bold text-on-surface-variant">Nome Completo</label>
          <input
            id="name"
            name="name"
            type="text"
            placeholder="Seu nome profissional"
            autocomplete="name"
            class="w-full rounded-xl border-none bg-surface-container-highest px-4 py-4 text-on-surface transition-all duration-200 placeholder:text-outline focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary/20 outline-none"
          />
        </fieldset>

        <fieldset class="space-y-2">
          <legend class="sr-only">E-mail</legend>
          <label for="email" class="ml-1 text-sm font-bold text-on-surface-variant">E-mail Profissional</label>
          <input
            id="email"
            name="email"
            type="email"
            placeholder="nome@exemplo.com"
            autocomplete="email"
            class="w-full rounded-xl border-none bg-surface-container-highest px-4 py-4 text-on-surface transition-all duration-200 placeholder:text-outline focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary/20 outline-none"
          />
        </fieldset>

        <fieldset class="space-y-2">
          <legend class="sr-only">CREF</legend>
          <label for="cref" class="ml-1 text-sm font-bold text-on-surface-variant">Registro CREF</label>
          <input
            id="cref"
            name="cref"
            type="text"
            placeholder="000000-G/XX"
            class="w-full rounded-xl border-none bg-surface-container-highest px-4 py-4 text-on-surface transition-all duration-200 placeholder:text-outline focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary/20 outline-none"
          />
        </fieldset>

        <section class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <fieldset class="space-y-2">
            <legend class="sr-only">Senha</legend>
            <label for="password" class="ml-1 text-sm font-bold text-on-surface-variant">Senha</label>
            <input
              id="password"
              name="password"
              type="password"
              placeholder="••••••••"
              autocomplete="new-password"
              class="w-full rounded-xl border-none bg-surface-container-highest px-4 py-4 text-on-surface transition-all duration-200 placeholder:text-outline focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary/20 outline-none"
            />
          </fieldset>
          <fieldset class="space-y-2">
            <legend class="sr-only">Confirmar Senha</legend>
            <label for="confirm-password" class="ml-1 text-sm font-bold text-on-surface-variant">Confirmar Senha</label>
            <input
              id="confirm-password"
              name="confirm-password"
              type="password"
              placeholder="••••••••"
              autocomplete="new-password"
              class="w-full rounded-xl border-none bg-surface-container-highest px-4 py-4 text-on-surface transition-all duration-200 placeholder:text-outline focus:bg-surface-container-lowest focus:ring-2 focus:ring-primary/20 outline-none"
            />
          </fieldset>
        </section>

        <fieldset>
          <label for="terms" class="flex items-start gap-3 py-2 cursor-pointer">
            <input
              id="terms"
              name="terms"
              type="checkbox"
              class="h-5 w-5 rounded border-none bg-surface-container-highest text-primary focus:ring-primary focus:ring-offset-0"
            />
            <p class="text-sm leading-tight text-on-surface-variant">
              Eu aceito os
              <strong class="cursor-pointer text-primary">Termos de Uso</strong>
              e a
              <strong class="cursor-pointer text-primary">Política de Privacidade</strong>.
            </p>
          </label>
        </fieldset>

        <button
          type="submit"
          class="group flex w-full items-center justify-center gap-3 rounded-full bg-gradient-to-r from-primary to-primary-container py-5 font-bold text-on-primary shadow-lg shadow-primary/20 transition-transform active:scale-[0.98]"
        >
          <em class="not-italic">Finalizar Cadastro</em>
          <i class="material-symbols-outlined text-xl transition-transform group-hover:translate-x-1 not-italic" aria-hidden="true">arrow_forward</i>
        </button>

      </form>

      <footer class="mt-12 text-center">
        <p class="font-medium text-on-surface-variant">
          Já possui uma conta?
          <a href="/loginprofessor" class="ml-1 font-extrabold text-primary hover:underline">Acesse agora</a>
        </p>
      </footer>

    </section>

    <footer class="mt-auto flex flex-col items-center justify-between gap-4 border-t border-surface-container-low pt-16 text-xs text-on-surface-variant opacity-60 md:flex-row">
      <p>© 2024 PlanoB. The Kinetic Editorial.</p>
      <nav class="flex gap-6" aria-label="Links legais">
        <a href="#" class="hover:text-primary">Privacy Policy</a>
        <a href="#" class="hover:text-primary">Terms of Service</a>
        <a href="#" class="hover:text-primary">Support</a>
      </nav>
    </footer>

  </main>

  <script src="/js/validacoes.js"></script>
</body>
</html>