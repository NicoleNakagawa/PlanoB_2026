<!DOCTYPE html>
<html class="light" lang="pt-BR">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>PlanoB - Painel Lazuli</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface-bright": "#f7f5ff",
            "tertiary-dim": "#5e4e00",
            "error": "#b31b25",
            "surface-dim": "#cad2ff",
            "outline-variant": "#a2abd7",
            "on-secondary": "#e2f6ff",
            "surface-container-highest": "#d5dbff",
            "inverse-primary": "#4a8eff",
            "surface": "#f7f5ff",
            "primary": "#0058ba",
            "outline": "#6c759e",
            "inverse-on-surface": "#929bc6",
            "error-container": "#fb5151",
            "surface-variant": "#d5dbff",
            "primary-fixed": "#6c9fff",
            "primary-container": "#6c9fff",
            "secondary-fixed-dim": "#37d4ff",
            "on-error": "#ffefee",
            "on-tertiary": "#fff2cd",
            "on-surface-variant": "#505a81",
            "tertiary-fixed-dim": "#efc900",
            "surface-container-high": "#dde1ff",
            "secondary-dim": "#00576c",
            "on-secondary-fixed-variant": "#00586d",
            "on-tertiary-container": "#5b4b00",
            "tertiary-fixed": "#ffd709",
            "on-primary-fixed": "#000000",
            "on-primary": "#f0f2ff",
            "on-error-container": "#570008",
            "secondary-fixed": "#80deff",
            "secondary-container": "#80deff",
            "on-tertiary-fixed": "#453900",
            "primary-fixed-dim": "#5091ff",
            "surface-container": "#e4e7ff",
            "primary-dim": "#004da4",
            "on-background": "#232c51",
            "surface-container-lowest": "#ffffff",
            "inverse-surface": "#020a2f",
            "tertiary-container": "#ffd709",
            "on-tertiary-fixed-variant": "#665500",
            "on-primary-container": "#00214e",
            "surface-container-low": "#efefff",
            "secondary": "#00647b",
            "on-primary-fixed-variant": "#002a60",
            "on-secondary-container": "#004e61",
            "on-surface": "#232c51",
            "surface-tint": "#0058ba",
            "background": "#f7f5ff",
            "on-secondary-fixed": "#003a48",
            "error-dim": "#9f0519",
            "tertiary": "#6c5a00"
          },
          borderRadius: {
            DEFAULT: "0.25rem",
            lg: "0.5rem",
            xl: "0.75rem",
            full: "9999px"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"],
            label: ["Manrope"]
          }
        }
      }
    }
  </script>

  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .logo-header {
      font-size: 2.7rem;
      line-height: 1;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    .avatar-placeholder .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    .video-card-link {
      color: inherit;
      text-decoration: none;
      display: flex;
      width: 100%;
      height: 100%;
    }

    .video-card-link:hover img {
      transform: scale(1.08);
    }

    @media (max-width: 768px) {
      html,
      body {
        width: 100%;
        overflow-x: hidden;
      }

      body {
        background: #f7f5ff;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      header.fixed strong.logo-header {
        font-size: 1.45rem;
        line-height: 1;
      }

      header.fixed menu {
        gap: 8px;
      }

      header.fixed button,
      header.fixed a {
        padding: 8px;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 16px 135px !important;
      }

      main section.max-w-6xl {
        gap: 18px;
      }

      article.hero-lazuli {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.hero-lazuli > section {
        align-items: flex-start !important;
        gap: 28px !important;
      }

      article.hero-lazuli h1 {
        font-size: 2rem !important;
        line-height: 1.1 !important;
        margin-left: 0 !important;
      }

      article.hero-lazuli p {
        font-size: 0.95rem !important;
      }

      article.hero-lazuli figure {
        max-width: 220px;
        width: 100% !important;
        margin: 0 auto !important;
        padding: 20px !important;
      }

      section.card-mobile,
      article.card-mobile {
        padding: 22px !important;
        border-radius: 26px !important;
      }

      section.card-mobile h2,
      article.card-mobile h2 {
        font-size: 1.35rem !important;
      }

      section.video-section li {
        height: auto !important;
        min-height: 115px;
      }

      section.video-section figure {
        width: 115px !important;
      }

      section.video-section h3 {
        font-size: 0.95rem;
        line-height: 1.2;
      }

      section.video-section p {
        font-size: 0.72rem;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 64px;
        border-radius: 18px;
      }

      nav[aria-label="Navegação mobile"] a[aria-current="page"] {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
      }

      nav[aria-label="Navegação mobile"] a:hover {
        color: #0058ba !important;
        opacity: 1 !important;
      }
    }

    @media (max-width: 420px) {
      main {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }

      article.hero-lazuli h1 {
        font-size: 1.75rem !important;
      }

      section.video-section figure {
        width: 95px !important;
      }

      section.video-section hgroup {
        padding: 12px !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding-left: 6px !important;
        padding-right: 6px !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 58px;
        padding: 10px 6px !important;
      }

      nav[aria-label="Navegação mobile"] em {
        font-size: 8px !important;
      }
    }
  </style>
</head>

<body class="bg-surface text-on-surface">

  <%
    const planoAluno = typeof aluno !== 'undefined' && aluno.id_plano ? Number(aluno.id_plano) : 2

    const painelCorreto = planoAluno === 3
      ? '/paineldiamante'
      : '/painellazuli'

    const nomePlanoAluno = planoAluno === 3
      ? 'Diamante'
      : 'Lazuli'

    const imagensPremium = {
      'agachamento': 'https://images.unsplash.com/photo-1599058917212-d750089bc07e?auto=format&fit=crop&w=1200&q=80',
      'cardio-10-minutos': 'https://images.unsplash.com/photo-1605296867304-46d5465a13f1?auto=format&fit=crop&w=1200&q=80',
      'mobilidade-basica': 'https://images.unsplash.com/photo-1599901860904-17e6ed7083a0?auto=format&fit=crop&w=1200&q=80',
      'flexao-perfeita': 'https://images.unsplash.com/photo-1598971639058-fab3c3109a00?auto=format&fit=crop&w=1200&q=80',
      'afundo-explosivo': 'https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=1200&q=80',
      'prancha-isometrica': 'https://images.unsplash.com/photo-1566241142559-40e1dab266c6?auto=format&fit=crop&w=1200&q=80'
    }

    const videosPremium = typeof videosFree !== 'undefined' && videosFree.length > 0
      ? videosFree.map(function(video) {
          return {
            ...video,
            capaPremium: imagensPremium[video.slug] || video.capa
          }
        })
      : []
  %>

  <!-- Header -->
  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">

    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <strong class="font-headline logo-font logo-header text-primary">PlanoB</strong>
    </nav>

    <menu class="flex items-center gap-4 p-0 m-0">
      <li>
        <button class="p-2 rounded-full hover:bg-surface-container transition-colors active:scale-95" aria-label="Notificações">
          <i class="material-symbols-outlined text-on-background not-italic" aria-hidden="true">notifications</i>
        </button>
      </li>

      <li>
        <a href="/perfilaluno"
          class="p-2 rounded-full hover:bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center"
          aria-label="Perfil">
          <i class="material-symbols-outlined text-on-background not-italic" aria-hidden="true">account_circle</i>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <!-- Sidebar Desktop -->
  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] dark:bg-[#12141c] flex-col gap-2 py-8 z-40 mt-16">

    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <picture>
          <% if (typeof aluno !== 'undefined' && aluno.foto) { %>
            <img
              class="w-12 h-12 rounded-full object-cover"
              src="<%= aluno.foto %>"
              alt="Foto de perfil do aluno"
            />
          <% } else { %>
            <span class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden" aria-label="Aluno sem foto">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </span>
          <% } %>
        </picture>

        <figcaption>
          <p class="text-sm font-bold text-on-surface">Portal <%= nomePlanoAluno %></p>
          <p class="text-xs text-on-surface-variant">Plano premium ativo</p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="<%= painelCorreto %>" aria-current="page">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">fitness_center</i>
        <em class="not-italic">Início</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/videos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">play_circle</i>
        <em class="not-italic">Vídeos</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/progressosemanal">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">monitoring</i>
        <em class="not-italic">Progresso</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/feedbackaluno">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
        <em class="not-italic">Feedback</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/perfilaluno">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">person</i>
        <em class="not-italic">Perfil</em>
      </a>
    </nav>

  </aside>

  <!-- Main -->
  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <!-- Hero -->
      <article class="hero-lazuli md:col-span-12 relative overflow-hidden rounded-3xl bg-primary p-8 md:p-12 text-white shadow-2xl">

        <section class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">

          <hgroup class="max-w-2xl">
            <mark class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md text-xs font-bold uppercase tracking-widest mb-4 text-white">
              Plano <%= nomePlanoAluno %> Ativo
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              BEM-VINDO AO SEU TREINO PREMIUM.
            </h1>

            <p class="text-lg opacity-90 max-w-xl">
              Agora você tem acesso a mais vídeos, progresso detalhado, feedback com professor e recursos avançados do PlanoB.
            </p>
          </hgroup>

          <figure class="flex flex-col items-center gap-4 bg-white/10 backdrop-blur-xl p-6 md:p-8 rounded-3xl border border-white/10 w-full max-w-[240px] mx-auto md:mx-0 md:w-auto m-0">
            <span class="w-28 h-28 rounded-full bg-white/15 flex items-center justify-center">
              <i class="material-symbols-outlined text-white text-7xl not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 48" aria-hidden="true">workspace_premium</i>
            </span>

            <figcaption class="text-sm font-black uppercase tracking-widest text-center">
              <%= nomePlanoAluno %> Premium
            </figcaption>
          </figure>

        </section>

        <b class="absolute -right-20 -bottom-20 w-96 h-96 bg-secondary-fixed opacity-10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        <b class="absolute -left-20 -top-20 w-64 h-64 bg-white opacity-5 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
      </article>

      <!-- Recursos Premium -->
      <section class="md:col-span-5 flex flex-col gap-6">

        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-8 shadow-sm flex flex-col gap-6 relative overflow-hidden">
          <i class="material-symbols-outlined text-primary text-5xl opacity-10 not-italic absolute top-0 right-0 p-4" aria-hidden="true">stars</i>

          <hgroup class="flex flex-col gap-2">
            <h2 class="text-2xl font-extrabold headline text-on-surface">Recursos <%= nomePlanoAluno %></h2>
            <p class="text-on-surface-variant leading-relaxed">
              Seu plano libera funções premium, incluindo vídeos completos, feedback com professor e acompanhamento de evolução.
            </p>
          </hgroup>

          <ul class="flex flex-col gap-3 list-none p-0 m-0">
            <li class="flex items-center gap-3 bg-surface-container-low rounded-2xl p-4">
              <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">play_circle</i>
              <b class="text-sm">Acesso ampliado aos vídeos</b>
            </li>

            <li class="flex items-center gap-3 bg-surface-container-low rounded-2xl p-4">
              <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">forum</i>
              <b class="text-sm">Feedback com professor</b>
            </li>

            <li class="flex items-center gap-3 bg-surface-container-low rounded-2xl p-4">
              <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">monitoring</i>
              <b class="text-sm">Progresso semanal</b>
            </li>
          </ul>

        </article>

        <article class="card-mobile bg-surface-container rounded-3xl p-8 flex flex-col gap-4">
          <p class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">Plano atual</p>

          <p class="flex items-end gap-2">
            <strong class="text-5xl font-black text-primary"><%= nomePlanoAluno %></strong>
          </p>

          <% if (planoAluno === 2) { %>
            <p class="text-xs text-on-surface-variant italic">
              Para consultoria VIP individual, evolua para o Plano Diamante.
            </p>

            <a href="/pagamento?plano=3" class="w-full bg-surface-container-highest text-on-surface py-4 rounded-full font-bold active:scale-95 transition-transform text-center">
              Fazer upgrade para Diamante
            </a>
          <% } else { %>
            <p class="text-xs text-on-surface-variant italic">
              Você está no plano mais completo do PlanoB.
            </p>

            <a href="/perfilaluno" class="w-full bg-surface-container-highest text-on-surface py-4 rounded-full font-bold active:scale-95 transition-transform text-center">
              Ver meu perfil
            </a>
          <% } %>
        </article>

      </section>

      <!-- Vídeos Premium -->
      <section class="video-section card-mobile md:col-span-7 bg-surface-container-low rounded-3xl p-8 flex flex-col gap-6">

        <header class="flex items-center justify-between gap-4">
          <h2 class="text-2xl font-extrabold headline text-on-surface">Vídeos Liberados</h2>

          <mark class="px-3 py-1 bg-surface-container-highest rounded-full text-[10px] font-bold uppercase text-on-surface-variant">
            Premium
          </mark>
        </header>

        <% if (videosPremium.length > 0) { %>
          <ul role="list" class="grid grid-cols-1 gap-4 list-none p-0 m-0">

            <% videosPremium.slice(0, 4).forEach(function(video) { %>
              <li class="group relative rounded-2xl overflow-hidden bg-surface-container-lowest h-32 flex items-center cursor-pointer transition-transform hover:scale-[1.01]">
                <a href="/execucaoexercicios?video=<%= video.slug %>" class="video-card-link">
                  <figure class="w-40 h-full relative m-0 shrink-0 overflow-hidden">
                    <img
                      class="w-full h-full object-cover transition-transform duration-500"
                      src="<%= video.capaPremium %>"
                      alt="<%= video.titulo %>"
                    />

                    <figcaption class="absolute inset-0 bg-primary/20 flex items-center justify-center">
                      <i class="material-symbols-outlined text-white text-3xl not-italic" aria-hidden="true">play_circle</i>
                    </figcaption>
                  </figure>

                  <hgroup class="p-4 flex-1">
                    <h3 class="font-bold text-on-surface"><%= video.titulo %></h3>
                    <p class="text-xs text-on-surface-variant">
                      <%= video.categoria %> • <%= video.duracao %> • <%= video.nivel %>
                    </p>
                  </hgroup>
                </a>
              </li>
            <% }) %>

          </ul>
        <% } else { %>
          <section class="bg-surface-container-lowest rounded-2xl p-6 text-center">
            <i class="material-symbols-outlined text-primary text-5xl not-italic mb-2" aria-hidden="true">video_library</i>
            <p class="font-bold text-on-surface">Nenhum vídeo carregado</p>
            <p class="text-sm text-on-surface-variant mt-1">Verifique se o router está enviando a lista videosFree.</p>
          </section>
        <% } %>

        <a href="/videos" class="mt-2 text-primary font-bold text-sm flex items-center gap-2 hover:translate-x-1 transition-transform">
          Abrir biblioteca completa
          <i class="material-symbols-outlined not-italic" aria-hidden="true">arrow_forward</i>
        </a>

      </section>

      <!-- Métricas e atalhos -->
      <section class="md:col-span-12 mt-8">

        <h2 class="text-3xl font-black headline text-on-surface mb-8">
          SUA EVOLUÇÃO NO <%= nomePlanoAluno.toUpperCase() %>
        </h2>

        <ul class="grid grid-cols-1 md:grid-cols-3 gap-6 list-none p-0 m-0" role="list">

          <li class="bg-surface-container-low rounded-[2rem] p-8 flex flex-col gap-6">
            <figure class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center m-0">
              <i class="material-symbols-outlined text-primary text-3xl not-italic" aria-hidden="true">monitoring</i>
            </figure>

            <hgroup>
              <h3 class="text-xl font-bold">Progresso Semanal</h3>
              <p class="text-sm text-on-surface-variant mt-2">
                Acompanhe seus treinos, tempo total, calorias e evolução.
              </p>
            </hgroup>

            <a href="/progressosemanal" class="mt-auto w-full bg-primary text-white py-4 rounded-full font-bold text-center active:scale-95 transition-transform">
              Ver Progresso
            </a>
          </li>

          <li class="bg-primary rounded-[2rem] p-8 flex flex-col gap-6 text-white shadow-xl shadow-primary/30 relative">
            <mark class="absolute top-0 right-8 -translate-y-1/2 bg-tertiary-fixed text-on-tertiary-fixed px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest">
              Exclusivo
            </mark>

            <figure class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center m-0">
              <i class="material-symbols-outlined text-white text-3xl not-italic" aria-hidden="true">forum</i>
            </figure>

            <hgroup>
              <h3 class="text-xl font-bold">Feedback do Professor</h3>
              <p class="text-sm opacity-80 mt-2">
                Envie sua percepção de treino, cansaço e dúvidas para acompanhamento.
              </p>
            </hgroup>

            <a href="/feedbackaluno" class="mt-auto w-full bg-white text-primary py-4 rounded-full font-bold text-center active:scale-95 transition-transform">
              Enviar Feedback
            </a>
          </li>

          <li class="bg-surface-container-lowest rounded-[2rem] p-8 flex flex-col gap-6 shadow-sm border border-outline-variant/10">
            <figure class="w-14 h-14 rounded-2xl bg-tertiary-fixed/20 flex items-center justify-center m-0">
              <i class="material-symbols-outlined text-on-tertiary-fixed text-3xl not-italic" aria-hidden="true">local_fire_department</i>
            </figure>

            <hgroup>
              <h3 class="text-xl font-bold">Streak e Descontos</h3>
