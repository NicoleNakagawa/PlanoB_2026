<!DOCTYPE html>
<html class="light" lang="pt-BR">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>PlanoB - Meus Alunos</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface": "#f7f5ff",
            "primary": "#0058ba",
            "secondary": "#00647b",
            "on-primary": "#f0f2ff",
            "on-surface": "#232c51",
            "on-surface-variant": "#505a81",
            "surface-container-lowest": "#ffffff",
            "surface-container-low": "#efefff",
            "surface-container": "#e4e7ff",
            "surface-container-highest": "#d5dbff",
            "outline": "#6c759e",
            "outline-variant": "#a2abd7",
            "tertiary-fixed": "#ffd709",
            "on-tertiary-fixed": "#453900",
            "error": "#b31b25"
          },
          borderRadius: {
            DEFAULT: "0.25rem",
            lg: "0.5rem",
            xl: "0.75rem",
            full: "9999px"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"],
            label: ["Manrope"]
          }
        }
      }
    }
  </script>

  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .logo-header {
      font-size: 2.7rem;
      line-height: 1;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    h4,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    .avatar-placeholder .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    progress {
      appearance: none;
      -webkit-appearance: none;
    }

    progress::-webkit-progress-bar {
      background: #d5dbff;
      border-radius: 999px;
    }

    progress::-webkit-progress-value {
      background: #0058ba;
      border-radius: 999px;
    }

    progress::-moz-progress-bar {
      background: #0058ba;
      border-radius: 999px;
    }

    .aluno-radio input:checked + article {
      border-color: #0058ba;
      background: #e4e7ff;
      box-shadow: 0 18px 35px rgba(0, 88, 186, 0.14);
      transform: translateY(-2px);
    }

    @media (max-width: 768px) {
      html,
      body {
        width: 100%;
        overflow-x: hidden;
      }

      body {
        background: #f7f5ff;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      header.fixed a.logo-header {
        font-size: 1.45rem;
        line-height: 1;
      }

      header.fixed menu {
        gap: 8px;
      }

      header.fixed button,
      header.fixed a {
        padding: 8px;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 16px 135px !important;
      }

      article.hero-alunos {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.hero-alunos h1 {
        font-size: 2rem !important;
        line-height: 1.1 !important;
      }

      section.card-mobile,
      article.card-mobile {
        padding: 22px !important;
        border-radius: 26px !important;
      }

      section.tabela-alunos table {
        min-width: 820px;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 52px;
        border-radius: 18px;
      }

      nav[aria-label="Navegação mobile"] a[aria-current="page"] {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
      }
    }

    @media (max-width: 420px) {
      main {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }

      article.hero-alunos h1 {
        font-size: 1.75rem !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding-left: 6px !important;
        padding-right: 6px !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 48px;
        padding: 10px 4px !important;
      }

      nav[aria-label="Navegação mobile"] em {
        font-size: 8px !important;
      }
    }
  </style>
</head>

<body class="bg-surface text-on-surface">

  <%
    const professorSeguro = typeof professor !== 'undefined' && professor ? professor : {}

    const alunosSeguros = typeof alunos !== 'undefined' && alunos ? alunos : []
    const alunosDisponiveisSeguros = typeof alunosDisponiveis !== 'undefined' && alunosDisponiveis ? alunosDisponiveis : []

    const estatisticasSeguras = typeof estatisticas !== 'undefined' && estatisticas ? estatisticas : {
      totalAlunos: 0,
      totalAtivos: 0,
      totalLazuli: 0,
      totalDiamante: 0,
      mediaProgresso: 0
    }

    const filtrosSeguros = typeof filtros !== 'undefined' && filtros ? filtros : {
      busca: '',
      plano: 'todos',
      paginaAtual: 1,
      totalPaginas: 1,
      porPagina: 8
    }

    function badgePlanoClasse(plano) {
      if (plano === 'Diamante') return 'bg-tertiary-fixed text-on-tertiary-fixed'
      if (plano === 'Lazuli') return 'bg-primary text-white'
      return 'bg-surface-container-highest text-on-surface-variant'
    }

    function statusClasse(status) {
      if (status === 'Ativo') return 'bg-emerald-500'
      if (status === 'Em pausa') return 'bg-yellow-500'
      return 'bg-outline'
    }

    function textoUltimoTreino(data) {
      if (!data) return 'Nenhum treino'
      return new Date(data).toLocaleDateString('pt-BR')
    }

    function queryPagina(numero) {
      const params = new URLSearchParams()
      if (filtrosSeguros.busca) params.set('busca', filtrosSeguros.busca)
      if (filtrosSeguros.plano) params.set('plano', filtrosSeguros.plano)
      params.set('page', numero)
      return '/todosalunos?' + params.toString()
    }
  %>

  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">

    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <a href="/painelprofessor" class="font-headline logo-font logo-header text-primary no-underline">PlanoB</a>
    </nav>

    <form action="/todosalunos" method="GET" class="hidden md:flex items-center bg-surface-container-low px-4 py-2 rounded-full">
      <i class="material-symbols-outlined text-outline text-sm not-italic" aria-hidden="true">search</i>

      <label for="top-search" class="sr-only">Buscar alunos</label>

      <input
        id="top-search"
        name="busca"
        value="<%= filtrosSeguros.busca %>"
        class="bg-transparent border-none focus:ring-0 text-sm w-48 ml-2"
        placeholder="Buscar alunos..."
        type="search"
      />

      <input type="hidden" name="plano" value="<%= filtrosSeguros.plano %>">
    </form>

    <menu class="flex items-center gap-4 p-0 m-0 list-none">
      <li>
        <a href="/feedbackprofessor" class="p-2 rounded-full hover:bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center" aria-label="Feedbacks">
          <i class="material-symbols-outlined text-on-background not-italic" aria-hidden="true">notifications</i>
        </a>
      </li>

      <li>
        <a href="/painelprofessor" class="p-1 rounded-full bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center" aria-label="Perfil do professor">
          <% if (professorSeguro.foto) { %>
            <img src="<%= professorSeguro.foto %>" alt="Foto do professor" class="w-10 h-10 rounded-full object-cover">
          <% } else { %>
            <span class="w-10 h-10 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </span>
          <% } %>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] dark:bg-[#12141c] flex-col gap-2 py-8 z-40 mt-16">

    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <picture>
          <% if (professorSeguro.foto) { %>
            <img
              class="w-12 h-12 rounded-full object-cover"
              src="<%= professorSeguro.foto %>"
              alt="Foto de perfil do professor"
            />
          <% } else { %>
            <span class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden" aria-label="Professor sem foto">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </span>
          <% } %>
        </picture>

        <figcaption>
          <p class="text-sm font-bold text-on-surface">Portal do Professor</p>
          <p class="text-xs text-on-surface-variant">
            <%= professorSeguro.nome ? professorSeguro.nome.split(' ')[0] : 'Bem-vindo' %>
          </p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/painelprofessor">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">dashboard</i>
        <em class="not-italic">Dashboard</em>
      </a>

      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="/todosalunos" aria-current="page">
        <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">groups</i>
        <em class="not-italic">Meus Alunos</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/todosvideos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">video_library</i>
        <em class="not-italic">Meus Vídeos</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/feedbackprofessor">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
        <em class="not-italic">Feedbacks</em>
      </a>

    </nav>

    <footer class="mt-auto px-4 pb-8 flex flex-col gap-2">
      <a href="#vincular-aluno" class="w-full bg-primary text-on-primary rounded-full py-4 font-bold shadow-lg shadow-primary/30 flex items-center justify-center gap-2 active:scale-95 transition-transform">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">person_add</i>
        Vincular aluno
      </a>

      <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:text-error rounded-full hover:bg-surface-container transition-colors text-sm"
         href="/logout">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i>
        <em class="not-italic">Sair</em>
      </a>
    </footer>
  </aside>

  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <article class="hero-alunos md:col-span-12 relative overflow-hidden rounded-3xl bg-primary p-8 md:p-12 text-white shadow-2xl">

        <section class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">

          <hgroup class="max-w-2xl">
            <mark class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md text-xs font-bold uppercase tracking-widest mb-4 text-white">
              Gestão de Alunos
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              MEUS ALUNOS.
            </h1>

            <p class="text-lg opacity-90 max-w-xl">
              Veja alunos vinculados às suas fichas, acompanhe progresso, filtre por plano e associe novos alunos ao seu acompanhamento.
            </p>
          </hgroup>

          <figure class="flex flex-col items-center gap-4 bg-white/10 backdrop-blur-xl p-6 md:p-8 rounded-3xl border border-white/10 w-full max-w-[240px] mx-auto md:mx-0 md:w-auto m-0">
            <span class="w-28 h-28 rounded-full bg-white/15 flex items-center justify-center">
              <i class="material-symbols-outlined text-white text-7xl not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 48" aria-hidden="true">groups</i>
            </span>

            <figcaption class="text-sm font-black uppercase tracking-widest text-center">
              <%= estatisticasSeguras.totalAlunos %> alunos vinculados
            </figcaption>
          </figure>

        </section>

        <b class="absolute -right-20 -bottom-20 w-96 h-96 bg-[#80deff] opacity-10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        <b class="absolute -left-20 -top-20 w-64 h-64 bg-white opacity-5 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
      </article>

      <% if (erro) { %>
        <section class="md:col-span-12 bg-red-50 text-error rounded-3xl p-5 font-bold text-center" role="alert">
          <%= erro %>
        </section>
      <% } %>

      <% if (sucesso) { %>
        <section class="md:col-span-12 bg-green-50 text-green-700 rounded-3xl p-5 font-bold text-center" role="status">
          <%= sucesso %>
        </section>
      <% } %>

      <section class="md:col-span-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-6 shadow-sm flex items-center gap-4">
          <figure class="w-14 h-14 rounded-2xl bg-primary/10 text-primary flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">groups</i>
          </figure>

          <section>
            <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Total vinculados</p>
            <data value="<%= estatisticasSeguras.totalAlunos %>" class="text-3xl font-black headline text-on-surface">
              <%= estatisticasSeguras.totalAlunos %>
            </data>
          </section>
        </article>

        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-6 shadow-sm flex items-center gap-4">
          <figure class="w-14 h-14 rounded-2xl bg-emerald-500/10 text-emerald-600 flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">check_circle</i>
          </figure>

          <section>
            <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Ativos semana</p>
            <data value="<%= estatisticasSeguras.totalAtivos %>" class="text-3xl font-black headline text-on-surface">
              <%= estatisticasSeguras.totalAtivos %>
            </data>
          </section>
        </article>

        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-6 shadow-sm flex items-center gap-4">
          <figure class="w-14 h-14 rounded-2xl bg-primary/10 text-primary flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">workspace_premium</i>
          </figure>

          <section>
            <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Lazuli</p>
            <data value="<%= estatisticasSeguras.totalLazuli %>" class="text-3xl font-black headline text-on-surface">
              <%= estatisticasSeguras.totalLazuli %>
            </data>
          </section>
        </article>

        <article class="card-mobile bg-tertiary-fixed rounded-3xl p-6 shadow-sm flex items-center gap-4 text-on-tertiary-fixed">
          <figure class="w-14 h-14 rounded-2xl bg-white/25 flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">diamond</i>
          </figure>

          <section>
            <p class="text-xs font-black uppercase tracking-widest opacity-70">Diamante</p>
            <data value="<%= estatisticasSeguras.totalDiamante %>" class="text-3xl font-black headline">
              <%= estatisticasSeguras.totalDiamante %>
            </data>
          </section>
        </article>

      </section>

      <section id="vincular-aluno" class="card-mobile md:col-span-12 bg-surface-container-lowest rounded-3xl p-8 shadow-sm flex flex-col gap-6">

        <header class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <hgroup>
            <h2 class="text-2xl font-extrabold headline text-on-surface">Vincular aluno ao professor</h2>
            <p class="text-sm text-on-surface-variant mt-1">
              Escolha um aluno cadastrado para vincular a uma ficha sua.
            </p>
          </hgroup>

          <form action="/professor/vincular-alunos-disponiveis" method="POST">
            <button type="submit" class="inline-flex items-center justify-center gap-2 bg-surface-container-highest text-on-surface px-6 py-3 rounded-full font-bold active:scale-95 transition-transform">
              Vincular todos disponíveis
              <i class="material-symbols-outlined not-italic" aria-hidden="true">group_add</i>
            </button>
          </form>
        </header>

        <form action="/professor/vincular-aluno" method="POST" class="flex flex-col gap-6">

          <section>
            <label for="busca-alunos-disponiveis" class="text-xs font-black uppercase tracking-widest text-on-surface-variant block mb-2">
              Buscar nos alunos disponíveis
            </label>

            <input
              id="busca-alunos-disponiveis"
              type="search"
              placeholder="Digite nome, e-mail ou plano..."
              class="w-full rounded-2xl border-none bg-surface-container-low px-5 py-4 focus:ring-2 focus:ring-primary"
              oninput="filtrarAlunosDisponiveis(this.value)"
            />
          </section>

          <% if (alunosDisponiveisSeguros.length > 0) { %>
            <section class="max-h-[420px] overflow-y-auto pr-2 rounded-3xl">
              <fieldset class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                <legend class="sr-only">Alunos disponíveis</legend>

                <% alunosDisponiveisSeguros.forEach(function(alunoDisponivel) { %>
                  <label class="aluno-radio cursor-pointer aluno-disponivel-card" data-aluno-texto="<%= (alunoDisponivel.nome + ' ' + alunoDisponivel.email + ' ' + alunoDisponivel.plano).toLowerCase() %>">
                    <input type="radio" name="id_aluno" value="<%= alunoDisponivel.id_aluno %>" class="sr-only" required>

                    <article class="h-full rounded-3xl border-2 border-outline-variant/20 bg-surface-container-low p-5 flex items-center gap-4 transition-all">
                      <figure class="w-14 h-14 rounded-2xl overflow-hidden avatar-placeholder flex items-center justify-center m-0 shrink-0">
                        <% if (alunoDisponivel.foto_perfil) { %>
                          <img src="<%= alunoDisponivel.foto_perfil %>" alt="Foto de <%= alunoDisponivel.nome %>" class="w-full h-full object-cover">
                        <% } else { %>
                          <i class="material-symbols-outlined text-5xl not-italic" aria-hidden="true">account_circle</i>
                        <% } %>
                      </figure>

                      <hgroup class="min-w-0">
                        <h3 class="font-black text-on-surface truncate"><%= alunoDisponivel.nome %></h3>
                        <p class="text-xs text-on-surface-variant truncate"><%= alunoDisponivel.email %></p>
                        <strong class="inline-block mt-2 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= badgePlanoClasse(alunoDisponivel.plano) %>">
                          <%= alunoDisponivel.plano %>
                        </strong>
                      </hgroup>
                    </article>
                  </label>
                <% }) %>
              </fieldset>
            </section>
          <% } else { %>
            <section class="bg-surface-container-low rounded-3xl p-8 text-center">
              <i class="material-symbols-outlined text-primary text-6xl not-italic mb-3" aria-hidden="true">person_search</i>
              <h3 class="text-xl font-black headline text-on-surface">Nenhum aluno disponível</h3>
              <p class="text-sm text-on-surface-variant mt-2">
                Todos os alunos cadastrados já estão vinculados a você, ou ainda não existem alunos cadastrados.
              </p>
            </section>
          <% } %>

          <section class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <label>
              <span class="text-xs font-black uppercase tracking-widest text-on-surface-variant block mb-2">Nome da ficha</span>

              <input
                type="text"
                name="nome_ficha"
                value="Ficha principal"
                class="w-full rounded-2xl border-none bg-surface-container-low px-4 py-4 focus:ring-2 focus:ring-primary"
              />
            </label>

            <label>
              <span class="text-xs font-black uppercase tracking-widest text-on-surface-variant block mb-2">Categoria</span>

              <input
                type="text"
                name="categoria"
                value="Treino personalizado"
                class="w-full rounded-2xl border-none bg-surface-container-low px-4 py-4 focus:ring-2 focus:ring-primary"
              />
            </label>

            <label>
              <span class="text-xs font-black uppercase tracking-widest text-on-surface-variant block mb-2">Nível</span>

              <select name="nivel" class="w-full rounded-2xl border-none bg-surface-container-low px-4 py-4 focus:ring-2 focus:ring-primary">
                <option value="iniciante">Iniciante</option>
                <option value="intermediario">Intermediário</option>
                <option value="avancado">Avançado</option>
              </select>
            </label>
          </section>

          <button type="submit" class="bg-primary text-white rounded-full px-8 py-4 font-black shadow-lg shadow-primary/20 active:scale-95 transition-transform inline-flex items-center justify-center gap-2">
            Vincular aluno selecionado
            <i class="material-symbols-outlined not-italic" aria-hidden="true">person_add</i>
          </button>
        </form>

      </section>

      <section class="card-mobile md:col-span-12 bg-surface-container-low rounded-3xl p-8 flex flex-col gap-6">

        <header class="flex flex-col lg:flex-row lg:items-center justify-between gap-4">
          <hgroup>
            <h2 class="text-2xl font-extrabold headline text-on-surface">Lista de alunos</h2>
            <p class="text-sm text-on-surface-variant mt-1">
              Exibindo <%= alunosSeguros.length %> de <%= estatisticasSeguras.totalAlunos %> alunos vinculados.
            </p>
          </hgroup>

          <form action="/todosalunos" method="GET" class="flex flex-col md:flex-row gap-3">
            <label class="sr-only" for="busca">Buscar aluno</label>

            <input
              id="busca"
              name="busca"
              value="<%= filtrosSeguros.busca %>"
              type="search"
              placeholder="Buscar por nome ou e-mail"
              class="rounded-full border-none bg-surface-container-lowest px-5 py-3 focus:ring-2 focus:ring-primary min-w-[240px]"
            />

            <label class="sr-only" for="plano">Plano</label>

            <select
              id="plano"
              name="plano"
              class="rounded-full border-none bg-surface-container-lowest px-5 py-3 focus:ring-2 focus:ring-primary"
            >
              <option value="todos" <%= filtrosSeguros.plano === 'todos' ? 'selected' : '' %>>Todos</option>
              <option value="Free" <%= filtrosSeguros.plano === 'Free' ? 'selected' : '' %>>Free</option>
              <option value="Lazuli" <%= filtrosSeguros.plano === 'Lazuli' ? 'selected' : '' %>>Lazuli</option>
              <option value="Diamante" <%= filtrosSeguros.plano === 'Diamante' ? 'selected' : '' %>>Diamante</option>
            </select>

            <button type="submit" class="bg-primary text-white rounded-full px-6 py-3 font-bold active:scale-95 transition-transform">
              Filtrar
            </button>
          </form>
        </header>

        <% if (alunosSeguros.length > 0) { %>
          <section class="tabela-alunos overflow-x-auto">
            <table class="w-full text-left border-separate border-spacing-y-3">
              <thead>
                <tr class="text-on-surface-variant text-xs uppercase tracking-widest">
                  <th class="px-4 py-2">Aluno</th>
                  <th class="px-4 py-2">Plano</th>
                  <th class="px-4 py-2">Progresso</th>
                  <th class="px-4 py-2">Ficha</th>
                  <th class="px-4 py-2">Status</th>
                  <th class="px-4 py-2 text-right">Ações</th>
                </tr>
              </thead>

              <tbody class="text-sm">
                <% alunosSeguros.forEach(function(alunoItem) { %>
                  <tr class="bg-surface-container-lowest hover:bg-surface-container-highest transition-colors">
                    <td class="px-4 py-4 rounded-l-3xl">
                      <article class="flex items-center gap-3">
                        <figure class="w-12 h-12 rounded-2xl overflow-hidden m-0 avatar-placeholder flex items-center justify-center shrink-0">
                          <% if (alunoItem.foto_perfil) { %>
                            <img alt="Foto de <%= alunoItem.nome %>" src="<%= alunoItem.foto_perfil %>" class="w-full h-full object-cover">
                          <% } else { %>
                            <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
                          <% } %>
                        </figure>

                        <hgroup>
                          <p class="font-black text-on-surface"><%= alunoItem.nome %></p>
                          <p class="text-xs text-on-surface-variant"><%= alunoItem.email %></p>
                        </hgroup>
                      </article>
                    </td>

                    <td class="px-4 py-4">
                      <strong class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= badgePlanoClasse(alunoItem.plano) %>">
                        <%= alunoItem.plano %>
                      </strong>
                    </td>

                    <td class="px-4 py-4">
                      <section class="flex items-center gap-3 min-w-[150px]">
                        <progress class="flex-1 h-3 rounded-full overflow-hidden" value="<%= alunoItem.progresso %>" max="100">
                          <%= alunoItem.progresso %>%
                        </progress>

                        <strong class="w-10 text-xs font-black text-primary">
                          <%= alunoItem.progresso %>%
                        </strong>
                      </section>

                      <p class="text-xs text-on-surface-variant mt-1">
                        <%= alunoItem.dias_treinados_semana %>/<%= alunoItem.meta_dias_aluno %> dias nesta semana
                      </p>
                    </td>

                    <td class="px-4 py-4">
                      <p class="font-black text-on-surface"><%= alunoItem.nome_ficha || 'Ficha principal' %></p>
                      <p class="text-xs text-on-surface-variant">
                        <%= alunoItem.categoria || 'Treino' %> • <%= alunoItem.nivel || 'Nível livre' %>
                      </p>
                    </td>

                    <td class="px-4 py-4">
                      <section class="inline-flex items-center gap-2 bg-surface-container-low px-3 py-2 rounded-full">
                        <i class="h-2 w-2 rounded-full <%= statusClasse(alunoItem.status) %> inline-block"></i>
                        <b class="text-xs font-black"><%= alunoItem.status %></b>
                      </section>

                      <p class="text-xs text-on-surface-variant mt-2">
                        Último: <%= textoUltimoTreino(alunoItem.ultimo_treino) %>
                      </p>
                    </td>

                    <td class="px-4 py-4 text-right rounded-r-3xl">
                      <section class="flex justify-end gap-2">
                        <a href="/feedbackresposta?aluno=<%= alunoItem.id_aluno %>" class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary/10 text-primary hover:bg-primary hover:text-white transition-colors" aria-label="Responder aluno">
                          <i class="material-symbols-outlined not-italic" aria-hidden="true">chat</i>
                        </a>

                        <a href="/visaoperfilaluno?id_aluno=<%= alunoItem.id_aluno %>" class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-surface-container-highest text-on-surface-variant hover:bg-primary hover:text-white transition-colors" aria-label="Ver perfil do aluno">
                          <i class="material-symbols-outlined not-italic" aria-hidden="true">visibility</i>
                        </a>

                        <form action="/professor/desvincular-aluno" method="POST" onsubmit="return confirm('Deseja desvincular este aluno?')">
                          <input type="hidden" name="id_aluno" value="<%= alunoItem.id_aluno %>">

                          <button type="submit" class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-red-50 text-error hover:bg-error hover:text-white transition-colors" aria-label="Desvincular aluno">
                            <i class="material-symbols-outlined not-italic" aria-hidden="true">link_off</i>
                          </button>
                        </form>
                      </section>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </section>
        <% } else { %>
          <section class="bg-surface-container-lowest rounded-3xl p-10 text-center">
            <i class="material-symbols-outlined text-primary text-6xl not-italic mb-4" aria-hidden="true">groups</i>
            <h3 class="text-2xl font-black headline text-on-surface">Nenhum aluno encontrado</h3>
            <p class="text-on-surface-variant mt-2">
              Vincule um aluno cadastrado usando o formulário acima.
            </p>
          </section>
        <% } %>

        <footer class="flex flex-col md:flex-row md:items-center justify-between gap-4 pt-4">
          <p class="text-xs font-bold text-on-surface-variant">
            Página <%= filtrosSeguros.paginaAtual %> de <%= filtrosSeguros.totalPaginas %>
          </p>

          <nav class="flex gap-2" aria-label="Paginação">
            <% if (filtrosSeguros.paginaAtual > 1) { %>
              <a href="<%= queryPagina(filtrosSeguros.paginaAtual - 1) %>" class="h-10 w-10 flex items-center justify-center rounded-full bg-surface-container-lowest text-on-surface hover:bg-primary hover:text-white transition-colors">
                <i class="material-symbols-outlined not-italic text-sm" aria-hidden="true">chevron_left</i>
              </a>
            <% } %>

            <% for (let pagina = 1; pagina <= filtrosSeguros.totalPaginas; pagina++) { %>
              <a href="<%= queryPagina(pagina) %>" class="h-10 w-10 flex items-center justify-center rounded-full <%= pagina === filtrosSeguros.paginaAtual ? 'bg-primary text-white shadow-lg shadow-primary/20' : 'bg-surface-container-lowest text-on-surface hover:bg-primary hover:text-white' %> font-bold transition-colors">
                <%= pagina %>
              </a>
            <% } %>

            <% if (filtrosSeguros.paginaAtual < filtrosSeguros.totalPaginas) { %>
              <a href="<%= queryPagina(filtrosSeguros.paginaAtual + 1) %>" class="h-10 w-10 flex items-center justify-center rounded-full bg-surface-container-lowest text-on-surface hover:bg-primary hover:text-white transition-colors">
                <i class="material-symbols-outlined not-italic text-sm" aria-hidden="true">chevron_right</i>
              </a>
            <% } %>
          </nav>
        </footer>

      </section>

    </section>
  </main>

  <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex justify-around items-end px-4 pb-6 pt-2 bg-[#f7f5ff]/90 backdrop-blur-lg shadow-[0_-10px_40px_rgba(35,44,81,0.08)] rounded-t-[32px]"
       aria-label="Navegação mobile">

    <a href="/painelprofessor"
       class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">dashboard</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Início</em>
    </a>

    <a href="/todosalunos"
       class="flex flex-col items-center justify-center text-[#0058ba] opacity-100 p-3 rounded-[18px] bg-[#d5dbff]"
       aria-current="page">
      <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">groups</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Alunos</em>
    </a>

    <a href="#vincular-aluno"
       class="bg-primary text-white w-14 h-14 rounded-full shadow-lg shadow-primary/40 -mt-8 flex items-center justify-center active:scale-95 transition-transform"
       aria-label="Vincular aluno">
      <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">person_add</i>
    </a>

    <a href="/todosvideos"
       class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">video_library</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Vídeos</em>
    </a>

    <a href="/feedbackprofessor"
       class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Feedback</em>
    </a>

  </nav>

  <script>
    function filtrarAlunosDisponiveis(valor) {
      const termo = valor.toLowerCase().trim()
      const cards = document.querySelectorAll('.aluno-disponivel-card')

      cards.forEach(card => {
        const texto = card.dataset.alunoTexto || ''

        if (texto.includes(termo)) {
          card.style.display = ''
        } else {
          card.style.display = 'none'
        }
      })
    }
  </script>

</body>
</html>