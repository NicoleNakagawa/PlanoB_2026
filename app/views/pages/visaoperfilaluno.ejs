<!DOCTYPE html>
<html class="light" lang="pt-BR">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>PlanoB - Perfil do Aluno</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            surface: "#f7f5ff",
            primary: "#0058ba",
            secondary: "#00647b",
            "on-primary": "#f0f2ff",
            "on-surface": "#232c51",
            "on-surface-variant": "#505a81",
            "surface-container-lowest": "#ffffff",
            "surface-container-low": "#efefff",
            "surface-container": "#e4e7ff",
            "surface-container-high": "#dde1ff",
            "surface-container-highest": "#d5dbff",
            outline: "#6c759e",
            "outline-variant": "#a2abd7",
            "tertiary-fixed": "#ffd709",
            "on-tertiary-fixed": "#453900",
            error: "#b31b25"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"],
            label: ["Manrope"]
          }
        }
      }
    }
  </script>

  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .logo-header {
      font-size: 2.7rem;
      line-height: 1;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    h4,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    .avatar-placeholder .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    progress,
    meter {
      appearance: none;
      -webkit-appearance: none;
    }

    progress::-webkit-progress-bar {
      background: #d5dbff;
      border-radius: 999px;
    }

    progress::-webkit-progress-value {
      background: #0058ba;
      border-radius: 999px;
    }

    progress::-moz-progress-bar {
      background: #0058ba;
      border-radius: 999px;
    }

    meter::-webkit-meter-bar {
      background: #d5dbff;
      border: none;
      border-radius: 999px;
    }

    meter::-webkit-meter-optimum-value,
    meter::-webkit-meter-suboptimum-value,
    meter::-webkit-meter-even-less-good-value {
      background: #0058ba;
      border-radius: 999px;
    }

    .notification-menu {
      position: relative;
      display: flex;
      align-items: center;
    }

    .notification-button {
      position: relative;
      width: 40px;
      height: 40px;
      padding: 8px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .notification-popup {
      position: absolute;
      top: 48px;
      right: 0;
      width: 300px;
      max-width: calc(100vw - 24px);
      background: #ffffff;
      border: 1px solid #e4e7ff;
      border-radius: 22px;
      box-shadow: 0 18px 45px rgba(35, 44, 81, 0.18);
      padding: 12px;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(-8px);
      transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s ease;
      z-index: 99999;
    }

    .notification-popup.open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateY(0);
    }

    .notification-arrow {
      position: absolute;
      top: -7px;
      right: 18px;
      width: 14px;
      height: 14px;
      background: #ffffff;
      border-left: 1px solid #e4e7ff;
      border-top: 1px solid #e4e7ff;
      transform: rotate(45deg);
    }

    .notification-badge {
      position: absolute;
      top: -3px;
      right: -3px;
      min-width: 18px;
      height: 18px;
      padding: 0 5px;
      border-radius: 999px;
      background: #b31b25;
      color: #ffffff;
      font-size: 9px;
      font-weight: 900;
      line-height: 18px;
      display: none;
      align-items: center;
      justify-content: center;
    }

    .notification-badge.active {
      display: flex;
    }

    .notification-list {
      max-height: 260px;
      overflow-y: auto;
    }

    @media (max-width: 768px) {
      html,
      body {
        width: 100%;
        overflow-x: hidden;
      }

      body {
        background: #f7f5ff;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      header.fixed a.logo-header {
        font-size: 1.45rem;
        line-height: 1;
      }

      header.fixed menu {
        gap: 8px;
      }

      header.fixed button,
      header.fixed a {
        padding: 8px;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 16px 135px !important;
      }

      article.hero-aluno-prof {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.hero-aluno-prof h1 {
        font-size: 2rem !important;
        line-height: 1.1 !important;
      }

      section.card-mobile,
      article.card-mobile {
        padding: 22px !important;
        border-radius: 26px !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 52px;
        border-radius: 18px;
      }

      nav[aria-label="Navegação mobile"] a[aria-current="page"] {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
      }

      .notification-popup {
        right: -52px;
        width: 280px;
      }

      .notification-arrow {
        right: 66px;
      }
    }

    @media (max-width: 420px) {
      main {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 48px;
        padding: 10px 4px !important;
      }

      nav[aria-label="Navegação mobile"] em {
        font-size: 8px !important;
      }
    }

    .weekly-frequency-chart {
  min-height: 320px;
}

.weekly-frequency-bars {
  height: 240px;
  align-items: flex-end;
}

.weekly-frequency-bar {
  min-height: 18px;
  background: linear-gradient(180deg, #0058ba 0%, #6c9fff 100%);
  border-radius: 999px 999px 18px 18px;
  box-shadow: 0 12px 28px rgba(0, 88, 186, 0.22);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.weekly-frequency-bar:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 35px rgba(0, 88, 186, 0.3);
}

.weekly-frequency-bar.is-low {
  background: linear-gradient(180deg, #a2abd7 0%, #d5dbff 100%);
  box-shadow: none;
}

.weekly-frequency-value {
  margin-bottom: 10px;
  font-size: 0.75rem;
  font-weight: 900;
  color: #0058ba;
}

@media (max-width: 768px) {
  .weekly-frequency-chart {
    min-height: 280px;
  }

  .weekly-frequency-bars {
    height: 200px;
  }
}
  </style>

  <link rel="stylesheet" href="/css/transicao-paginas.css">
</head>

<body class="bg-surface text-on-surface">

  <%
    const professorSeguro = typeof professor !== 'undefined' && professor ? professor : {}
    const alunoSeguro = typeof alunoPerfil !== 'undefined' && alunoPerfil ? alunoPerfil : {}
    const resumoSeguro = typeof resumoTreinos !== 'undefined' && resumoTreinos ? resumoTreinos : {
      total_treinos: 0,
      tempo_total: 0,
      tempo_medio: 0,
      calorias_total: 0,
      bpm_maximo: 0
    }
    const streakSeguro = typeof streak !== 'undefined' && streak ? streak : {
      streak_atual: 0,
      streak_maximo: 0
    }
    const historicoSeguro = typeof historicoTreinos !== 'undefined' && historicoTreinos ? historicoTreinos : []
    const feedbacksSeguros = typeof feedbacksAluno !== 'undefined' && feedbacksAluno ? feedbacksAluno : []
    const frequenciaSegura = typeof frequenciaSemanas !== 'undefined' && frequenciaSemanas ? frequenciaSemanas : []
    const progressoSeguro = typeof progressoSemana !== 'undefined' && progressoSemana ? progressoSemana : {
      dias_treinados: 0,
      meta_dias: 5,
      porcentagem: 0,
      variacao_pct: 0
    }

    const nomeProfessor = professorSeguro.nome ? professorSeguro.nome.split(' ')[0] : 'Professor'
    const nomeAluno = alunoSeguro.nome ? alunoSeguro.nome.split(' ')[0] : 'Aluno'

    const planoAluno = alunoSeguro.id_plano ? Number(alunoSeguro.id_plano) : 1
    const nomePlanoAluno = alunoSeguro.plano || (planoAluno === 3 ? 'Diamante' : planoAluno === 2 ? 'Lazuli' : 'Free')

    const mapaObjetivo = {
      hipertrofia: 'Hipertrofia',
      emagrecimento: 'Emagrecimento',
      forca: 'Força',
      condicionamento: 'Condicionamento'
    }

    const mapaTipoTreino = {
      musculacao: 'Musculação',
      calistenia: 'Calistenia',
      cardio: 'Cardio',
      misto: 'Misto'
    }

    const mapaNivel = {
      iniciante: 'Iniciante',
      intermediario: 'Intermediário',
      avancado: 'Avançado'
    }

    const mapaLocal = {
      casa: 'Casa',
      academia: 'Academia',
      ar_livre: 'Ar livre'
    }

    const mapaEquipamentos = {
      nenhum: 'Nenhum',
      halteres: 'Halteres',
      elasticos: 'Elásticos',
      barra: 'Barra',
      maquinas: 'Máquinas',
      esteira: 'Esteira',
      bicicleta: 'Bicicleta',
      colchonete: 'Colchonete'
    }

    const equipamentosArray = alunoSeguro.equipamentos
      ? alunoSeguro.equipamentos.split(',').filter(Boolean)
      : []

    const equipamentosFormatados = equipamentosArray.length > 0
      ? equipamentosArray.map(function(item) { return mapaEquipamentos[item] || item }).join(', ')
      : 'Não informado'

    function dataFormatada(data) {
      if (!data) return 'Sem data'
      return new Date(data).toLocaleDateString('pt-BR')
    }

    function dataHoraFormatada(data) {
      if (!data) return 'Sem registro'
      return new Date(data).toLocaleString('pt-BR', { dateStyle: 'short', timeStyle: 'short' })
    }

    function porcentagemFrequencia(item) {
      const meta = Number(item.meta_dias || 5)
      const dias = Number(item.dias_treinados || 0)
      if (!meta) return 0
      return Math.min(Math.round((dias / meta) * 100), 100)
    }

    const objetivoTexto = mapaObjetivo[alunoSeguro.objetivo] || alunoSeguro.objetivo || 'Não informado'
    const tipoTreinoTexto = mapaTipoTreino[alunoSeguro.tipo_treino] || alunoSeguro.tipo_treino || 'Não informado'
    const nivelTexto = mapaNivel[alunoSeguro.nivel_treino] || alunoSeguro.nivel_treino || 'Não informado'
    const localTexto = mapaLocal[alunoSeguro.local_treino] || alunoSeguro.local_treino || 'Não informado'
    const metaDias = Number(progressoSeguro.meta_dias || alunoSeguro.dias_semana || 5) || 5
    const diasTreinados = Number(progressoSeguro.dias_treinados || 0) || 0
    const porcentagemSemana = Number(progressoSeguro.porcentagem || Math.min(Math.round((diasTreinados / metaDias) * 100), 100)) || 0
    const variacaoPct = Number(progressoSeguro.variacao_pct || 0) || 0
  %>

  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">
    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <a href="/painelprofessor" class="font-headline logo-font logo-header text-primary no-underline">PlanoB</a>
    </nav>

    <form action="/todosalunos" method="GET" class="hidden md:flex items-center bg-surface-container-low px-4 py-2 rounded-full">
      <i class="material-symbols-outlined text-outline text-sm not-italic" aria-hidden="true">search</i>
      <label for="top-search" class="sr-only">Buscar alunos</label>
      <input
        id="top-search"
        name="busca"
        class="bg-transparent border-none focus:ring-0 text-sm w-48 ml-2"
        placeholder="Buscar alunos..."
        type="search"
      />
    </form>

    <menu class="flex items-center gap-4 p-0 m-0 list-none">
      <li class="notification-menu">
        <button
          id="notification-button"
          type="button"
          class="notification-button hover:bg-surface-container transition-colors active:scale-95"
          aria-label="Abrir notificações"
          aria-expanded="false"
          aria-controls="notification-popup"
        >
          <i class="material-symbols-outlined text-on-surface not-italic" aria-hidden="true">notifications</i>
          <em id="notification-badge" class="notification-badge not-italic">0</em>
        </button>

        <section id="notification-popup" class="notification-popup" aria-label="Notificações">
          <b class="notification-arrow font-normal" aria-hidden="true"></b>

          <header class="flex items-center justify-between gap-3 px-2 pb-3 border-b border-surface-container">
            <h2 class="text-sm font-black text-on-surface">Notificações</h2>
            <a href="/feedbackprofessor?status=pendentes" class="text-xs font-black text-primary hover:underline">Ver todas</a>
          </header>

          <section id="notification-content" class="notification-list pt-3">
            <article class="rounded-2xl bg-surface-container-low p-4 text-center">
              <i class="material-symbols-outlined text-primary text-4xl not-italic mb-2" aria-hidden="true">hourglass_empty</i>
              <p class="text-sm font-bold text-on-surface">Carregando...</p>
            </article>
          </section>
        </section>
      </li>

      <li>
        <a href="/perfilprofessor" class="p-1 rounded-full bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center" aria-label="Perfil do professor">
          <% if (professorSeguro.foto) { %>
            <img src="<%= professorSeguro.foto %>" alt="Foto do professor" class="w-10 h-10 rounded-full object-cover">
          <% } else { %>
            <em class="w-10 h-10 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden not-italic">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </em>
          <% } %>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] flex-col gap-2 py-8 z-40 mt-16">
    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <% if (professorSeguro.foto) { %>
          <img class="w-12 h-12 rounded-full object-cover" src="<%= professorSeguro.foto %>" alt="Foto de perfil do professor" />
        <% } else { %>
          <em class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden not-italic" aria-label="Professor sem foto">
            <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
          </em>
        <% } %>

        <figcaption>
          <p class="text-sm font-bold text-on-surface"><%= nomeProfessor %></p>
          <p class="text-xs text-on-surface-variant"><%= professorSeguro.cref ? 'CREF ' + professorSeguro.cref : 'Professor PlanoB' %></p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/painelprofessor">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">dashboard</i>
        <em class="not-italic">Dashboard</em>
      </a>

      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="/todosalunos" aria-current="page">
        <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">groups</i>
        <em class="not-italic">Meus Alunos</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/todosvideos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">video_library</i>
        <em class="not-italic">Meus Vídeos</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/feedbackprofessor">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
        <em class="not-italic">Feedbacks</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/perfilprofessor">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">person</i>
        <em class="not-italic">Perfil</em>
      </a>
    </nav>

    <footer class="mt-auto px-4 pb-8 flex flex-col gap-2">
      <a href="/editarexercicios?aluno=<%= alunoSeguro.id_aluno || alunoSeguro.id || '' %>" class="w-full bg-primary text-on-primary rounded-full py-4 font-bold shadow-lg shadow-primary/30 flex items-center justify-center gap-2 active:scale-95 transition-transform">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">add_circle</i>
        Novo Treino
      </a>

      <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:text-error rounded-full hover:bg-surface-container transition-colors text-sm" href="/logout">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i>
        <em class="not-italic">Sair</em>
      </a>
    </footer>
  </aside>

  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <nav class="md:col-span-12 flex items-center justify-between gap-4" aria-label="Voltar">
        <button type="button" onclick="history.back()" class="inline-flex items-center gap-2 bg-surface-container-lowest text-primary px-5 py-3 rounded-full font-bold shadow-sm hover:bg-surface-container transition-all active:scale-95">
          <i class="material-symbols-outlined not-italic" aria-hidden="true">arrow_back</i>
          Voltar
        </button>
      </nav>

      <article class="hero-aluno-prof md:col-span-12 relative overflow-hidden rounded-3xl bg-primary p-8 md:p-12 text-white shadow-2xl">
        <section class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
          <figure class="relative shrink-0 m-0">
            <% if (alunoSeguro.foto_perfil || alunoSeguro.foto) { %>
              <img class="w-36 h-36 md:w-44 md:h-44 rounded-[2rem] object-cover border-4 border-white/30 shadow-2xl" src="<%= alunoSeguro.foto_perfil || alunoSeguro.foto %>" alt="Foto do aluno <%= alunoSeguro.nome || '' %>">
            <% } else { %>
              <em class="w-36 h-36 md:w-44 md:h-44 rounded-[2rem] avatar-placeholder flex items-center justify-center overflow-hidden not-italic border-4 border-white/30 shadow-2xl" aria-label="Aluno sem foto">
                <i class="material-symbols-outlined text-[8rem] not-italic" aria-hidden="true">account_circle</i>
              </em>
            <% } %>
          </figure>

          <hgroup class="flex-1 text-center md:text-left">
            <mark class="inline-flex items-center gap-1 bg-tertiary-fixed text-on-tertiary-fixed px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest mb-4">
              <i class="material-symbols-outlined text-sm not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true"><%= planoAluno === 3 ? 'diamond' : planoAluno === 2 ? 'workspace_premium' : 'person' %></i>
              Plano <%= nomePlanoAluno %>
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              <%= alunoSeguro.nome || 'Aluno' %>
            </h1>

            <p class="text-lg opacity-90 max-w-xl mx-auto md:mx-0">
              Acompanhe dados reais de treino, progresso, frequência, feedbacks e histórico do aluno.
            </p>

            <ul class="flex flex-wrap justify-center md:justify-start gap-3 mt-6 list-none p-0 m-0">
              <li class="bg-white/15 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-bold"><%= objetivoTexto %></li>
              <li class="bg-white/15 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-bold"><%= nivelTexto %></li>
              <li class="bg-white/15 backdrop-blur-sm px-4 py-2 rounded-full text-sm font-bold"><%= localTexto %></li>
            </ul>
          </hgroup>

          <aside class="w-full md:w-auto flex flex-col gap-3">
            <a href="/editarexercicios?aluno=<%= alunoSeguro.id_aluno || alunoSeguro.id || '' %>" class="bg-white text-primary px-6 py-4 rounded-full font-black text-center shadow-lg active:scale-95 transition-transform">
              Montar treino
            </a>

            <a href="/feedbackresposta?aluno=<%= alunoSeguro.id_aluno || alunoSeguro.id || '' %>" class="bg-white/15 text-white px-6 py-4 rounded-full font-black text-center border border-white/20 active:scale-95 transition-transform">
              Enviar resposta
            </a>
          </aside>
        </section>

        <b class="absolute -right-20 -bottom-20 w-96 h-96 bg-secondary opacity-10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        <b class="absolute -left-20 -top-20 w-64 h-64 bg-white opacity-5 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
      </article>

      <% if (typeof erro !== 'undefined' && erro) { %>
