<!DOCTYPE html>
<html class="light" lang="pt-BR">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />

  <title>PlanoB - Moderador</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            surface: "#f7f5ff",
            primary: "#0058ba",
            "primary-container": "#6c9fff",
            "primary-dim": "#004da4",
            "on-primary": "#f0f2ff",
            "on-surface": "#232c51",
            "on-surface-variant": "#505a81",
            "surface-container-lowest": "#ffffff",
            "surface-container-low": "#efefff",
            "surface-container": "#e4e7ff",
            "surface-container-high": "#dde1ff",
            "surface-container-highest": "#d5dbff",
            outline: "#6c759e",
            "outline-variant": "#a2abd7",
            "tertiary-fixed": "#ffd709",
            "on-tertiary-fixed": "#453900",
            secondary: "#00647b",
            error: "#b31b25"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"],
            label: ["Manrope"]
          }
        }
      }
    }
  </script>

  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    @media (max-width: 768px) {
      html,
      body {
        width: 100%;
        overflow-x: hidden;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 14px 135px !important;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      article.hero-admin {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.hero-admin h1 {
        font-size: 2rem !important;
        line-height: 1.1 !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }
    }
  </style>
</head>

<body class="bg-surface text-on-surface min-h-screen">

  <%
    const moderadorSeguro = typeof moderador !== 'undefined' && moderador ? moderador : {}
    const usuariosSeguros = typeof usuarios !== 'undefined' && usuarios ? usuarios : []
    const atividadesSeguras = typeof atividadesRecentes !== 'undefined' && atividadesRecentes ? atividadesRecentes : []
    const estatisticasSeguras = typeof estatisticas !== 'undefined' && estatisticas ? estatisticas : {}
    const filtrosSeguros = typeof filtros !== 'undefined' && filtros ? filtros : {}

    function moeda(valor) {
      return Number(valor || 0).toLocaleString('pt-BR', {
        style: 'currency',
        currency: 'BRL'
      })
    }

    function dataFormatada(valor) {
      if (!valor) return 'Sem registro'

      return new Date(valor).toLocaleDateString('pt-BR')
    }

    function tipoLabel(tipo) {
      return tipo === 'professor' ? 'Professor' : 'Aluno'
    }

    function badgePlanoClasse(plano) {
      if (plano === 'Diamante') return 'bg-tertiary-fixed text-on-tertiary-fixed'
      if (plano === 'Lazuli') return 'bg-primary text-white'
      if (plano === 'Professor') return 'bg-secondary text-white'
      return 'bg-surface-container-highest text-on-surface-variant'
    }
  %>

  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/85 backdrop-blur-xl flex justify-between items-center px-6 py-4">
    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <a href="/moderador" class="logo-font text-4xl text-primary no-underline">PlanoB</a>
      <p class="hidden md:block text-xs font-black uppercase tracking-widest text-on-surface-variant">
        Painel de Moderador
      </p>
    </nav>

    <menu class="flex items-center gap-4 p-0 m-0 list-none">
      <li>
        <a href="/moderador/exportar" class="hidden md:inline-flex items-center gap-2 rounded-full bg-primary text-white px-5 py-3 text-sm font-black active:scale-95 transition-transform">
          <i class="material-symbols-outlined not-italic" aria-hidden="true">download</i>
          Exportar
        </a>
      </li>

      <li>
        <a href="/logout" class="p-2 rounded-full hover:bg-red-50 transition-colors active:scale-95 inline-flex items-center justify-center" aria-label="Sair">
          <i class="material-symbols-outlined text-error not-italic" aria-hidden="true">logout</i>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <aside class="hidden md:flex h-screen w-72 fixed left-0 top-0 bg-[#efefff] flex-col gap-2 py-8 z-40 mt-16">
    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <% if (moderadorSeguro.foto) { %>
          <img class="w-12 h-12 rounded-full object-cover" src="<%= moderadorSeguro.foto %>" alt="Foto do moderador" />
        <% } else { %>
          <em class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden not-italic" aria-label="Moderador sem foto">
            <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">admin_panel_settings</i>
          </em>
        <% } %>

        <figcaption>
          <p class="text-sm font-bold text-on-surface">
            <%= moderadorSeguro.nome || 'Admin PlanoB' %>
          </p>
          <p class="text-xs text-on-surface-variant">
            <%= moderadorSeguro.nivel || 'Moderador Master' %>
          </p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="/moderador" aria-current="page">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">dashboard</i>
        <em class="not-italic">Painel</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/moderador?tipo=alunos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">group</i>
        <em class="not-italic">Alunos</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/moderador?tipo=professores">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">school</i>
        <em class="not-italic">Professores</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="#atividades">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">history</i>
        <em class="not-italic">Atividades</em>
      </a>
    </nav>

    <footer class="mt-auto px-4 pb-8 flex flex-col gap-3">
      <a href="/moderador/exportar" class="w-full bg-primary text-white rounded-full py-4 font-bold shadow-lg shadow-primary/30 flex items-center justify-center gap-2 active:scale-95 transition-transform">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">download</i>
        Exportar CSV
      </a>

      <a class="flex items-center gap-3 px-4 py-3 text-error hover:bg-red-50 rounded-full transition-colors text-sm" href="/logout">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i>
        <em class="not-italic">Sair</em>
      </a>
    </footer>
  </aside>

  <main class="md:ml-72 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <article class="hero-admin md:col-span-12 relative overflow-hidden rounded-3xl bg-primary p-8 md:p-12 text-white shadow-2xl">
        <section class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8">
          <hgroup class="max-w-3xl">
            <mark class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md text-xs font-bold uppercase tracking-widest mb-4 text-white">
              Gestão da Plataforma
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              COMUNIDADE PLANOB.
            </h1>

            <p class="text-lg opacity-90 max-w-2xl">
              Gerencie alunos, professores, cadastros, planos e atividades reais da plataforma.
            </p>
          </hgroup>

          <figure class="flex flex-col items-center gap-4 bg-white/10 backdrop-blur-xl p-6 md:p-8 rounded-3xl border border-white/10 w-full max-w-[240px] mx-auto md:mx-0 md:w-auto m-0">
            <em class="w-28 h-28 rounded-full bg-white/15 flex items-center justify-center not-italic">
              <i class="material-symbols-outlined text-white text-7xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">admin_panel_settings</i>
            </em>

            <figcaption class="text-sm font-black uppercase tracking-widest text-center">
              <%= usuariosSeguros.length %> usuários listados
            </figcaption>
          </figure>
        </section>

        <b class="absolute -right-20 -bottom-20 w-96 h-96 bg-secondary opacity-10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        <b class="absolute -left-20 -top-20 w-64 h-64 bg-white opacity-5 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
      </article>

      <% if (typeof sucesso !== 'undefined' && sucesso) { %>
        <section class="md:col-span-12 bg-green-50 text-green-700 rounded-3xl p-5 font-bold text-center" role="status">
          <%= sucesso %>
        </section>
      <% } %>

      <% if (typeof erro !== 'undefined' && erro) { %>
        <section class="md:col-span-12 bg-red-50 text-error rounded-3xl p-5 font-bold text-center" role="alert">
          <%= erro %>
        </section>
      <% } %>

      <section class="md:col-span-12 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">
        <article class="bg-surface-container-lowest p-6 rounded-3xl border-b-4 border-primary shadow-sm">
          <p class="text-sm font-bold text-on-surface-variant uppercase tracking-widest mb-4">Total Alunos</p>
          <h3 class="text-4xl font-black text-on-surface"><%= estatisticasSeguras.totalAlunos || 0 %></h3>
        </article>

        <article class="bg-surface-container-lowest p-6 rounded-3xl border-b-4 border-secondary shadow-sm">
          <p class="text-sm font-bold text-on-surface-variant uppercase tracking-widest mb-4">Professores</p>
          <h3 class="text-4xl font-black text-on-surface"><%= estatisticasSeguras.totalProfessores || 0 %></h3>
        </article>

        <article class="bg-surface-container-lowest p-6 rounded-3xl border-b-4 border-tertiary-fixed shadow-sm">
          <p class="text-sm font-bold text-on-surface-variant uppercase tracking-widest mb-4">Diamante</p>
          <h3 class="text-4xl font-black text-on-surface"><%= estatisticasSeguras.totalDiamante || 0 %></h3>
        </article>

        <article class="bg-primary text-white p-6 rounded-3xl shadow-xl shadow-primary/20">
          <p class="text-sm font-bold text-white/70 uppercase tracking-widest mb-4">Receita Mensal</p>
          <h3 class="text-3xl font-black italic"><%= moeda(estatisticasSeguras.receitaMensal || 0) %></h3>
        </article>
      </section>

      <section class="md:col-span-12 bg-surface-container-lowest rounded-3xl p-6 shadow-sm">
        <form action="/moderador" method="GET" class="flex flex-col xl:flex-row gap-4 xl:items-center justify-between">
          <fieldset class="flex flex-col sm:flex-row gap-3 flex-1">
            <legend class="sr-only">Filtros</legend>

            <label for="busca" class="sr-only">Buscar cadastro</label>

            <section class="relative flex-1">
              <i class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline not-italic" aria-hidden="true">search</i>

              <input
                id="busca"
                name="busca"
                type="search"
                value="<%= filtrosSeguros.busca || '' %>"
                placeholder="Buscar por nome, e-mail ou CREF..."
                class="w-full rounded-full border-none bg-surface-container-low px-12 py-4 text-sm focus:ring-2 focus:ring-primary"
              />
            </section>

            <label for="tipo" class="sr-only">Tipo</label>

            <select
              id="tipo"
              name="tipo"
              class="rounded-full border-none bg-surface-container-low px-6 py-4 text-sm font-bold text-on-surface focus:ring-2 focus:ring-primary"
            >
              <option value="todos" <%= filtrosSeguros.tipo === 'todos' ? 'selected' : '' %>>Todos</option>
              <option value="alunos" <%= filtrosSeguros.tipo === 'alunos' ? 'selected' : '' %>>Alunos</option>
              <option value="professores" <%= filtrosSeguros.tipo === 'professores' ? 'selected' : '' %>>Professores</option>
            </select>
          </fieldset>

          <menu class="flex flex-col sm:flex-row gap-3 p-0 m-0 list-none">
            <li>
              <button type="submit" class="w-full sm:w-auto bg-primary text-white px-6 py-4 rounded-full font-black active:scale-95 transition-transform">
                Pesquisar
              </button>
            </li>

            <li>
              <a href="/moderador/exportar" class="w-full sm:w-auto bg-on-surface text-white px-6 py-4 rounded-full font-black active:scale-95 transition-transform inline-flex justify-center items-center gap-2">
                <i class="material-symbols-outlined not-italic" aria-hidden="true">download</i>
                CSV
              </a>
            </li>
          </menu>
        </form>
      </section>

      <section class="md:col-span-12 bg-surface-container-lowest rounded-[2rem] shadow-sm overflow-hidden">
        <header class="p-6 flex flex-col md:flex-row md:items-center justify-between gap-3 bg-surface-container-low">
          <h2 class="text-2xl font-black headline text-on-surface">Cadastros encontrados</h2>

          <p class="text-sm font-bold text-on-surface-variant">
            <%= usuariosSeguros.length %> resultado(s)
          </p>
        </header>

        <section class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-surface-container/50">
                <th class="px-6 py-5 text-xs font-black uppercase tracking-widest text-on-surface-variant">Usuário</th>
                <th class="px-6 py-5 text-xs font-black uppercase tracking-widest text-on-surface-variant">Tipo</th>
                <th class="px-6 py-5 text-xs font-black uppercase tracking-widest text-on-surface-variant">Plano/Cargo</th>
                <th class="px-6 py-5 text-xs font-black uppercase tracking-widest text-on-surface-variant">Atividades</th>
                <th class="px-6 py-5 text-xs font-black uppercase tracking-widest text-on-surface-variant">Última atividade</th>
                <th class="px-6 py-5 text-xs font-black uppercase tracking-widest text-on-surface-variant text-right">Ações</th>
              </tr>
            </thead>

            <tbody class="divide-y divide-surface-container-low">
              <% if (usuariosSeguros.length > 0) { %>
                <% usuariosSeguros.forEach(function(usuario) { %>
                  <tr class="hover:bg-primary/5 transition-colors group">
                    <td class="px-6 py-4">
                      <article class="flex items-center gap-4">
                        <% if (usuario.foto_perfil) { %>
                          <img class="w-12 h-12 rounded-2xl object-cover" src="<%= usuario.foto_perfil %>" alt="Foto de <%= usuario.nome %>" />
                        <% } else { %>
                          <em class="w-12 h-12 rounded-2xl avatar-placeholder flex items-center justify-center overflow-hidden not-italic">
                            <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">
                              <%= usuario.tipo_usuario === 'professor' ? 'school' : 'account_circle' %>
                            </i>
                          </em>
                        <% } %>

                        <section>
                          <p class="font-black text-on-surface group-hover:text-primary transition-colors">
                            <%= usuario.nome %>
                          </p>

                          <p class="text-xs text-on-surface-variant">
                            <%= usuario.email %>
                          </p>
                        </section>
                      </article>
                    </td>

                    <td class="px-6 py-4">
                      <strong class="text-sm font-bold <%= usuario.tipo_usuario === 'professor' ? 'text-primary' : 'text-on-surface' %>">
                        <%= tipoLabel(usuario.tipo_usuario) %>
                      </strong>
                    </td>

                    <td class="px-6 py-4">
                      <strong class="px-4 py-1 rounded-full font-bold text-xs inline-flex items-center gap-1 w-fit <%= badgePlanoClasse(usuario.plano) %>">
                        <% if (usuario.plano === 'Diamante') { %>
                          <i class="material-symbols-outlined text-xs not-italic" aria-hidden="true" style="font-variation-settings:'FILL' 1">diamond</i>
                        <% } else if (usuario.plano === 'Lazuli') { %>
                          <i class="material-symbols-outlined text-xs not-italic" aria-hidden="true">star</i>
                        <% } else if (usuario.plano === 'Professor') { %>
                          <i class="material-symbols-outlined text-xs not-italic" aria-hidden="true">school</i>
                        <% } %>

                        <%= usuario.plano %>
                      </strong>
                    </td>

                    <td class="px-6 py-4">
                      <strong class="text-sm text-on-surface">
                        <%= usuario.total_atividades || 0 %>
                      </strong>
                    </td>

                    <td class="px-6 py-4">
                      <p class="text-sm text-on-surface-variant">
                        <%= dataFormatada(usuario.ultima_atividade || usuario.criado_em) %>
                      </p>
                    </td>

                    <td class="px-6 py-4 text-right">
                      <form
                        action="/moderador/excluir/<%= usuario.tipo_usuario %>/<%= usuario.id %>"
                        method="POST"
                        onsubmit="return confirm('Tem certeza que deseja excluir este cadastro definitivamente do banco de dados? Essa ação não pode ser desfeita.')"
                      >
                        <button type="submit" class="p-3 text-error hover:bg-red-50 rounded-full transition-colors" aria-label="Excluir cadastro">
                          <i class="material-symbols-outlined not-italic" aria-hidden="true">delete</i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="px-6 py-12 text-center">
                    <i class="material-symbols-outlined text-primary text-5xl not-italic mb-3" aria-hidden="true">search_off</i>
                    <p class="font-black text-on-surface">Nenhum cadastro encontrado</p>
                    <p class="text-sm text-on-surface-variant mt-1">Tente mudar a busca ou o filtro.</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </section>
      </section>

      <section id="atividades" class="md:col-span-8">
        <header class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-black headline text-on-surface">Atividades Recentes</h2>
        </header>

        <section class="space-y-4">
          <% if (atividadesSeguras.length > 0) { %>
            <% atividadesSeguras.forEach(function(atividade) { %>
              <article class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border-l-4 <%= atividade.tipo === 'cadastro_professor' ? 'border-secondary' : 'border-primary' %>">
                <figure class="w-10 h-10 rounded-full <%= atividade.tipo === 'cadastro_professor' ? 'bg-secondary/10 text-secondary' : 'bg-primary/10 text-primary' %> flex items-center justify-center m-0">
                  <i aria-hidden="true" class="material-symbols-outlined not-italic">
                    <%= atividade.tipo === 'cadastro_professor' ? 'school' : 'person_add' %>
                  </i>
                </figure>

                <section class="flex-1">
                  <p class="text-sm text-on-surface font-bold">
                    <% if (atividade.tipo === 'cadastro_professor') { %>
                      Professor cadastrado:
                    <% } else { %>
                      Aluno cadastrado:
                    <% } %>

                    <strong class="text-primary italic"><%= atividade.nome %></strong>
                  </p>

                  <p class="text-xs text-on-surface-variant">
                    <%= atividade.detalhe %> • <%= dataFormatada(atividade.data_evento) %>
                  </p>
                </section>
              </article>
            <% }) %>
          <% } else { %>
            <article class="bg-white p-8 rounded-3xl text-center shadow-sm">
              <p class="font-bold text-on-surface">Nenhuma atividade recente encontrada.</p>
            </article>
          <% } %>
        </section>
      </section>

      <aside class="md:col-span-4 bg-gradient-to-br from-primary-dim to-primary p-8 rounded-[2.5rem] text-white relative overflow-hidden shadow-2xl">
        <section class="relative z-10">
          <h2 class="text-2xl font-black headline mb-4">Resumo da plataforma</h2>

          <p class="text-white/80 text-sm mb-6 leading-relaxed">
            Os números são carregados diretamente do banco de dados do PlanoB.
          </p>

          <ul class="grid grid-cols-1 gap-3 list-none p-0 m-0">
            <li class="bg-white/15 rounded-2xl p-4">
              <p class="text-xs font-black uppercase text-white/60">Usuários totais</p>
              <strong class="text-3xl"><%= (estatisticasSeguras.totalAlunos || 0) + (estatisticasSeguras.totalProfessores || 0) %></strong>
            </li>

            <li class="bg-white/15 rounded-2xl p-4">
              <p class="text-xs font-black uppercase text-white/60">Diamante</p>
              <strong class="text-3xl"><%= estatisticasSeguras.totalDiamante || 0 %></strong>
            </li>

            <li class="bg-white/15 rounded-2xl p-4">
              <p class="text-xs font-black uppercase text-white/60">Receita mês</p>
              <strong class="text-2xl"><%= moeda(estatisticasSeguras.receitaMensal || 0) %></strong>
            </li>
          </ul>
        </section>

        <b class="absolute -bottom-10 -right-10 w-40 h-40 bg-white/10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
      </aside>

    </section>
  </main>

