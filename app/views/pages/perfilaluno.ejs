<style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
    }
    .logo-font { font-family: 'Baumans', sans-serif !important; letter-spacing: 0.02em; }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }
    body { font-family: 'Manrope', sans-serif; background-color: #f7f5ff; }
    h1, h2, h3, h4, h5, h6 { font-family: 'Lexend', sans-serif; }
    .kinetic-gradient { background: linear-gradient(135deg, #0058ba 0%, #6c9fff 100%); }

    @media (max-width: 768px) {
      main { margin-left: 0 !important; padding: 80px 16px 120px !important; }
      aside.sidebar { display: none !important; }
      header.topbar { left: 0 !important; width: 100% !important; }
    }
  
    /* Ajustes gerais de responsividade */
    img, video { max-width: 100%; height: auto; }
    a, button { -webkit-tap-highlight-color: transparent; }
    @media (max-width: 768px) {
      body { overflow-x: hidden; }
      main { max-width: 100%; }
      .hide-mobile { display: none !important; }
    }
</style>
</head>
<body class="bg-surface text-on-surface">
<!-- Sidebar (desktop only) -->
<aside class="sidebar fixed left-0 top-0 h-screen w-64 z-40 bg-surface flex flex-col py-8 px-4 border-r border-surface-container">
<header class="mb-10 px-2">
<strong class="logo-font text-2xl text-primary block" style="font-size:1.6rem;">PlanoB</strong>
<p class="text-xs font-headline font-bold tracking-tight text-on-surface opacity-60 mt-1">Área do Aluno</p>
</header>
<nav aria-label="Menu lateral do aluno" class="flex-grow space-y-2">
<a class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors duration-200 text-on-surface opacity-70 hover:bg-surface-container-highest hover:opacity-100" href="painelfree">
<i class="material-symbols-outlined not-italic">fitness_center</i>
<strong class="font-bold">Treinos</strong>
</a>
<a class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors duration-200 text-on-surface opacity-70 hover:bg-surface-container-highest hover:opacity-100" href="pagamento">
<i class="material-symbols-outlined not-italic">payments</i>
<strong class="font-bold">Planos</strong>
</a>
<a class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors duration-200 text-on-surface opacity-70 hover:bg-surface-container-highest hover:opacity-100" href="feedbackaluno">
<i class="material-symbols-outlined not-italic">forum</i>
<strong class="font-bold">Feedbacks</strong>
</a>
<a class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors duration-200 text-on-surface opacity-70 hover:bg-surface-container-highest hover:opacity-100" href="suporte">
<i class="material-symbols-outlined not-italic">support_agent</i>
<strong class="font-bold">Suporte</strong>
</a>
<a aria-current="page" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors duration-200 text-primary font-bold border-r-4 border-primary bg-surface-container/50" href="perfilaluno">
<i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1;">person</i>
<strong class="font-bold">Perfil</strong>
</a>
</nav>
<footer class="mt-auto pt-6 border-t border-surface-container-high px-2">
<figure class="flex items-center gap-3 m-0">
<img alt="Foto do aluno" class="w-10 h-10 rounded-full object-cover" src="https://placeholder.pics/svg/300"/>
<figcaption>
<p class="text-sm font-bold">&lt;%= typeof aluno !== 'undefined' ? aluno.nome : 'Aluno' %&gt;</p>
<p class="text-xs opacity-60">Plano Ativo</p>
</figcaption>
</figure>
</footer>
</aside>
<!-- Top App Bar -->
<header class="topbar fixed top-0 right-0 w-[calc(100%-16rem)] h-20 z-30 bg-surface/80 backdrop-blur-xl flex justify-between items-center px-8 border-b border-surface-container">
<h1 class="font-headline font-black text-xl text-primary">Meu Perfil</h1>
<menu class="flex items-center gap-4 m-0 p-0 list-none">
<li class="relative">
<a aria-label="Notificações" class="material-symbols-outlined not-italic text-on-surface-variant hover:bg-surface-container rounded-full p-2 transition-all" href="suporte">notifications</a>
<strong aria-hidden="true" class="absolute top-2 right-2 w-2 h-2 bg-error rounded-full"></strong>
</li>
<li>
<a aria-label="Ajuda" class="material-symbols-outlined not-italic text-on-surface-variant hover:bg-surface-container rounded-full p-2 transition-all" href="suporte">help</a>
</li>
</menu>
</header>
<!-- Main Content -->
<main class="ml-64 pt-24 p-8 min-h-screen">
<!-- Profile Header -->
<section aria-labelledby="perfil-heading" class="grid grid-cols-12 gap-8 mb-12">
<article class="col-span-12 lg:col-span-8 bg-surface-container-lowest rounded-[2rem] p-8 relative overflow-hidden flex flex-col md:flex-row gap-8 items-center md:items-start shadow-[0_12px_40px_rgba(35,44,81,0.05)]">
<figure class="relative z-10 w-40 h-40 flex-shrink-0 m-0">
<img alt="Foto do aluno" class="w-full h-full rounded-[2rem] object-cover" src="https://placeholder.pics/svg/300"/>
<figcaption class="absolute -bottom-2 -right-2 bg-tertiary-fixed text-on-tertiary-fixed font-black px-4 py-1 rounded-full text-xs tracking-widest uppercase">
            &lt;%= typeof aluno !== 'undefined' &amp;&amp; aluno.plano ? aluno.plano : 'FREE' %&gt;
          </figcaption>
</figure>
<section class="relative z-10 flex flex-col justify-center">
<p class="text-primary font-bold text-sm tracking-widest uppercase mb-2">Aluno Ativo</p>
<h2 class="font-headline font-black text-4xl md:text-5xl text-on-surface mb-4 leading-tight" id="perfil-heading">
            &lt;%= typeof aluno !== 'undefined' ? aluno.nome : 'Nome do Aluno' %&gt;
          </h2>
<ul class="flex flex-wrap gap-4 list-none m-0 p-0">
<li class="bg-surface-container px-4 py-2 rounded-full text-sm font-bold flex items-center gap-2">
<i class="material-symbols-outlined text-primary text-lg not-italic">calendar_today</i>
              Aluno PlanoB
            </li>
<li class="bg-surface-container px-4 py-2 rounded-full text-sm font-bold flex items-center gap-2">
<i class="material-symbols-outlined text-primary text-lg not-italic">fitness_center</i>
              Academia em Casa
            </li>
</ul>
</section>
<strong aria-hidden="true" class="absolute top-[-20%] right-[-10%] w-64 h-64 kinetic-gradient opacity-10 rounded-full blur-3xl pointer-events-none"></strong>
</article>
<aside class="col-span-12 lg:col-span-4 kinetic-gradient rounded-[2rem] p-8 flex flex-col justify-between text-on-primary shadow-[0_20px_50px_rgba(0,88,186,0.3)]">
<header>
<h3 class="font-headline font-bold text-xl mb-1">Próximo Treino</h3>
<p class="opacity-80 text-sm mb-6">Continue sua evolução</p>
</header>
<section class="space-y-4">
<p class="flex items-center justify-between">
<strong class="font-medium opacity-90">Progresso do Plano</strong>
<strong class="font-black">75%</strong>
</p>
<meter class="w-full h-3 rounded-full overflow-hidden block" max="100" min="0" style="appearance:none;" value="75">
<section class="h-full bg-white w-3/4 rounded-full"></section>
</meter>
</section>
<a class="mt-8 bg-white text-primary font-bold py-4 rounded-full flex items-center justify-center gap-2 transition-transform active:scale-95 hover:opacity-90" href="painelfree">
          Iniciar Treino Agora
          <i class="material-symbols-outlined not-italic">play_arrow</i>
</a>
</aside>
</section>
<!-- Metrics Grid -->
<section aria-label="Métricas do aluno" class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
<article class="bg-surface-container-low p-8 rounded-[2rem] border-b-4 border-primary/20 transition-all hover:-translate-y-1">
<header class="flex items-center gap-4 mb-4">
<figure class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center m-0">
<i class="material-symbols-outlined text-primary not-italic">analytics</i>
</figure>
<h4 class="font-bold text-on-surface-variant">Frequência Semanal</h4>
</header>
<p class="flex items-baseline gap-2">
<strong class="font-headline font-black text-4xl">4.2</strong>
<strong class="text-on-surface-variant/60 font-medium">dias/sem</strong>
</p>
<p class="text-xs text-secondary font-bold mt-2 flex items-center gap-1">
<i class="material-symbols-outlined text-sm not-italic">trending_up</i>
          +12% que o mês passado
        </p>
</article>
<article class="bg-surface-container-low p-8 rounded-[2rem] border-b-4 border-secondary/20 transition-all hover:-translate-y-1">
<header class="flex items-center gap-4 mb-4">
<figure class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center m-0">
<i class="material-symbols-outlined text-secondary not-italic">timer</i>
</figure>
<h4 class="font-bold text-on-surface-variant">Tempo de Treino</h4>
</header>
<p class="flex items-baseline gap-2">
<strong class="font-headline font-black text-4xl">58</strong>
<strong class="text-on-surface-variant/60 font-medium">min/méd</strong>
</p>
<p class="text-xs text-on-surface-variant/60 font-medium mt-2">Meta: 60 min</p>
</article>
<article class="bg-surface-container-low p-8 rounded-[2rem] border-b-4 border-tertiary-fixed/40 transition-all hover:-translate-y-1">
<header class="flex items-center gap-4 mb-4">
<figure class="w-12 h-12 rounded-full bg-tertiary-fixed/20 flex items-center justify-center m-0">
<i class="material-symbols-outlined text-on-tertiary-fixed not-italic">star</i>
</figure>
<h4 class="font-bold text-on-surface-variant">Média de Feedback</h4>
</header>
<p class="flex items-baseline gap-2">
<strong class="font-headline font-black text-4xl">4.9</strong>
<strong class="text-on-surface-variant/60 font-medium">/ 5.0</strong>
</p>
<p class="text-xs text-on-surface-variant/60 font-medium mt-2">Excelentes resultados técnicos</p>
</article>
</section>
<!-- Activity History -->
<section aria-labelledby="historico-heading">
<header class="flex items-center justify-between mb-6">
<h3 class="font-headline font-black text-2xl" id="historico-heading">Histórico de Atividades</h3>
<a class="text-primary font-bold text-sm hover:underline" href="feedbackaluno">Ver tudo</a>
</header>
<ul class="space-y-4 list-none m-0 p-0">
