</section>
<aside class="text-right">
<p class="flex items-center gap-1 text-tertiary font-bold mb-1">
<i class="material-symbols-outlined text-sm not-italic" style="font-variation-settings:'FILL' 1;">star</i>
              5.0
            </p>
<mark class="text-xs font-bold bg-primary/10 text-primary px-3 py-1 rounded-full uppercase" style="background-color:rgba(0,88,186,0.1);">Concluído</mark>
</aside>
</li>
<li class="bg-surface-container-lowest p-6 rounded-3xl flex items-center gap-6 hover:bg-white transition-all shadow-sm">
<figure class="w-16 h-16 rounded-2xl overflow-hidden flex-shrink-0 m-0">
<img alt="Treino Lower Body" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida/ADBb0uiHf5yBD1OtKZ9OibcAsInnQ1_NNKuUhYAmFcYvCXtQ7kcxe66WxUnMm_cuFd8qMGr4HJDRpVBpLsfrHZp3rzbRG4-_HeMBdRDoWx-un5VAnQzs0G6VtKIuuG4UMH0lgywkJ4DdMHh1e4DX8pserETt8ZXvJfsTQUAbKV5k9CvVm9iWis8P97a-IHNhE-Yhk-nR8PTnrmkh9QWjv8bcmtIKSTrLUrJXyGelaeS0dCKfEdX9FwLC84GP4--8"/>
</figure>
<section class="flex-grow">
<h5 class="font-bold text-lg">Lower Body (Foco Quadríceps)</h5>
<p class="text-sm text-on-surface-variant/70">Terça-feira às 07:15 • Prof. Ricardo</p>
</section>
<aside class="text-right">
<p class="flex items-center gap-1 text-tertiary font-bold mb-1">
<i class="material-symbols-outlined text-sm not-italic" style="font-variation-settings:'FILL' 1;">star</i>
              4.8
            </p>
<mark class="text-xs font-bold bg-primary/10 text-primary px-3 py-1 rounded-full uppercase" style="background-color:rgba(0,88,186,0.1);">Concluído</mark>
</aside>
</li>
<li class="bg-surface-container-lowest p-6 rounded-3xl flex items-center gap-6 hover:bg-white transition-all shadow-sm">
<figure class="w-16 h-16 rounded-2xl overflow-hidden flex-shrink-0 m-0">
<img alt="Treino HIIT" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida/ADBb0ujvMAT4XdA4ZcgBZqm82NeZJujKLdnQNiO1WcZSPVs_7nqyOai0Scy-CdEGNwQETsrdUyKyvYWJEEDZXQzgKtOt31Z3YtxMX3z916Jg25Z20ekq5yvGJOypCHjho_Hr4Hs8lk7AWRgOtDKaqy12faAG_iYUhgpypJjhiOf9Cvsj7oK090GcP1OzTram5WbsM0uXs85P6b_TVXHJKmegTnydm3PsxGjszHROMW7fkH5AEXBC8zFILnbNavE"/>
</figure>
<section class="flex-grow">
<h5 class="font-bold text-lg">HIIT Cardiovascular</h5>
<p class="text-sm text-on-surface-variant/70">Segunda-feira às 19:00 • Prof. Ricardo</p>
</section>
<aside class="text-right">
<p class="flex items-center gap-1 text-tertiary font-bold mb-1">
<i class="material-symbols-outlined text-sm not-italic" style="font-variation-settings:'FILL' 1;">star</i>
              5.0
            </p>
<mark class="text-xs font-bold bg-primary/10 text-primary px-3 py-1 rounded-full uppercase" style="background-color:rgba(0,88,186,0.1);">Concluído</mark>
</aside>
</li>
</ul>
</section>
</main>
<!-- Mobile Bottom Nav -->
<nav aria-label="Navegação mobile" class="md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-2 bg-[#f7f5ff]/90 backdrop-blur-lg shadow-[0_-10px_40px_rgba(35,44,81,0.08)] rounded-t-[32px]">
<a class="mobile-link flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity" data-page="painelfree" href="painelfree">
<i class="material-symbols-outlined not-italic">fitness_center</i>
<em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Treinos</em>
</a>
<a class="mobile-link flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity" data-page="pagamento" href="pagamento">
<i class="material-symbols-outlined not-italic">payments</i>
<em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Planos</em>
</a>
<a class="mobile-link flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity" data-page="feedbackaluno" href="feedbackaluno">
<i class="material-symbols-outlined not-italic">forum</i>
<em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Feedback</em>
</a>
<a aria-current="page" class="mobile-link flex flex-col items-center justify-center text-[#0058ba] opacity-100 p-3" data-page="perfilaluno" href="perfilaluno">
<i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1;">person</i>
<em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Perfil</em>
</a>
</nav>
<script>
    const paginaAtual = window.location.pathname.split("/").pop().replace(".html", "");
    document.querySelectorAll(".mobile-link").forEach(link => {
      if (link.dataset.page === paginaAtual || paginaAtual === "" && link.dataset.page === "painelfree") {
        link.classList.remove("opacity-60");
        link.classList.add("opacity-100", "text-[#0058ba]");
        link.setAttribute("aria-current", "page");
      }
    });
  </script>
</body>
</html>
