  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .logo-header {
      font-size: 2.7rem;
      line-height: 1;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    h4,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.65);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    .avatar-placeholder .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    @media (max-width: 768px) {
      html,
      body {
        width: 100%;
        overflow-x: hidden;
      }

      body {
        background: #f7f5ff;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      header.fixed a.logo-header {
        font-size: 1.45rem;
        line-height: 1;
      }

      header.fixed menu {
        gap: 8px;
      }

      header.fixed button,
      header.fixed a {
        padding: 8px;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 16px 135px !important;
      }

      main section.max-w-6xl {
        gap: 18px;
      }

      article.profile-hero {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.profile-hero > section {
        align-items: flex-start !important;
        gap: 26px !important;
      }

      article.profile-hero h1 {
        font-size: 2rem !important;
        line-height: 1.1 !important;
      }

      article.profile-hero p {
        font-size: 0.95rem !important;
      }

      article.profile-hero figure {
        width: 132px !important;
        height: 132px !important;
        margin: 0 auto !important;
      }

      section.profile-card,
      section.metrics-card,
      section.training-data-card,
      article.activity-card {
        padding: 22px !important;
        border-radius: 26px !important;
      }

      section.profile-card h2,
      section.metrics-card h2,
      section.training-data-card h2 {
        font-size: 1.35rem !important;
      }

      section.metrics-grid article {
        padding: 24px !important;
        border-radius: 26px !important;
      }

      article.activity-card li {
        align-items: flex-start !important;
        gap: 14px !important;
      }

      article.activity-card figure {
        width: 58px !important;
        height: 58px !important;
      }

      article.activity-card h3 {
        font-size: 0.95rem !important;
        line-height: 1.2;
      }

      article.activity-card p {
        font-size: 0.72rem !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 58px;
        border-radius: 18px;
      }

      nav[aria-label="Navegação mobile"] a[aria-current="page"] {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
      }

      nav[aria-label="Navegação mobile"] a:hover {
        color: #0058ba !important;
        opacity: 1 !important;
      }
    }

    @media (max-width: 420px) {
      main {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }

      article.profile-hero h1 {
        font-size: 1.75rem !important;
      }

      article.profile-hero figure {
        width: 118px !important;
        height: 118px !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding-left: 4px !important;
        padding-right: 4px !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 52px;
        padding: 10px 4px !important;
      }

      nav[aria-label="Navegação mobile"] em {
        font-size: 8px !important;
      }
    }
  </style>
</head>

<body class="bg-surface text-on-surface">

  <%
    const planoAluno = typeof aluno !== 'undefined' && aluno.id_plano ? Number(aluno.id_plano) : 1
    const alunoPago = planoAluno >= 2

    const painelCorreto = typeof linkPainelAluno !== 'undefined'
      ? linkPainelAluno
      : planoAluno === 3
        ? '/paineldiamante'
        : planoAluno === 2
          ? '/painellazuli'
          : '/painelfree'

    const videosCorreto = typeof linkVideosAluno !== 'undefined'
      ? linkVideosAluno
      : alunoPago
        ? '/videos'
        : '/videosfree'

    const nomePlanoAluno = planoAluno === 3
      ? 'Diamante'
      : planoAluno === 2
        ? 'Lazuli'
        : 'Free'

    const alunoSeguro = typeof aluno !== 'undefined' && aluno ? aluno : {}
    const nomeAluno = alunoSeguro.nome ? alunoSeguro.nome.split(' ')[0] : 'Aluno'

    const dadosTreino = typeof dadosAluno !== 'undefined' && dadosAluno ? dadosAluno : {}

    const mapaObjetivo = {
      hipertrofia: 'Hipertrofia',
      emagrecimento: 'Emagrecimento',
      forca: 'Força',
      condicionamento: 'Condicionamento'
    }

    const mapaTipoTreino = {
      musculacao: 'Musculação',
      calistenia: 'Calistenia',
      cardio: 'Cardio',
      misto: 'Misto'
    }

    const mapaNivel = {
      iniciante: 'Iniciante',
      intermediario: 'Intermediário',
      avancado: 'Avançado'
    }

    const mapaLocal = {
      casa: 'Casa',
      academia: 'Academia',
      ar_livre: 'Ar livre'
    }

    const mapaEquipamentos = {
      nenhum: 'Nenhum',
      halteres: 'Halteres',
      elasticos: 'Elásticos',
      barra: 'Barra',
      maquinas: 'Máquinas',
      esteira: 'Esteira',
      bicicleta: 'Bicicleta',
      colchonete: 'Colchonete'
    }

    const equipamentosArray = dadosTreino.equipamentos
      ? dadosTreino.equipamentos.split(',').filter(Boolean)
      : []

    const equipamentosFormatados = equipamentosArray.length > 0
      ? equipamentosArray.map(function(item) {
          return mapaEquipamentos[item] || item
        }).join(', ')
      : 'Não informado'

    const dadosForamPreenchidos = Number(dadosTreino.dados_completos) === 1
  %>

  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">
    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <a href="<%= painelCorreto %>" class="font-headline logo-font logo-header text-primary no-underline">PlanoB</a>
    </nav>

    <menu class="flex items-center gap-4 p-0 m-0 list-none">
      <li>

      </li>

      <li>
        <a href="/perfilaluno"
           class="p-2 rounded-full bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center"
           aria-label="Perfil"
           aria-current="page">
          <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24">account_circle</i>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] dark:bg-[#12141c] flex-col gap-2 py-8 z-40 mt-16">

    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <picture>
          <% if (alunoSeguro.foto) { %>
            <img
              class="w-12 h-12 rounded-full object-cover"
              src="<%= alunoSeguro.foto %>"
              alt="Foto de perfil do aluno"
            />
          <% } else { %>
            <em class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden not-italic" aria-label="Aluno sem foto">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </em>
          <% } %>
        </picture>

        <figcaption>
          <p class="text-sm font-bold text-on-surface">
            <%= nomeAluno %>
          </p>
          <p class="text-xs text-on-surface-variant">
            Plano <%= nomePlanoAluno %> ativo
          </p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="<%= painelCorreto %>">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">fitness_center</i>
        <em class="not-italic">Início</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="<%= videosCorreto %>">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">play_circle</i>
        <em class="not-italic">Vídeos</em>
      </a>

      <% if (alunoPago) { %>
        <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/progressosemanal">
          <i class="material-symbols-outlined not-italic" aria-hidden="true">monitoring</i>
          <em class="not-italic">Progresso</em>
        </a>

        <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/feedbackaluno">
          <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
          <em class="not-italic">Feedback</em>
        </a>
      <% } else { %>
        <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="<%= painelCorreto %>#planos">
          <i class="material-symbols-outlined not-italic" aria-hidden="true">payments</i>
          <em class="not-italic">Planos</em>
        </a>
      <% } %>

      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="/perfilaluno" aria-current="page">
        <i class="material-symbols-outlined not-italic" aria-hidden="true" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24">person</i>
        <em class="not-italic">Perfil</em>
      </a>

            <br><br><br><br><br>
          <footer class="mt-auto px-4 pb-8 flex flex-col gap-2">
      <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:text-error rounded-full hover:bg-surface-container transition-colors text-sm" href="/logout">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i>
        <em class="not-italic">Sair</em>
      </a>
    </footer>
    </nav>

  </aside>

  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <article class="profile-hero md:col-span-12 relative overflow-hidden rounded-3xl bg-primary p-8 md:p-12 text-white shadow-2xl">

        <section class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">

          <hgroup class="max-w-2xl">
            <mark class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md text-xs font-bold uppercase tracking-widest mb-4 text-white">
              Perfil do Aluno
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              OLÁ, <%= alunoSeguro.nome ? alunoSeguro.nome.split(' ')[0].toUpperCase() : 'ALUNO' %>.
            </h1>

            <p class="text-lg opacity-90 max-w-xl">
              Acompanhe suas informações, evolução e histórico de exercícios dentro do PlanoB.
            </p>
          </hgroup>

          <figure class="relative w-40 h-40 md:w-44 md:h-44 rounded-[2rem] bg-white/10 backdrop-blur-xl border border-white/10 p-3 m-0 group">
            <% if (alunoSeguro.foto) { %>
              <img
                class="w-full h-full rounded-[1.5rem] object-cover"
                src="<%= alunoSeguro.foto %>"
                alt="Foto do aluno"
              />
            <% } else { %>
              <em class="w-full h-full rounded-[1.5rem] avatar-placeholder flex items-center justify-center overflow-hidden not-italic" aria-label="Aluno sem foto">
                <i class="material-symbols-outlined text-[7rem] md:text-[8rem] not-italic" aria-hidden="true">account_circle</i>
              </em>
            <% } %>

            <form action="/perfilaluno/foto" method="POST" enctype="multipart/form-data">
              <label
                for="foto-perfil-hero"
                class="absolute inset-3 rounded-[1.5rem] bg-black/0 group-hover:bg-black/35 flex items-center justify-center cursor-pointer transition-all"
                aria-label="Alterar foto de perfil"
              >
                <strong class="opacity-0 group-hover:opacity-100 bg-white text-primary px-4 py-2 rounded-full font-black text-xs flex items-center gap-2 shadow-xl transition-opacity">
                  <i class="material-symbols-outlined text-lg not-italic" aria-hidden="true">photo_camera</i>
                  Alterar foto
                </strong>
              </label>

              <input
                id="foto-perfil-hero"
                name="foto_perfil"
                type="file"
                accept="image/png,image/jpeg,image/webp"
                class="hidden"
                onchange="this.form.submit()"
              />
            </form>

            <figcaption class="absolute -bottom-3 left-1/2 -translate-x-1/2 bg-tertiary-fixed text-on-tertiary-fixed font-black px-4 py-1 rounded-full text-xs tracking-widest uppercase shadow-lg">
              <%= nomePlanoAluno %>
            </figcaption>
          </figure>

        </section>

        <b class="absolute -right-20 -bottom-20 w-96 h-96 bg-secondary-fixed opacity-10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        <b class="absolute -left-20 -top-20 w-64 h-64 bg-white opacity-5 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
      </article>

      <% if (typeof sucesso !== 'undefined' && sucesso) { %>
        <section class="md:col-span-12 bg-green-50 text-green-700 rounded-3xl p-5 font-bold text-center" role="status">
          <%= sucesso %>
        </section>
      <% } %>

      <% if (typeof erroPerfil !== 'undefined' && erroPerfil) { %>
        <section class="md:col-span-12 bg-red-50 text-error rounded-3xl p-5 font-bold text-center" role="alert">
          <%= erroPerfil %>
        </section>
      <% } %>

      <section class="profile-card md:col-span-5 bg-surface-container-lowest rounded-3xl p-8 shadow-sm flex flex-col gap-6">

        <header class="flex items-center justify-between">
          <h2 class="text-2xl font-extrabold headline text-on-surface">Dados do Perfil</h2>
          <i class="material-symbols-outlined text-primary text-3xl not-italic" aria-hidden="true">account_circle</i>
        </header>

        <ul class="flex flex-col gap-4 list-none p-0 m-0">
          <li class="bg-surface-container-low rounded-2xl p-4">
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">Nome</p>
            <p class="font-bold text-on-surface">
              <%= alunoSeguro.nome || 'Aluno' %>
            </p>
          </li>

          <li class="bg-surface-container-low rounded-2xl p-4">
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">E-mail</p>
            <p class="font-bold text-on-surface break-all">
              <%= alunoSeguro.email || 'email@exemplo.com' %>
            </p>
          </li>

          <li class="bg-surface-container-low rounded-2xl p-4">
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">Plano atual</p>
            <p class="font-bold text-primary"><%= nomePlanoAluno %></p>
          </li>
        </ul>

        <details class="bg-surface-container-low rounded-3xl p-4 group">
          <summary class="cursor-pointer list-none flex items-center justify-between gap-3 font-black text-primary">
            <strong>Alterar dados do perfil</strong>
            <i class="material-symbols-outlined not-italic transition-transform group-open:rotate-180" aria-hidden="true">expand_more</i>
          </summary>

          <section class="mt-5 flex flex-col gap-6">

            <form action="/perfilaluno/dados" method="POST" class="flex flex-col gap-4">
              <fieldset class="flex flex-col gap-2">
                <legend class="sr-only">Alterar nome e e-mail</legend>

                <label for="nome-perfil" class="text-xs font-black uppercase tracking-widest text-on-surface-variant">
                  Nome
                </label>

                <input
                  id="nome-perfil"
                  name="nome"
                  type="text"
                  value="<%= alunoSeguro.nome || '' %>"
                  class="w-full rounded-2xl border-none bg-surface-container-lowest px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary"
                  required
                />

                <label for="email-perfil" class="text-xs font-black uppercase tracking-widest text-on-surface-variant mt-2">
                  E-mail
                </label>

                <input
                  id="email-perfil"
                  name="email"
                  type="email"
                  value="<%= alunoSeguro.email || '' %>"
                  class="w-full rounded-2xl border-none bg-surface-container-lowest px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary"
                  required
                />
              </fieldset>

              <button
                type="submit"
                class="w-full bg-primary text-white py-4 rounded-full font-bold shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all text-center">
                Salvar nome e e-mail
              </button>
            </form>

          </section>
        </details>

        <a href="<%= painelCorreto %>" class="w-full bg-primary text-white py-4 rounded-full font-bold shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all text-center">
          Voltar aos Treinos
        </a>

        <a href="/logout"
          class="w-full bg-error text-white py-4 rounded-full font-bold shadow-lg shadow-error/20 hover:scale-[1.02] active:scale-95 transition-all text-center flex items-center justify-center gap-2">
          <i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i>
          Sair da conta
        </a>

      </section>

      <section class="metrics-card md:col-span-7 bg-surface-container-low rounded-3xl p-8 flex flex-col gap-6">

        <header class="flex items-center justify-between">
          <h2 class="text-2xl font-extrabold headline text-on-surface">Resumo dos Treinos</h2>

          <mark class="px-3 py-1 bg-surface-container-highest rounded-full text-[10px] font-bold uppercase text-on-surface-variant">
            Atualizado
          </mark>
        </header>

        <section class="metrics-grid grid grid-cols-1 sm:grid-cols-3 gap-4">

          <article class="bg-surface-container-lowest rounded-3xl p-6 shadow-sm">
            <figure class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center m-0 mb-4">
              <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">fitness_center</i>
            </figure>

            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">Treinos feitos</p>
            <p class="flex items-end gap-1">
              <strong class="text-4xl font-black text-on-surface">
                <%= typeof resumoTreinos !== 'undefined' ? resumoTreinos.total_treinos : 0 %>
              </strong>
              <em class="not-italic text-sm text-on-surface-variant mb-1">total</em>
            </p>
          </article>

          <article class="bg-surface-container-lowest rounded-3xl p-6 shadow-sm">
            <figure class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center m-0 mb-4">
              <i class="material-symbols-outlined text-secondary not-italic" aria-hidden="true">timer</i>
            </figure>

            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">Tempo médio</p>
            <p class="flex items-end gap-1">
              <strong class="text-4xl font-black text-on-surface">
                <%= typeof resumoTreinos !== 'undefined' ? resumoTreinos.tempo_medio : 0 %>
              </strong>
              <em class="not-italic text-sm text-on-surface-variant mb-1">min</em>
            </p>
          </article>

          <article class="bg-surface-container-lowest rounded-3xl p-6 shadow-sm">
            <figure class="w-12 h-12 rounded-full bg-tertiary-fixed/20 flex items-center justify-center m-0 mb-4">
              <i class="material-symbols-outlined text-on-tertiary-fixed not-italic" aria-hidden="true">local_fire_department</i>
            </figure>

            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">Ofensiva</p>
            <p class="flex items-end gap-1">
              <strong class="text-4xl font-black text-on-surface">
                <%= typeof streak !== 'undefined' ? streak.streak_atual : 0 %>
              </strong>
              <em class="not-italic text-sm text-on-surface-variant mb-1">dias</em>
            </p>
          </article>

        </section>

        <article class="bg-primary rounded-3xl p-6 text-white relative overflow-hidden">
          <h3 class="text-xl font-extrabold headline mb-2">Continue treinando</h3>
          <p class="opacity-90 mb-5 max-w-lg">
            Seu painel acompanha seu plano atual, então você sempre volta para o lugar certo.
          </p>

          <a href="<%= painelCorreto %>" class="inline-flex items-center gap-2 bg-white text-primary px-6 py-3 rounded-full font-bold active:scale-95 transition-transform">
            Ir para meus treinos
            <i class="material-symbols-outlined not-italic" aria-hidden="true">arrow_forward</i>
          </a>

          <b class="absolute -right-10 -bottom-10 w-40 h-40 bg-white opacity-10 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
        </article>

      </section>

      <section class="training-data-card md:col-span-12 bg-surface-container-lowest rounded-3xl p-8 shadow-sm flex flex-col gap-6">

        <header class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <hgroup>
            <h2 class="text-2xl font-extrabold headline text-on-surface">Preferências de Treino</h2>
            <p class="text-sm text-on-surface-variant mt-1">
              Essas são as informações que você preencheu na tela de dados do aluno.
            </p>
          </hgroup>

          <a href="/dadosaluno" class="inline-flex items-center justify-center gap-2 bg-primary text-white px-6 py-3 rounded-full font-bold shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all">
            Alterar dados
            <i class="material-symbols-outlined not-italic" aria-hidden="true">edit</i>
          </a>
        </header>

        <% if (dadosForamPreenchidos) { %>
          <ul class="grid grid-cols-1 md:grid-cols-4 gap-4 list-none p-0 m-0">

            <li class="bg-surface-container-low rounded-3xl p-5">
              <figure class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center m-0 mb-4">
                <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">flag</i>
              </figure>
              <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">Objetivo</p>
              <p class="font-black text-on-surface">
                <%= mapaObjetivo[dadosTreino.objetivo] || dadosTreino.objetivo || 'Não informado' %>
              </p>
            </li>

            <li class="bg-surface-container-low rounded-3xl p-5">
              <figure class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center m-0 mb-4">
                <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">exercise</i>
              </figure>
              <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">Tipo de treino</p>
              <p class="font-black text-on-surface">
                <%= mapaTipoTreino[dadosTreino.tipo_treino] || dadosTreino.tipo_treino || 'Não informado' %>
              </p>
            </li>

            <li class="bg-surface-container-low rounded-3xl p-5">
              <figure class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center m-0 mb-4">
                <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">trending_up</i>
              </figure>
              <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">Nível</p>
              <p class="font-black text-on-surface">
                <%= mapaNivel[dadosTreino.nivel_treino] || dadosTreino.nivel_treino || 'Não informado' %>
              </p>
            </li>

            <li class="bg-surface-container-low rounded-3xl p-5">
              <figure class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center m-0 mb-4">
                <i class="material-symbols-outlined text-primary not-italic" aria-hidden="true">location_on</i>
              </figure>
              <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">Local</p>
              <p class="font-black text-on-surface">
                <%= mapaLocal[dadosTreino.local_treino] || dadosTreino.local_treino || 'Não informado' %>
              </p>
            </li>

            <li class="bg-surface-container-low rounded-3xl p-5">
              <figure class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center m-0 mb-4">
                <i class="material-symbols-outlined text-secondary not-italic" aria-hidden="true">calendar_month</i>
              </figure>
              <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">Dias por semana</p>
              <p class="font-black text-on-surface">
                <%= dadosTreino.dias_semana ? dadosTreino.dias_semana + ' dias' : 'Não informado' %>
              </p>
            </li>

            <li class="md:col-span-3 bg-surface-container-low rounded-3xl p-5">
              <figure class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center m-0 mb-4">
                <i class="material-symbols-outlined text-secondary not-italic" aria-hidden="true">fitness_center</i>
              </figure>
              <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">Equipamentos</p>
              <p class="font-black text-on-surface">
                <%= equipamentosFormatados %>
              </p>
            </li>

            <li class="md:col-span-4 bg-surface-container-low rounded-3xl p-5">
              <figure class="w-12 h-12 rounded-full bg-tertiary-fixed/20 flex items-center justify-center m-0 mb-4">
                <i class="material-symbols-outlined text-on-tertiary-fixed not-italic" aria-hidden="true">assignment</i>
              </figure>
              <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">Limitações ou observações</p>
              <p class="font-bold text-on-surface leading-relaxed">
                <%= dadosTreino.limitacoes && dadosTreino.limitacoes.trim() ? dadosTreino.limitacoes : 'Nenhuma limitação informada.' %>
              </p>
            </li>

          </ul>
        <% } else { %>
          <section class="bg-surface-container-low rounded-3xl p-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
            <hgroup>
              <h3 class="font-black text-xl text-on-surface">Você ainda não preencheu seus dados de treino</h3>
              <p class="text-sm text-on-surface-variant mt-2 max-w-2xl">
                Preencha seu objetivo, nível, local de treino, equipamentos e disponibilidade para personalizar melhor sua experiência.
              </p>
            </hgroup>

            <a href="/dadosaluno" class="bg-primary text-white px-6 py-3 rounded-full font-bold active:scale-95 transition-transform">
              Preencher agora
            </a>
          </section>
        <% } %>

      </section>

      <article class="activity-card md:col-span-12 bg-surface-container-low rounded-3xl p-8 flex flex-col gap-6">

        <header class="flex items-center justify-between gap-4">
          <h2 class="text-2xl font-extrabold headline text-on-surface">Histórico de Exercícios</h2>

          <a href="<%= painelCorreto %>" class="text-primary font-bold text-sm flex items-center gap-2 hover:translate-x-1 transition-transform">
            Fazer treino
            <i class="material-symbols-outlined not-italic" aria-hidden="true">arrow_forward</i>
          </a>
        </header>

        <% if (typeof historicoTreinos !== 'undefined' && historicoTreinos.length > 0) { %>
          <ul role="list" class="grid grid-cols-1 gap-4 list-none p-0 m-0">

            <% historicoTreinos.forEach(function(treino) { %>
              <li class="bg-surface-container-lowest rounded-3xl p-5 flex items-center gap-5 shadow-sm hover:scale-[1.01] transition-transform">
                <figure class="w-20 h-20 rounded-2xl bg-primary/10 flex items-center justify-center m-0 shrink-0">
                  <i class="material-symbols-outlined text-primary text-4xl not-italic" aria-hidden="true">done_all</i>
                </figure>

                <hgroup class="flex-1">
                  <h3 class="font-bold text-lg text-on-surface">
                    <%= treino.nome_ficha ? treino.nome_ficha : 'Treino realizado' %>
                  </h3>

                  <p class="text-sm text-on-surface-variant">
                    <%= treino.categoria ? treino.categoria : 'Exercício' %>
                    <% if (treino.nivel) { %>
                      • <%= treino.nivel %>
                    <% } %>
                  </p>

                  <p class="text-xs text-on-surface-variant mt-2">
                    <%= new Date(treino.data_treino).toLocaleDateString('pt-BR') %>
                    •
                    <%= treino.duracao_min || 0 %> min
                    <% if (treino.calorias) { %>
                      • <%= treino.calorias %> kcal
                    <% } %>
                  </p>

                  <% if (treino.observacao) { %>
                    <p class="text-xs text-on-surface-variant mt-1 italic">
                      <%= treino.observacao %>
                    </p>
                  <% } %>
                </hgroup>

                <mark class="hidden sm:inline-block bg-primary/10 text-primary px-4 py-2 rounded-full text-xs font-black uppercase">
                  Concluído
                </mark>
              </li>
            <% }) %>

          </ul>
        <% } else { %>
          <section class="bg-surface-container-lowest rounded-3xl p-8 flex flex-col items-center justify-center text-center gap-4 shadow-sm">
            <figure class="w-20 h-20 rounded-full bg-primary/10 flex items-center justify-center m-0">
              <i class="material-symbols-outlined text-primary text-4xl not-italic" aria-hidden="true">fitness_center</i>
            </figure>

            <hgroup>
              <h3 class="font-bold text-xl text-on-surface">Nenhum exercício registrado ainda</h3>
              <p class="text-sm text-on-surface-variant max-w-md mt-2">
                Quando você concluir exercícios, eles aparecerão aqui.
              </p>
            </hgroup>

            <a href="<%= painelCorreto %>" class="bg-primary text-white px-6 py-3 rounded-full font-bold active:scale-95 transition-transform">
              Começar meu primeiro treino
            </a>
          </section>
        <% } %>

      </article>

    </section>
  </main>

  <nav class="md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-2 pb-6 pt-2 bg-[#f7f5ff]/90 dark:bg-[#1a1b26]/90 backdrop-blur-lg shadow-[0_-10px_40px_rgba(35,44,81,0.08)] rounded-t-[32px]"
       aria-label="Navegação mobile">

    <a href="<%= painelCorreto %>"
       class="flex flex-col items-center justify-center text-[#232c51] dark:text-[#d5dbff] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">fitness_center</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Treinos</em>
    </a>

    <a href="<%= videosCorreto %>"
       class="flex flex-col items-center justify-center text-[#232c51] dark:text-[#d5dbff] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">play_circle</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Vídeos</em>
    </a>

    <% if (alunoPago) { %>
      <a href="/feedbackaluno"
         class="flex flex-col items-center justify-center text-[#232c51] dark:text-[#d5dbff] opacity-60 p-3 hover:opacity-100 transition-opacity">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
        <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Feedback</em>
      </a>
    <% } else { %>
      <a href="<%= painelCorreto %>#planos"
         class="flex flex-col items-center justify-center text-[#232c51] dark:text-[#d5dbff] opacity-60 p-3 hover:opacity-100 transition-opacity">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">payments</i>
        <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Planos</em>
      </a>
    <% } %>

    <a href="/perfilaluno"
       class="flex flex-col items-center justify-center text-[#0058ba] dark:text-[#d5dbff] opacity-100 p-3 rounded-[18px] bg-[#d5dbff] hover:opacity-100 transition-opacity"
       aria-current="page">
      <i class="material-symbols-outlined not-italic" aria-hidden="true"
         style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24">person</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Perfil</em>
    </a>

  </nav>

</body>
</html>