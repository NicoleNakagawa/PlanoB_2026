<!DOCTYPE html>
<html class="light" lang="pt-BR">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>PlanoB - Painel Diamante</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface": "#f7f5ff",
            "primary": "#0058ba",
            "secondary": "#00647b",
            "on-primary": "#f0f2ff",
            "on-surface": "#232c51",
            "on-surface-variant": "#505a81",
            "surface-container-lowest": "#ffffff",
            "surface-container-low": "#efefff",
            "surface-container": "#e4e7ff",
            "surface-container-high": "#dde1ff",
            "surface-container-highest": "#d5dbff",
            "outline": "#6c759e",
            "outline-variant": "#a2abd7",
            "tertiary-fixed": "#ffd709",
            "on-tertiary-fixed": "#453900",
            "error": "#b31b25"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"],
            label: ["Manrope"]
          }
        }
      }
    }
  </script>

  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .logo-header {
      font-size: 2.7rem;
      line-height: 1;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    h4,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    .avatar-placeholder .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    .diamond-card {
      background:
        radial-gradient(circle at top right, rgba(255, 215, 9, 0.25), transparent 32%),
        linear-gradient(135deg, #0058ba 0%, #00647b 100%);
    }

    .exercise-card:hover img {
      transform: scale(1.08);
    }

    progress {
      appearance: none;
      -webkit-appearance: none;
    }

    progress::-webkit-progress-bar {
      background: #d5dbff;
      border-radius: 999px;
    }

    progress::-webkit-progress-value {
      background: #ffd709;
      border-radius: 999px;
    }

    progress::-moz-progress-bar {
      background: #ffd709;
      border-radius: 999px;
    }

    @media (max-width: 768px) {
      html,
      body {
        width: 100%;
        overflow-x: hidden;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      header.fixed a.logo-header {
        font-size: 1.45rem;
        line-height: 1;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 16px 135px !important;
      }

      article.hero-diamante {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.hero-diamante h1 {
        font-size: 2.15rem !important;
        line-height: 1.05 !important;
      }

      section.card-mobile,
      article.card-mobile {
        padding: 22px !important;
        border-radius: 26px !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 52px;
        border-radius: 18px;
      }

      nav[aria-label="Navegação mobile"] a[aria-current="page"] {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
      }
    }

    @media (max-width: 420px) {
      main {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }

      article.hero-diamante h1 {
        font-size: 1.85rem !important;
      }

      nav[aria-label="Navegação mobile"] em {
        font-size: 8px !important;
      }
    }
  </style>
</head>

<body class="bg-surface text-on-surface min-h-screen">

  <%
    const alunoSeguro = typeof aluno !== 'undefined' && aluno ? aluno : {}
    const videosSeguros = typeof videosFree !== 'undefined' && videosFree ? videosFree : []

    const linkPainel = typeof linkPainelAluno !== 'undefined' && linkPainelAluno ? linkPainelAluno : '/paineldiamante'
    const linkVideos = typeof linkVideosAluno !== 'undefined' && linkVideosAluno ? linkVideosAluno : '/videos'

    const nomeAluno = alunoSeguro.nome ? alunoSeguro.nome.split(' ')[0] : 'Atleta'

    const treinosHoje = videosSeguros.length > 0 ? videosSeguros.slice(0, 6) : [
      {
        slug: 'agachamento',
        titulo: 'Explosão Muscular',
        categoria: 'Full Body',
        nivel: 'Intermediário',
        duracao: '45:00',
        duracaoMin: 45,
        capa: 'https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&w=1200&q=80',
        descricao: 'Treino completo para força, resistência e hipertrofia.'
      },
      {
        slug: 'cardio-10-minutos',
        titulo: 'Cardio Intenso',
        categoria: 'Cardio',
        nivel: 'Avançado',
        duracao: '20:00',
        duracaoMin: 20,
        capa: 'https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?auto=format&fit=crop&w=1200&q=80',
        descricao: 'Eleve sua frequência cardíaca com segurança.'
      },
      {
        slug: 'mobilidade-basica',
        titulo: 'Mobilidade Premium',
        categoria: 'Mobilidade',
        nivel: 'Iniciante',
        duracao: '15:00',
        duracaoMin: 15,
        capa: 'https://images.unsplash.com/photo-1599901860904-17e6ed7083a0?auto=format&fit=crop&w=1200&q=80',
        descricao: 'Prepare articulações e músculos para treinos melhores.'
      }
    ]

    const treinoDestaque = treinosHoje[0]
    const totalTreinos = treinosHoje.length
    const treinosConcluidos = 2
    const progressoTreino = totalTreinos > 0 ? Math.round((treinosConcluidos / totalTreinos) * 100) : 0

    function primeiraLetra(texto) {
      return texto ? texto.charAt(0).toUpperCase() : 'A'
    }
  %>

  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">
    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <a href="<%= linkPainel %>" class="font-headline logo-font logo-header text-primary no-underline">PlanoB</a>

      <section class="hidden md:flex gap-3 ml-8">
        <a class="text-primary bg-surface-container-highest font-bold transition-colors px-4 py-2 rounded-full" href="<%= linkPainel %>">
          Treinos
        </a>

        <a class="text-on-surface hover:bg-surface-container transition-colors px-4 py-2 rounded-full" href="/progressosemanal">
          Progresso
        </a>

        <a class="text-on-surface hover:bg-surface-container transition-colors px-4 py-2 rounded-full" href="/feedbackaluno">
          Feedback
        </a>
      </section>
    </nav>

    <menu class="flex items-center gap-4 p-0 m-0 list-none">
      <li>
        <a href="/suporte" class="p-2 rounded-full hover:bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center" aria-label="Suporte">
          <i class="material-symbols-outlined text-on-surface-variant not-italic" aria-hidden="true">notifications</i>
        </a>
      </li>

      <li>
        <a href="/perfilaluno" class="p-1 rounded-full bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center" aria-label="Perfil do aluno">
          <% if (alunoSeguro.foto) { %>
            <img src="<%= alunoSeguro.foto %>" alt="Foto do aluno" class="w-10 h-10 rounded-full object-cover">
          <% } else { %>
            <span class="w-10 h-10 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </span>
          <% } %>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] flex-col gap-2 py-8 z-40 mt-16">
    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <% if (alunoSeguro.foto) { %>
          <img class="w-12 h-12 rounded-full object-cover" src="<%= alunoSeguro.foto %>" alt="Foto de perfil do aluno" />
        <% } else { %>
          <span class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden" aria-label="Aluno sem foto">
            <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
          </span>
        <% } %>

        <figcaption>
          <p class="text-sm font-bold text-on-surface">Portal Diamante</p>
          <p class="text-xs text-on-surface-variant">Olá, <%= nomeAluno %></p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="<%= linkPainel %>" aria-current="page">
        <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">dashboard</i>
        <em class="not-italic">Início</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="<%= linkVideos %>">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">play_circle</i>
        <em class="not-italic">Início</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/progressosemanal">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">monitoring</i>
        <em class="not-italic">Progresso</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/streakprogress">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">local_fire_department</i>
        <em class="not-italic">Sequência</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/feedbackaluno">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
        <em class="not-italic">Feedback</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/perfilaluno">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">person</i>
        <em class="not-italic">Perfil</em>
      </a>
    </nav>

    <footer class="mt-auto px-4 pb-8 flex flex-col gap-3">
      <section class="mx-2 p-4 bg-tertiary-fixed rounded-3xl text-on-tertiary-fixed shadow-sm">
        <p class="text-[10px] font-black uppercase tracking-wider mb-1 opacity-70">Plano ativo</p>
        <p class="text-lg font-black headline mb-2">Diamante VIP</p>
        <p class="text-xs font-bold opacity-80">Treinos completos, feedback e recursos premium liberados.</p>
      </section>

      <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:text-primary rounded-full hover:bg-surface-container transition-colors text-sm" href="/suporte">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">help</i>
        <em class="not-italic">Ajuda</em>
      </a>

      <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:text-error rounded-full hover:bg-surface-container transition-colors text-sm" href="/logout">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i>
        <em class="not-italic">Sair</em>
      </a>
    </footer>
  </aside>

  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <article class="hero-diamante md:col-span-12 relative overflow-hidden rounded-3xl diamond-card p-8 md:p-12 text-white shadow-2xl">
        <section class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
          <hgroup class="max-w-2xl">
            <mark class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md text-xs font-bold uppercase tracking-widest mb-4 text-white">
              Plano Diamante
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              MEUS TREINOS.
            </h1>

            <p class="text-lg opacity-90 max-w-xl">
              Sua jornada premium continua hoje. Acesse seus treinos, acompanhe sua sequência e envie feedback ao professor.
            </p>

            <nav class="flex flex-col sm:flex-row gap-3 mt-6">
              <a href="<%= linkVideos %>" class="bg-white text-primary rounded-full px-7 py-3 font-black inline-flex items-center justify-center gap-2 active:scale-95 transition-transform">
                Ver todos os treinos
                <i class="material-symbols-outlined not-italic" aria-hidden="true">arrow_forward</i>
              </a>

              <a href="/feedbackaluno" class="bg-white/15 text-white border border-white/20 rounded-full px-7 py-3 font-black inline-flex items-center justify-center gap-2 active:scale-95 transition-transform">
                Enviar feedback
                <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
              </a>
            </nav>
          </hgroup>

          <figure class="flex flex-col items-center gap-4 bg-white/10 backdrop-blur-xl p-6 md:p-8 rounded-3xl border border-white/10 w-full max-w-[240px] mx-auto md:mx-0 md:w-auto m-0">
            <span class="w-28 h-28 rounded-full bg-white/15 flex items-center justify-center">
              <i class="material-symbols-outlined text-tertiary-fixed text-7xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">diamond</i>
            </span>

            <figcaption class="text-sm font-black uppercase tracking-widest text-center">
              Diamante ativo
            </figcaption>
          </figure>
        </section>

        <b class="absolute -right-20 -bottom-20 w-96 h-96 bg-tertiary-fixed opacity-10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        <b class="absolute -left-20 -top-20 w-64 h-64 bg-white opacity-5 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
      </article>

      <section class="md:col-span-12">
        <article class="relative aspect-video min-h-[320px] rounded-[2rem] overflow-hidden shadow-2xl bg-black">
          <img
            alt="<%= treinoDestaque.titulo %>"
            class="w-full h-full object-cover opacity-60"
            src="<%= treinoDestaque.capa %>"
          />

          <section class="absolute inset-0 flex items-center justify-center">
            <a class="w-24 h-24 rounded-full bg-white/85 backdrop-blur-md flex items-center justify-center text-primary hover:scale-110 transition-transform shadow-2xl active:scale-95"
               href="/execucaoexercicios?video=<%= treinoDestaque.slug %>"
               aria-label="Iniciar treino do dia">
              <i aria-hidden="true" class="material-symbols-outlined text-5xl not-italic" style="font-variation-settings:'FILL' 1;">play_arrow</i>
            </a>
          </section>

          <section class="absolute bottom-0 left-0 right-0 p-6 md:p-10 bg-gradient-to-t from-black/90 via-black/50 to-transparent">
            <article class="flex flex-wrap items-center gap-3 mb-4">
              <strong class="px-4 py-1.5 bg-tertiary-fixed text-on-tertiary-fixed text-[11px] font-black rounded-full uppercase">
                Treino do dia
              </strong>

              <strong class="px-4 py-1.5 bg-primary text-white text-[11px] font-black rounded-full uppercase flex items-center gap-1.5">
                <i aria-hidden="true" class="material-symbols-outlined text-xs not-italic" style="font-variation-settings:'FILL' 1;">diamond</i>
                Diamante VIP
              </strong>
            </article>

            <h2 class="text-2xl md:text-4xl font-headline font-black text-white leading-tight">
              <%= treinoDestaque.titulo %>
            </h2>

            <p class="text-white/80 text-sm md:text-base mt-3 max-w-2xl">
              <%= treinoDestaque.descricao || 'Treino premium selecionado para sua evolução de hoje.' %>
            </p>

            <footer class="text-white/80 text-sm mt-4 flex flex-wrap items-center gap-5">
              <strong class="flex items-center gap-2">
                <i aria-hidden="true" class="material-symbols-outlined text-xl not-italic">timer</i>
                <%= treinoDestaque.duracao || ((treinoDestaque.duracaoMin || 30) + ' min') %>
              </strong>

              <strong class="flex items-center gap-2">
                <i aria-hidden="true" class="material-symbols-outlined text-xl not-italic">fitness_center</i>
                <%= treinoDestaque.nivel || 'Intermediário' %>
              </strong>
            </footer>
          </section>
        </article>
      </section>

      <section class="md:col-span-12 grid grid-cols-1 md:grid-cols-3 gap-6">
        <article class="card-mobile md:col-span-2 bg-primary rounded-3xl p-8 text-white shadow-xl shadow-primary/20 relative overflow-hidden">
          <i class="material-symbols-outlined absolute -right-6 -top-6 text-[150px] opacity-10 not-italic" aria-hidden="true">local_fire_department</i>

          <header>
            <p class="text-xs font-black uppercase tracking-widest text-white/70">Sua ofensiva</p>
            <h2 class="text-3xl font-black headline mt-1">Continue sua sequência</h2>
          </header>

          <section class="flex flex-col md:flex-row md:items-end justify-between gap-6 mt-8">
            <article>
              <strong class="text-7xl font-black headline">42</strong>
              <span class="text-xl font-bold uppercase tracking-widest text-white/70"> dias</span>
            </article>

            <section class="bg-white/15 backdrop-blur-md rounded-3xl p-5">
              <p class="text-sm font-black flex items-center gap-2">
                <i class="material-symbols-outlined text-tertiary-fixed not-italic" aria-hidden="true">stars</i>
                Meta Diamante: 40 dias
              </p>

              <p class="text-xs font-black bg-tertiary-fixed text-on-tertiary-fixed px-3 py-2 rounded-full mt-3 inline-block">
                Benefício premium desbloqueado
              </p>
            </section>
          </section>
        </article>

        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-8 shadow-sm border-t-4 border-tertiary-fixed">
          <i class="material-symbols-outlined text-tertiary-fixed text-5xl not-italic mb-4" style="font-variation-settings:'FILL' 1" aria-hidden="true">loyalty</i>

          <h2 class="text-2xl font-black headline text-on-surface">Clube Diamante</h2>

          <p class="text-sm text-on-surface-variant mt-2">
            Continue treinando para manter seus benefícios premium ativos.
          </p>

          <section class="mt-6">
            <header class="flex justify-between text-xs font-black text-on-surface-variant uppercase mb-2">
              <span>Progresso</span>
              <span class="text-primary">85%</span>
            </header>

            <progress class="w-full h-3 rounded-full overflow-hidden" value="85" max="100">85%</progress>

            <p class="text-sm text-on-surface-variant mt-4">
              Faltam poucos dias para alcançar uma nova recompensa.
            </p>
          </section>
        </article>
      </section>

      <section class="md:col-span-12">
        <header class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-6">
          <hgroup>
            <h2 class="text-3xl font-black headline tracking-tight uppercase">Exercícios de hoje</h2>
            <p class="text-on-surface-variant">Siga a sequência para melhores resultados.</p>
          </hgroup>

          <section class="flex flex-col sm:flex-row gap-3">
            <a class="flex items-center justify-center gap-2 text-sm font-black text-primary bg-primary/10 px-5 py-3 rounded-full active:scale-95 transition-transform"
               href="<%= linkVideos %>">
              Ver todos
              <i aria-hidden="true" class="material-symbols-outlined text-sm not-italic">arrow_forward</i>
            </a>

            <article class="flex items-center justify-center gap-2 text-sm font-black text-on-tertiary-fixed bg-tertiary-fixed px-5 py-3 rounded-full">
              <i aria-hidden="true" class="material-symbols-outlined text-lg not-italic">check_circle</i>
              <%= treinosConcluidos %> / <%= totalTreinos %> concluídos
            </article>
          </section>
        </header>

        <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
          <% treinosHoje.forEach(function(video, index) { %>
            <% const concluido = index === 1 || index === 3 %>

            <article class="exercise-card bg-surface-container-lowest rounded-3xl p-5 border border-surface-container-high hover:shadow-xl transition-all duration-300 flex flex-col">
              <figure class="relative w-full aspect-video rounded-2xl overflow-hidden mb-4 bg-surface-container-high m-0">
                <img alt="<%= video.titulo %>" class="w-full h-full object-cover transition-transform duration-500" src="<%= video.capa %>" />

                <figcaption class="absolute top-3 left-3">
                  <strong class="px-3 py-1 bg-white/90 backdrop-blur-sm text-primary text-[10px] font-black rounded-full uppercase">
                    <%= video.categoria || 'Treino' %>
                  </strong>
                </figcaption>

                <a class="absolute top-3 right-3 w-11 h-11 rounded-full bg-white/90 backdrop-blur-sm flex items-center justify-center text-primary shadow-md active:scale-95 transition-transform"
                   href="/execucaoexercicios?video=<%= video.slug %>"
                   aria-label="Abrir vídeo <%= video.titulo %>">
                  <i aria-hidden="true" class="material-symbols-outlined not-italic">videocam</i>
                </a>
              </figure>

              <section class="flex justify-between items-start gap-4 mb-4">
                <hgroup>
                  <h3 class="text-xl font-black headline text-on-surface"><%= video.titulo %></h3>
                  <p class="text-on-surface-variant text-sm font-medium"><%= video.nivel || 'Nível livre' %></p>
                </hgroup>

                <button type="button" class="shrink-0" aria-label="Marcar treino como concluído">
                  <span class="w-11 h-11 rounded-full border-2 <%= concluido ? 'border-primary bg-primary text-white' : 'border-primary text-primary bg-white' %> flex items-center justify-center transition-all">
                    <i aria-hidden="true" class="material-symbols-outlined not-italic" style="<%= concluido ? 'font-variation-settings:\'FILL\' 1,\'wght\' 700' : '' %>">check</i>
                  </span>
                </button>
              </section>

              <p class="text-sm text-on-surface-variant mb-4 line-clamp-2">
                <%= video.descricao || 'Abra o vídeo para acompanhar a execução correta do exercício.' %>
              </p>

              <footer class="mt-auto flex items-center justify-between gap-4 py-3 border-t border-surface-container-high">
                <span class="flex items-center gap-1.5">
                  <i aria-hidden="true" class="material-symbols-outlined text-primary text-lg not-italic">timer</i>
                  <strong class="text-sm font-bold"><%= video.duracao || ((video.duracaoMin || 10) + ' min') %></strong>
                </span>

                <a href="/execucaoexercicios?video=<%= video.slug %>" class="text-sm font-black text-primary hover:underline">
                  Iniciar
                </a>
              </footer>
            </article>
          <% }) %>
        </section>

        <footer class="mt-10 flex justify-center">
          <a class="px-10 md:px-12 py-4 bg-primary text-white rounded-full font-black text-lg shadow-2xl shadow-primary/30 hover:scale-105 active:scale-95 transition-all text-center"
             href="<%= linkVideos %>">
            Ver todos os treinos
          </a>
        </footer>
      </section>

    </section>
  </main>

  <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex justify-around items-end px-4 pb-6 pt-2 bg-[#f7f5ff]/90 backdrop-blur-lg shadow-[0_-10px_40px_rgba(35,44,81,0.08)] rounded-t-[32px]"
       aria-label="Navegação mobile">

    <a href="<%= linkPainel %>"
       class="flex flex-col items-center justify-center text-[#0058ba] opacity-100 p-3 rounded-[18px] bg-[#d5dbff]"
       aria-current="page">
      <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">dashboard</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Início</em>
    </a>

    <a href="/progressosemanal"
       class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">monitoring</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Progresso</em>
    </a>

    <a href="<%= linkVideos %>"
       class="bg-primary text-white w-14 h-14 rounded-full shadow-lg shadow-primary/40 -mt-8 flex items-center justify-center active:scale-95 transition-transform"
       aria-label="Ver treinos">
      <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">play_circle</i>
    </a>

    <a href="/feedbackaluno"
       class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Feedback</em>
    </a>

    <a href="/perfilaluno"
       class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">person</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Perfil</em>
    </a>
  </nav>

</body>

</html>