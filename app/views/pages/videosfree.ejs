<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>PlanoB - Vídeos Demonstrativos</title>

  <link rel="stylesheet" href="/css/videosfree.css" />

  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <style>
    .avatar-placeholder {
      width: 48px;
      height: 48px;
      border-radius: 999px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
      flex-shrink: 0;
    }

    .avatar-placeholder .material-symbols-outlined {
      font-size: 2.5rem;
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    .video-card-link,
    .demo-card-link {
      display: block;
      color: inherit;
      text-decoration: none;
      height: 100%;
    }
  </style>
</head>

<body>
  <%
    const alunoSeguro = typeof aluno !== 'undefined' && aluno ? aluno : {}
    const planoAluno = alunoSeguro.id_plano ? Number(alunoSeguro.id_plano) : 1
    const nomePlanoAluno = planoAluno === 3 ? 'Diamante' : planoAluno === 2 ? 'Lazuli' : 'Free'
    const nomeAluno = alunoSeguro.nome ? alunoSeguro.nome.split(' ')[0] : 'Aluno'
  %>
  <header class="topbar">
    <nav class="topbar-logo" aria-label="Navegação principal">
      <a href="/painelfree" class="logo">PlanoB</a>
    </nav>

    <menu class="topbar-actions">
      <li>
        <button type="button" aria-label="Notificações">
          <i class="material-symbols-outlined" aria-hidden="true">notifications</i>
        </button>
      </li>

      <li>
        <a href="/perfilaluno" aria-label="Perfil">
          <% if (alunoSeguro.foto) { %>
            <img src="<%= alunoSeguro.foto %>" alt="Foto do aluno" style="width: 40px; height: 40px; border-radius: 999px; object-fit: cover;" />
          <% } else { %>
            <i class="material-symbols-outlined" aria-hidden="true">account_circle</i>
          <% } %>
        </a>
      </li>
    </menu>
  </header>

  <aside class="sidebar">
    <header class="sidebar-profile">
      <figure>
        <picture>
          <% if (alunoSeguro.foto) { %>
            <img
              src="<%= alunoSeguro.foto %>"
              alt="Foto de perfil do aluno"
            />
          <% } else { %>
            <span class="avatar-placeholder" aria-label="Aluno sem foto">
              <i class="material-symbols-outlined" aria-hidden="true">account_circle</i>
            </span>
          <% } %>
        </picture>

        <figcaption>
          <p><%= nomeAluno %></p>
          <p>Plano <%= nomePlanoAluno %> ativo</p>
        </figcaption>
      </figure>
    </header>

    <nav class="sidebar-menu" aria-label="Menu lateral">
      <a href="/painelfree">
        <i class="material-symbols-outlined" aria-hidden="true">fitness_center</i>
        <em>Treinos</em>
      </a>

      <a class="active" href="/videosfree" aria-current="page">
        <i class="material-symbols-outlined" aria-hidden="true">play_circle</i>
        <em>Vídeos</em>
      </a>

      <a href="/painelfree#planos">
        <i class="material-symbols-outlined" aria-hidden="true">payments</i>
        <em>Planos</em>
      </a>

      <a href="/perfilaluno">
        <i class="material-symbols-outlined" aria-hidden="true">person</i>
        <em>Perfil</em>
      </a>

            <br><br><br><br><br>
          <footer class="mt-auto px-4 pb-8 flex flex-col gap-2">
      <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:text-error rounded-full hover:bg-surface-container transition-colors text-sm" href="/logout">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i>
        <em class="not-italic">Sair</em>
      </a>
    </footer>
    </nav>
  </aside>

  <main class="content">
    <section class="hero">
      <picture>
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuCQ25wGvp89ZWp-q_wgmN4zlTksHejznpDyMFkVzY8hA1PZfwXkiH5AeveRNaMH6Gmo9jDbw_-fGnSPZSCyClC-LhjZPPcwqTR250tBOiixcyBjQyt27-_Iazsp42_Mm5U6woJm0XOrjQH7cStx247aZfGtybfKsNttn5XyO8VIhbI7Yom2uE8Pswu-zvBz0mqrIgihphjWm45pmD-k5nXlQA9iCupQVWr512lhmQPUjpCGpvzK8ztyzKWNEpqqqxdi_zdW_jStPndy"
          alt="Atleta realizando treino intenso"
        />
      </picture>

      <article class="hero-text">
        <mark>Plano gratuito</mark>

        <h1>Libere o seu potencial máximo</h1>

        <p>
          Você está acessando uma parte da nossa biblioteca. Melhore para Lazuli ou Diamante e tenha acesso a rotinas personalizadas e vídeos exclusivos.
        </p>

        <a href="/painelfree#planos">Conhecer Planos</a>
      </article>
    </section>

    <section class="library">
      <header class="section-title">
        <hgroup>
          <h2>Vídeos do dia</h2>
          <p>Os primeiros passos para uma vida mais ativa e saudável.</p>
        </hgroup>
      </header>

      <ul class="video-grid" role="list">
        <% videosFree.slice(0, 3).forEach(function(video) { %>
          <li>
            <a class="video-card-link" href="/execucaoexercicios?video=<%= video.slug %>">
              <article class="video-card">
                <figure>
                  <img
                    src="<%= video.capa %>"
                    alt="<%= video.titulo %>"
                  />

                  <figcaption>
                    <i class="material-symbols-outlined" aria-hidden="true">play_circle</i>
                    <time><%= video.duracao %></time>
                  </figcaption>
                </figure>

                <footer>
                  <hgroup>
                    <p><%= video.categoria %></p>
                    <h3><%= video.titulo %></h3>
                  </hgroup>

                  <mark><%= video.nivel %></mark>
                </footer>
              </article>
            </a>
          </li>
        <% }) %>
      </ul>
    </section>

    <section class="quick-demos">
      <h2>Demonstrações Rápidas</h2>

      <ul class="demo-grid" role="list">
        <% videosFree.slice(3, 6).forEach(function(video) { %>
          <li>
            <a class="demo-card-link" href="/execucaoexercicios?video=<%= video.slug %>">
              <article class="demo-card">
                <img
                  src="<%= video.capa %>"
                  alt="<%= video.titulo %>"
                />

                <footer>
                  <p><%= video.categoria %></p>
                  <h3><%= video.titulo %></h3>
                </footer>
              </article>
            </a>
          </li>
        <% }) %>

        <li>
          <article class="premium-card">
            <i class="material-symbols-outlined" aria-hidden="true">workspace_premium</i>

            <h3>Liberar mais +100 vídeos</h3>

            <p>Tenha acesso a conteúdos exclusivos de treinadores Pro.</p>

            <a href="/painelfree#planos">Upgrade Agora</a>
          </article>
        </li>
      </ul>
    </section>
  </main>

  <nav class="mobile-menu" aria-label="Navegação mobile">
    <a href="/painelfree">
      <i class="material-symbols-outlined" aria-hidden="true">fitness_center</i>
      <em>Treinos</em>
    </a>

    <a class="active" href="/videosfree" aria-current="page">
      <i class="material-symbols-outlined" aria-hidden="true">play_circle</i>
      <em>Vídeos</em>
    </a>

    <a href="/painelfree#planos">
      <i class="material-symbols-outlined" aria-hidden="true">payments</i>
      <em>Planos</em>
    </a>

    <a href="/perfilaluno">
      <i class="material-symbols-outlined" aria-hidden="true">person</i>
      <em>Perfil</em>
    </a>
  </nav>
</body>
</html>