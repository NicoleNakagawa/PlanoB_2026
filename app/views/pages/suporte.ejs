    /* ===================== RESPONSIVIDADE MOBILE - PÁGINA SUPORTE ===================== */

* {
  box-sizing: border-box;
}

html,
body {
  max-width: 100%;
  overflow-x: hidden;
}

/* ===================== TABLETS E CELULARES ===================== */
@media (max-width: 768px) {

  body {
    padding-bottom: 7rem !important;
  }

  /* ===================== HEADER ===================== */
  header nav[aria-label="Navegação principal"] {
    height: 80px !important;
    padding: 0 1.25rem !important;
    display: flex !important;
    flex-direction: row !important;
    justify-content: space-between !important;
    align-items: center !important;
    gap: 1rem !important;
    flex-wrap: nowrap !important;
  }

  header nav[aria-label="Navegação principal"] > a {
    font-size: 1.6rem !important;
    width: auto !important;
    text-align: left !important;
    white-space: nowrap;
  }

  header ul[role="list"] {
    display: none !important;
  }

  header nav[aria-label="Ações do usuário"] {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: flex-end !important;
    gap: 0.7rem !important;
    width: auto !important;
  }

  header nav[aria-label="Ações do usuário"] a {
    white-space: nowrap;
    font-size: 0.9rem !important;
  }

  header nav[aria-label="Ações do usuário"] a:first-child {
    padding: 0 !important;
  }

  header nav[aria-label="Ações do usuário"] a:last-child {
    padding: 0.75rem 1rem !important;
    font-size: 0.85rem !important;
  }

  /* ===================== MAIN ===================== */
  main {
    padding-top: 80px !important;
  }

  /* ===================== HERO ===================== */
  section[aria-labelledby="suporte-heading"] {
    padding: 4rem 1.25rem 3rem !important;
  }

  section[aria-labelledby="suporte-heading"] article {
    max-width: 100% !important;
  }

  section[aria-labelledby="suporte-heading"] p.inline-flex {
    margin-bottom: 1.8rem !important;
    padding: 0.6rem 1rem !important;
  }

  section[aria-labelledby="suporte-heading"] p.inline-flex em {
    font-size: 0.8rem !important;
  }

  #suporte-heading {
    font-size: clamp(2.8rem, 13vw, 4.5rem) !important;
    line-height: 1 !important;
    margin-bottom: 2rem !important;
  }

/* Barra de busca */
search {
  width: 100% !important;
  display: block !important;
  position: relative !important;
}

search input {
  width: 100% !important;
  padding: 1.2rem 1.2rem 1.2rem 3.3rem !important;
  font-size: 0.95rem !important;
  border-radius: 1.5rem !important;
}

search i {
  position: absolute !important;
  left: 1.2rem !important;
  top: 1.35rem !important;
  bottom: auto !important;
  transform: none !important;
  display: block !important;
  line-height: 1 !important;
  z-index: 2 !important;
}

search button {
  position: static !important;
  transform: none !important;
  width: 100% !important;
  margin-top: 0.8rem !important;
  padding: 1rem !important;
  border-radius: 1.5rem !important;
}

  section[aria-labelledby="suporte-heading"] > b {
    display: none !important;
  }

  /* ===================== CATEGORIAS ===================== */
  section[aria-labelledby="categorias-heading"] {
    padding: 4rem 1.25rem !important;
  }

  section[aria-labelledby="categorias-heading"] ul {
    grid-template-columns: 1fr !important;
    gap: 1.2rem !important;
  }

  section[aria-labelledby="categorias-heading"] li {
    padding: 1.6rem !important;
    border-radius: 1.6rem !important;
    transform: none !important;
  }

  section[aria-labelledby="categorias-heading"] li:hover {
    transform: none !important;
  }

  section[aria-labelledby="categorias-heading"] figure {
    width: 3rem !important;
    height: 3rem !important;
    margin-bottom: 1.2rem !important;
  }

  section[aria-labelledby="categorias-heading"] h3 {
    font-size: 1.2rem !important;
  }

  section[aria-labelledby="categorias-heading"] p {
    font-size: 0.9rem !important;
    line-height: 1.5 !important;
  }

  /* ===================== FAQ ===================== */
  section[aria-labelledby="faq-heading"] {
    padding: 4rem 1.25rem !important;
  }

  section[aria-labelledby="faq-heading"] header {
    margin-bottom: 2.5rem !important;
    gap: 1rem !important;
  }

  #faq-heading {
    font-size: 2.2rem !important;
    line-height: 1.1 !important;
  }

  #faq-heading + p {
    font-size: 1rem !important;
    line-height: 1.6 !important;
  }

  section[aria-labelledby="faq-heading"] summary {
    padding: 1.4rem !important;
    gap: 1rem !important;
  }

  section[aria-labelledby="faq-heading"] summary h3 {
    font-size: 1rem !important;
    line-height: 1.4 !important;
  }

  section[aria-labelledby="faq-heading"] details p {
    padding-left: 1.4rem !important;
    padding-right: 1.4rem !important;
    padding-bottom: 1.4rem !important;
    font-size: 0.95rem !important;
  }

  section[aria-labelledby="faq-heading"] details {
    border-radius: 1.5rem !important;
  }

  /* ===================== CONTATO ===================== */
  section[aria-labelledby="contato-heading"] {
    padding: 4rem 1.25rem !important;
  }

  #contato-heading {
    font-size: 2.2rem !important;
    line-height: 1.1 !important;
    margin-bottom: 2.5rem !important;
  }

  section[aria-labelledby="contato-heading"] ul {
    grid-template-columns: 1fr !important;
    gap: 1.5rem !important;
  }

  section[aria-labelledby="contato-heading"] li {
    padding: 2rem !important;
    border-radius: 1.6rem !important;
  }

  section[aria-labelledby="contato-heading"] h3 {
    font-size: 1.5rem !important;
  }

  section[aria-labelledby="contato-heading"] p {
    font-size: 0.95rem !important;
    line-height: 1.6 !important;
  }

  section[aria-labelledby="contato-heading"] a {
    padding: 1rem 1.2rem !important;
    font-size: 0.95rem !important;
  }

  /* ===================== FOOTER ===================== */
  footer {
    padding: 3rem 1.25rem 8rem !important;
    text-align: center !important;
  }

  footer section {
    align-items: center !important;
  }

  footer nav[aria-label="Links do rodapé"] {
    gap: 1rem !important;
    flex-direction: column !important;
  }

  footer nav[aria-label="Redes sociais"] {
    justify-content: center !important;
  }

  /* ===================== NAV MOBILE INFERIOR ===================== */
  nav[aria-label="Navegação mobile"] {
    padding-left: 0.75rem !important;
    padding-right: 0.75rem !important;
    padding-bottom: 1rem !important;
    padding-top: 0.5rem !important;
    border-radius: 1.5rem 1.5rem 0 0 !important;
  }

  nav[aria-label="Navegação mobile"] a {
    padding: 0.65rem !important;
  }

  nav[aria-label="Navegação mobile"] em {
    font-size: 0.6rem !important;
  }

  nav[aria-label="Navegação mobile"] i {
    font-size: 1.5rem !important;
  }

  nav[aria-label="Navegação mobile"] a.ativo {
    background-color: #0058ba !important;
    color: white !important;
    opacity: 1 !important;
    border-radius: 1rem !important;
    margin-bottom: 0.5rem !important;
    transform: scale(1.1) !important;
  }

  nav[aria-label="Navegação mobile"] a.ativo i,
  nav[aria-label="Navegação mobile"] a.ativo em {
    color: white !important;
  }
}

/* ===================== CELULARES PEQUENOS ===================== */
@media (max-width: 420px) {

  /* HEADER */
  header nav[aria-label="Navegação principal"] {
    padding: 0 0.9rem !important;
    gap: 0.6rem !important;
  }

  header nav[aria-label="Navegação principal"] > a {
    font-size: 1.35rem !important;
  }

  header nav[aria-label="Ações do usuário"] {
    gap: 0.5rem !important;
  }

  header nav[aria-label="Ações do usuário"] a:first-child {
    font-size: 0.8rem !important;
  }

  header nav[aria-label="Ações do usuário"] a:last-child {
    padding: 0.65rem 0.75rem !important;
    font-size: 0.75rem !important;
  }

  /* HERO */
  #suporte-heading {
    font-size: 2.6rem !important;
  }

  search input {
    font-size: 0.85rem !important;
  }

  /* CATEGORIAS */
  section[aria-labelledby="categorias-heading"] li {
    padding: 1.4rem !important;
  }

  /* FAQ */
  #faq-heading {
    font-size: 2rem !important;
  }

  section[aria-labelledby="faq-heading"] summary {
    padding: 1.2rem !important;
  }

  section[aria-labelledby="faq-heading"] summary h3 {
    font-size: 0.95rem !important;
  }

  /* CONTATO */
  #contato-heading {
    font-size: 2rem !important;
  }

  section[aria-labelledby="contato-heading"] li {
    padding: 1.5rem !important;
  }

  /* NAV MOBILE */
  nav[aria-label="Navegação mobile"] {
    padding-left: 0.4rem !important;
    padding-right: 0.4rem !important;
  }

  nav[aria-label="Navegação mobile"] a {
    padding: 0.55rem !important;
  }

  nav[aria-label="Navegação mobile"] em {
    font-size: 0.52rem !important;
  }

  nav[aria-label="Navegação mobile"] a.ativo {
    transform: scale(1.05) !important;
  }
}
  </style>
</head>

<body class="bg-background text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">

  <!-- ===================== HEADER / NAV ===================== -->
  <header class="fixed top-0 w-full z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl transition-all duration-300">
