<script>
  const paginaAtual = window.location.pathname.split("/").pop().replace(".html", "");

  const linksMobile = document.querySelectorAll(".mobile-link");

  linksMobile.forEach(link => {
    const paginaDoLink = link.dataset.page;

    if (
      paginaAtual === paginaDoLink ||
      (paginaAtual === "" && paginaDoLink === "home")
    ) {
      link.classList.add("ativo");
      link.setAttribute("aria-current", "page");
    }
  });
