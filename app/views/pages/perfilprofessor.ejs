  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .logo-header {
      font-size: 2.7rem;
      line-height: 1;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    h4,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    .avatar-placeholder .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    progress {
      appearance: none;
      -webkit-appearance: none;
    }

    progress::-webkit-progress-bar {
      background: #d5dbff;
      border-radius: 999px;
    }

    progress::-webkit-progress-value {
      background: #0058ba;
      border-radius: 999px;
    }

    progress::-moz-progress-bar {
      background: #0058ba;
      border-radius: 999px;
    }

    @media (max-width: 768px) {
      html,
      body {
        width: 100%;
        overflow-x: hidden;
      }

      body {
        background: #f7f5ff;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      header.fixed a.logo-header {
        font-size: 1.45rem;
        line-height: 1;
      }

      header.fixed menu {
        gap: 8px;
      }

      header.fixed button,
      header.fixed a {
        padding: 8px;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 16px 135px !important;
      }

      article.hero-professor {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.hero-professor > section {
        align-items: flex-start !important;
        gap: 26px !important;
      }

      article.hero-professor h1 {
        font-size: 2rem !important;
        line-height: 1.1 !important;
      }

      article.hero-professor p {
        font-size: 0.95rem !important;
      }

      article.hero-professor figure {
        width: 132px !important;
        height: 132px !important;
        margin: 0 auto !important;
      }

      section.card-mobile,
      article.card-mobile {
        padding: 22px !important;
        border-radius: 26px !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 52px;
        border-radius: 18px;
      }

      nav[aria-label="Navegação mobile"] a[aria-current="page"] {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
      }

      nav[aria-label="Navegação mobile"] a:hover {
        color: #0058ba !important;
        opacity: 1 !important;
      }
    }

    @media (max-width: 420px) {
      main {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }

      article.hero-professor h1 {
        font-size: 1.75rem !important;
      }

      article.hero-professor figure {
        width: 118px !important;
        height: 118px !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding-left: 4px !important;
        padding-right: 4px !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 48px;
        padding: 10px 4px !important;
      }

      nav[aria-label="Navegação mobile"] em {
        font-size: 8px !important;
      }
    }


    .notification-menu {
      position: relative;
      display: flex;
      align-items: center;
    }

    .notification-button {
      position: relative;
      width: 40px;
      height: 40px;
      padding: 8px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .notification-popup {
      position: absolute;
      top: 48px;
      right: 0;
      width: 300px;
      max-width: calc(100vw - 24px);
      background: #ffffff;
      border: 1px solid #e4e7ff;
      border-radius: 22px;
      box-shadow: 0 18px 45px rgba(35, 44, 81, 0.18);
      padding: 12px;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(-8px);
      transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s ease;
      z-index: 99999;
    }

    .notification-popup.open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateY(0);
    }

    .notification-arrow {
      position: absolute;
      top: -7px;
      right: 18px;
      width: 14px;
      height: 14px;
      background: #ffffff;
      border-left: 1px solid #e4e7ff;
      border-top: 1px solid #e4e7ff;
      transform: rotate(45deg);
    }

    .notification-badge {
      position: absolute;
      top: -3px;
      right: -3px;
      min-width: 18px;
      height: 18px;
      padding: 0 5px;
      border-radius: 999px;
      background: #b31b25;
      color: #ffffff;
      font-size: 9px;
      font-weight: 900;
      line-height: 18px;
      display: none;
      align-items: center;
      justify-content: center;
    }

    .notification-badge.active {
      display: flex;
    }

    .notification-list {
      max-height: 260px;
      overflow-y: auto;
    }

    .notification-list::-webkit-scrollbar {
      width: 5px;
    }

    .notification-list::-webkit-scrollbar-thumb {
      background: #a2abd7;
      border-radius: 999px;
    }

    @media (max-width: 640px) {
      .notification-popup {
        right: -52px;
        width: 280px;
      }

      .notification-arrow {
        right: 66px;
      }
    }

  </style>

  <link rel="stylesheet" href="/css/transicao-paginas.css">
</head>

<body class="bg-surface text-on-surface">

  <%
    const professorSeguro = typeof professor !== 'undefined' && professor ? professor : {}
    const estatisticasSeguras = typeof estatisticas !== 'undefined' && estatisticas ? estatisticas : {
      total_alunos: 0,
      total_videos: 0,
      feedbacks_pendentes: 0,
      aulas_realizadas: 0,
      media_progressao: 0
    }

    const videosSeguros = typeof videos !== 'undefined' && videos ? videos : []
    const feedbacksSeguros = typeof feedbacksRecentes !== 'undefined' && feedbacksRecentes ? feedbacksRecentes : []
    const alunosSeguros = typeof alunos !== 'undefined' && alunos ? alunos : []

    const nomeProfessor = professorSeguro.nome ? professorSeguro.nome.split(' ')[0] : 'Professor'

    function dataFormatada(data) {
      if (!data) return 'Sem data'
      return new Date(data).toLocaleDateString('pt-BR')
    }

    function segundosParaMinutos(segundos) {
      const valor = Number(segundos) || 0
      if (valor <= 0) return '0 min'
      return Math.round(valor / 60) + ' min'
    }

    function textoPlano(plano) {
      if (!plano) return 'Sem plano'
      return plano
    }

    function progressoAluno(aluno) {
      const dias = Number(aluno.dias_treinados) || 0
      const meta = Number(aluno.meta_dias) || 5
      if (meta <= 0) return 0
      return Math.min(Math.round((dias / meta) * 100), 100)
    }
  %>

  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">

    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <a href="/painelprofessor" class="font-headline logo-font logo-header text-primary no-underline">PlanoB</a>
    </nav>

    <form action="/todosalunos" method="GET" class="hidden md:flex items-center bg-surface-container-low px-4 py-2 rounded-full">
      <i class="material-symbols-outlined text-outline text-sm not-italic" aria-hidden="true">search</i>

      <label for="top-search-professor" class="sr-only">Buscar alunos</label>

      <input
        id="top-search-professor"
        name="busca"
        class="bg-transparent border-none focus:ring-0 text-sm w-48 ml-2"
        placeholder="Buscar alunos..."
        type="search"
      />
    </form>

    <menu class="flex items-center gap-4 p-0 m-0 list-none">
      <li class="notification-menu">
        <button
          id="notification-button"
          type="button"
          class="notification-button hover:bg-surface-container transition-colors active:scale-95"
          aria-label="Abrir notificações"
          aria-expanded="false"
          aria-controls="notification-popup"
        >
          <i class="material-symbols-outlined text-on-surface not-italic" aria-hidden="true">notifications</i>

          <em id="notification-badge" class="notification-badge not-italic">
            0
          </em>
        </button>

        <section id="notification-popup" class="notification-popup" aria-label="Notificações">
          <b class="notification-arrow font-normal" aria-hidden="true"></b>

          <header class="flex items-center justify-between gap-3 px-2 pb-3 border-b border-surface-container">
            <h2 class="text-sm font-black text-on-surface">
              Notificações
            </h2>

            <a href="/feedbackprofessor?status=pendentes" class="text-xs font-black text-primary hover:underline">
              Ver todas
            </a>
          </header>

          <section id="notification-content" class="notification-list pt-3">
            <article class="rounded-2xl bg-surface-container-low p-4 text-center">
              <i class="material-symbols-outlined text-primary text-4xl not-italic mb-2" aria-hidden="true">hourglass_empty</i>

              <p class="text-sm font-bold text-on-surface">
                Carregando...
              </p>
            </article>
          </section>
        </section>
      </li>

      <li>
        <a
          href="/perfilprofessor"
          class="p-1 rounded-full bg-surface-container hover:bg-surface-container-high transition-colors active:scale-95 inline-flex items-center justify-center"
          aria-label="Abrir perfil do professor"
          title="Perfil do professor"
        >
          <% if (professorSeguro.foto) { %>
            <img src="<%= professorSeguro.foto %>" alt="Foto do professor" class="w-10 h-10 rounded-full object-cover">
          <% } else { %>
            <em class="w-10 h-10 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden not-italic" aria-label="Professor sem foto">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </em>
          <% } %>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] dark:bg-[#12141c] flex-col gap-2 py-8 z-40 mt-16">

    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <picture>
          <% if (professorSeguro.foto) { %>
            <img
              class="w-12 h-12 rounded-full object-cover"
              src="<%= professorSeguro.foto %>"
              alt="Foto de perfil do professor"
            />
          <% } else { %>
            <em class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden not-italic" aria-label="Professor sem foto">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </em>
          <% } %>
        </picture>

        <figcaption>
          <p class="text-sm font-bold text-on-surface">
            <%= nomeProfessor %>
          </p>
          <p class="text-xs text-on-surface-variant">
            <%= professorSeguro.cref ? 'CREF ' + professorSeguro.cref : 'Professor PlanoB' %>
          </p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/painelprofessor">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">dashboard</i>
        <em class="not-italic">Dashboard</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/todosalunos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">groups</i>
        <em class="not-italic">Meus Alunos</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/todosvideos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">video_library</i>
        <em class="not-italic">Meus Vídeos</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/feedbackprofessor">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
        <em class="not-italic">Feedbacks</em>
      </a>

      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="/perfilprofessor" aria-current="page">
        <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24" aria-hidden="true">person</i>
        <em class="not-italic">Perfil</em>
      </a>
    </nav>

    <footer class="mt-auto px-4 pb-8 flex flex-col gap-2">
      <a href="/todosvideos" class="w-full bg-primary text-on-primary rounded-full py-4 font-bold shadow-lg shadow-primary/30 flex items-center justify-center gap-2 active:scale-95 transition-transform">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">add_circle</i>
        Novo Conteúdo
      </a>

      <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:text-error rounded-full hover:bg-surface-container transition-colors text-sm"
         href="/logout">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i>
        <em class="not-italic">Sair</em>
      </a>
    </footer>
  </aside>

  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <article class="hero-professor md:col-span-12 relative overflow-hidden rounded-3xl bg-primary p-8 md:p-12 text-white shadow-2xl">

        <section class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">

          <hgroup class="max-w-2xl">
            <mark class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md text-xs font-bold uppercase tracking-widest mb-4 text-white">
              Perfil do Professor
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              OLÁ, <%= professorSeguro.nome ? professorSeguro.nome.split(' ')[0].toUpperCase() : 'PROFESSOR' %>.
            </h1>

            <p class="text-lg opacity-90 max-w-xl">
              Gerencie seus dados profissionais, acompanhe seus conteúdos, alunos vinculados e feedbacks recebidos dentro do PlanoB.
            </p>
          </hgroup>

          <figure class="relative w-40 h-40 md:w-44 md:h-44 rounded-[2rem] bg-white/10 backdrop-blur-xl border border-white/10 p-3 m-0 group">
            <% if (professorSeguro.foto) { %>
              <img
                class="w-full h-full rounded-[1.5rem] object-cover"
                src="<%= professorSeguro.foto %>"
                alt="Foto do professor"
              />
            <% } else { %>
              <em class="w-full h-full rounded-[1.5rem] avatar-placeholder flex items-center justify-center overflow-hidden not-italic" aria-label="Professor sem foto">
                <i class="material-symbols-outlined text-[7rem] md:text-[8rem] not-italic" aria-hidden="true">account_circle</i>
              </em>
            <% } %>

            <form action="/perfilprofessor/foto" method="POST" enctype="multipart/form-data">
              <label
                for="foto-professor-hero"
                class="absolute inset-3 rounded-[1.5rem] bg-black/0 group-hover:bg-black/35 flex items-center justify-center cursor-pointer transition-all"
                aria-label="Alterar foto de perfil"
              >
                <strong class="opacity-0 group-hover:opacity-100 bg-white text-primary px-4 py-2 rounded-full font-black text-xs flex items-center gap-2 shadow-xl transition-opacity">
                  <i class="material-symbols-outlined text-lg not-italic" aria-hidden="true">photo_camera</i>
                  Alterar foto
                </strong>
              </label>

              <input
                id="foto-professor-hero"
                name="foto_perfil"
                type="file"
                accept="image/png,image/jpeg,image/webp"
                class="hidden"
                onchange="this.form.submit()"
              />
            </form>

            <figcaption class="absolute -bottom-3 left-1/2 -translate-x-1/2 bg-tertiary-fixed text-on-tertiary-fixed font-black px-4 py-1 rounded-full text-xs tracking-widest uppercase shadow-lg">
              Professor
            </figcaption>
          </figure>

        </section>

        <b class="absolute -right-20 -bottom-20 w-96 h-96 bg-secondary-fixed opacity-10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        <b class="absolute -left-20 -top-20 w-64 h-64 bg-white opacity-5 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
      </article>

      <% if (typeof sucesso !== 'undefined' && sucesso) { %>
        <section class="md:col-span-12 bg-green-50 text-green-700 rounded-3xl p-5 font-bold text-center" role="status">
          <%= sucesso %>
        </section>
      <% } %>

      <% if (typeof erroPerfil !== 'undefined' && erroPerfil) { %>
        <section class="md:col-span-12 bg-red-50 text-error rounded-3xl p-5 font-bold text-center" role="alert">
          <%= erroPerfil %>
        </section>
      <% } %>

      <section class="card-mobile md:col-span-5 bg-surface-container-lowest rounded-3xl p-8 shadow-sm flex flex-col gap-6">

        <header class="flex items-center justify-between">
          <h2 class="text-2xl font-extrabold headline text-on-surface">Dados Profissionais</h2>
          <i class="material-symbols-outlined text-primary text-3xl not-italic" aria-hidden="true">badge</i>
        </header>

        <ul class="flex flex-col gap-4 list-none p-0 m-0">
          <li class="bg-surface-container-low rounded-2xl p-4">
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">Nome</p>
            <p class="font-bold text-on-surface">
              <%= professorSeguro.nome || 'Professor' %>
            </p>
          </li>

          <li class="bg-surface-container-low rounded-2xl p-4">
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">E-mail</p>
            <p class="font-bold text-on-surface break-all">
              <%= professorSeguro.email || 'email@exemplo.com' %>
            </p>
          </li>

          <li class="bg-surface-container-low rounded-2xl p-4">
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">CREF</p>
            <p class="font-bold text-primary">
              <%= professorSeguro.cref || 'Não informado' %>
            </p>
          </li>
        </ul>

