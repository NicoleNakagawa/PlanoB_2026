            "surface-container-lowest": "#ffffff",
            "inverse-surface": "#020a2f",
            "tertiary-container": "#ffd709",
            "on-tertiary-fixed-variant": "#665500",
            "on-primary-container": "#00214e",
            "surface-container-low": "#efefff",
            "secondary": "#00647b",
            "on-primary-fixed-variant": "#002a60",
            "on-secondary-container": "#004e61",
            "on-surface": "#232c51",
            "surface-tint": "#0058ba",
