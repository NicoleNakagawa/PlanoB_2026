<!DOCTYPE html>
<html class="light" lang="pt-BR">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>PlanoB - Feedbacks</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface": "#f7f5ff",
            "primary": "#0058ba",
            "secondary": "#00647b",
            "on-primary": "#f0f2ff",
            "on-surface": "#232c51",
            "on-surface-variant": "#505a81",
            "surface-container-lowest": "#ffffff",
            "surface-container-low": "#efefff",
            "surface-container": "#e4e7ff",
            "surface-container-highest": "#d5dbff",
            "outline": "#6c759e",
            "outline-variant": "#a2abd7",
            "tertiary-fixed": "#ffd709",
            "on-tertiary-fixed": "#453900",
            "error": "#b31b25"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"]
          }
        }
      }
    }
  </script>

  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .logo-header {
      font-size: 2.7rem;
      line-height: 1;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    h4,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    .avatar-placeholder .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    .chat-scroll {
      max-height: 560px;
      overflow-y: auto;
      scroll-behavior: smooth;
    }

    .lista-scroll {
      max-height: 670px;
      overflow-y: auto;
    }

    .chat-scroll::-webkit-scrollbar,
    .lista-scroll::-webkit-scrollbar {
      width: 8px;
    }

    .chat-scroll::-webkit-scrollbar-thumb,
    .lista-scroll::-webkit-scrollbar-thumb {
      background: #a2abd7;
      border-radius: 999px;
    }

    @media (max-width: 768px) {
      html,
      body {
        overflow-x: hidden;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      header.fixed a.logo-header {
        font-size: 1.45rem;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 16px 135px !important;
      }

      article.hero-feedback-prof {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.hero-feedback-prof h1 {
        font-size: 2rem !important;
        line-height: 1.1 !important;
      }

      section.card-mobile,
      article.card-mobile {
        padding: 22px !important;
        border-radius: 26px !important;
      }

      .lista-scroll,
      .chat-scroll {
        max-height: unset;
        overflow-y: visible;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 52px;
        border-radius: 18px;
      }

      nav[aria-label="Navegação mobile"] a[aria-current="page"] {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
      }
    }

    @media (max-width: 420px) {
      main {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }

      nav[aria-label="Navegação mobile"] em {
        font-size: 8px !important;
      }
    }
  </style>
</head>

<body class="bg-surface text-on-surface min-h-screen">

  <%
    const professorSeguro = typeof professor !== 'undefined' && professor ? professor : {}
    const conversasSeguras = typeof conversas !== 'undefined' && conversas ? conversas : []
    const mensagensSeguras = typeof mensagens !== 'undefined' && mensagens ? mensagens : []
    const conversaAtualSegura = typeof conversaAtual !== 'undefined' && conversaAtual ? conversaAtual : null

    const estatisticasSeguras = typeof estatisticas !== 'undefined' && estatisticas ? estatisticas : {
      total_conversas: 0,
      pendentes: 0,
      total_feedbacks: 0,
      total_respostas: 0
    }

    const filtrosSeguros = typeof filtros !== 'undefined' && filtros ? filtros : {
      busca: '',
      status: 'pendentes'
    }

    const erroSeguro = typeof erro !== 'undefined' ? erro : null
    const sucessoSeguro = typeof sucesso !== 'undefined' ? sucesso : null

    function dataFormatada(data) {
      if (!data) return 'Sem data'

      return new Date(data).toLocaleDateString('pt-BR') + ' às ' + new Date(data).toLocaleTimeString('pt-BR', {
        hour: '2-digit',
        minute: '2-digit'
      })
    }

    function dataCurta(data) {
      if (!data) return ''
      return new Date(data).toLocaleDateString('pt-BR')
    }

    function badgePlanoClasse(plano) {
      if (plano === 'Diamante') return 'bg-tertiary-fixed text-on-tertiary-fixed'
      if (plano === 'Lazuli') return 'bg-primary text-white'
      return 'bg-surface-container-highest text-on-surface-variant'
    }

    function intensidadeClasse(valor) {
      if (!valor) return 'bg-surface-container-highest text-on-surface-variant'

      const texto = String(valor).toLowerCase()

      if (texto.includes('alta')) return 'bg-red-50 text-error'
      if (texto.includes('média') || texto.includes('media')) return 'bg-yellow-100 text-yellow-800'

      return 'bg-green-50 text-green-700'
    }
  %>

  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">
    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <a href="/painelprofessor" class="font-headline logo-font logo-header text-primary no-underline">PlanoB</a>
    </nav>

    <form action="/feedbackprofessor" method="GET" class="hidden md:flex items-center bg-surface-container-low px-4 py-2 rounded-full">
      <i class="material-symbols-outlined text-outline text-sm not-italic" aria-hidden="true">search</i>

      <label for="top-search" class="sr-only">Buscar feedback</label>

      <input
        id="top-search"
        name="busca"
        value="<%= filtrosSeguros.busca %>"
        class="bg-transparent border-none focus:ring-0 text-sm w-48 ml-2"
        placeholder="Buscar feedback..."
        type="search"
      />

      <input type="hidden" name="status" value="<%= filtrosSeguros.status %>">
    </form>

    <menu class="flex items-center gap-4 p-0 m-0 list-none">
      <li>
        <a href="/feedbackprofessor" class="relative p-2 rounded-full hover:bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center" aria-label="Feedbacks">
          <i class="material-symbols-outlined text-on-surface not-italic" aria-hidden="true">notifications</i>

          <% if (Number(estatisticasSeguras.pendentes) > 0) { %>
            <span class="absolute -top-1 -right-1 min-w-5 h-5 px-1 rounded-full bg-error text-white text-[10px] font-black flex items-center justify-center">
              <%= estatisticasSeguras.pendentes %>
            </span>
          <% } %>
        </a>
      </li>

      <li>
        <a href="/painelprofessor" class="p-1 rounded-full bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center" aria-label="Perfil do professor">
          <% if (professorSeguro.foto) { %>
            <img src="<%= professorSeguro.foto %>" alt="Foto do professor" class="w-10 h-10 rounded-full object-cover">
          <% } else { %>
            <span class="w-10 h-10 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </span>
          <% } %>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] flex-col gap-2 py-8 z-40 mt-16">
    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <% if (professorSeguro.foto) { %>
          <img class="w-12 h-12 rounded-full object-cover" src="<%= professorSeguro.foto %>" alt="Foto de perfil do professor" />
        <% } else { %>
          <span class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden" aria-label="Professor sem foto">
            <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
          </span>
        <% } %>

        <figcaption>
          <p class="text-sm font-bold text-on-surface">Portal do Professor</p>
          <p class="text-xs text-on-surface-variant">
            <%= professorSeguro.nome ? professorSeguro.nome.split(' ')[0] : 'Bem-vindo' %>
          </p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/painelprofessor">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">dashboard</i>
        <em class="not-italic">Dashboard</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/todosalunos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">groups</i>
        <em class="not-italic">Meus Alunos</em>
      </a>

      <a class="text-[#232c51] hover:bg-[#d5dbff]/50 rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/todosvideos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">video_library</i>
        <em class="not-italic">Meus Vídeos</em>
      </a>

      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="/feedbackprofessor" aria-current="page">
        <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">forum</i>
        <em class="not-italic">Feedbacks</em>
      </a>
    </nav>

    <footer class="mt-auto px-4 pb-8 flex flex-col gap-2">
      <a href="#responder-feedback" class="w-full bg-primary text-on-primary rounded-full py-4 font-bold shadow-lg shadow-primary/30 flex items-center justify-center gap-2 active:scale-95 transition-transform">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">reply</i>
        Responder
      </a>

      <a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:text-error rounded-full hover:bg-surface-container transition-colors text-sm" href="/logout">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">logout</i>
        <em class="not-italic">Sair</em>
      </a>
    </footer>
  </aside>

  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <article class="hero-feedback-prof md:col-span-12 relative overflow-hidden rounded-3xl bg-primary p-8 md:p-12 text-white shadow-2xl">
        <section class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
          <hgroup class="max-w-2xl">
            <mark class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md text-xs font-bold uppercase tracking-widest mb-4 text-white">
              Central de Feedbacks
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              FEEDBACKS.
            </h1>

            <p class="text-lg opacity-90 max-w-xl">
              Acompanhe as mensagens dos alunos, analise intensidade, cansaço e responda diretamente por aqui.
            </p>
          </hgroup>

          <figure class="flex flex-col items-center gap-4 bg-white/10 backdrop-blur-xl p-6 md:p-8 rounded-3xl border border-white/10 w-full max-w-[240px] mx-auto md:mx-0 md:w-auto m-0">
            <span class="w-28 h-28 rounded-full bg-white/15 flex items-center justify-center">
              <i class="material-symbols-outlined text-white text-7xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">forum</i>
            </span>

            <figcaption class="text-sm font-black uppercase tracking-widest text-center">
              <%= estatisticasSeguras.pendentes %> pendentes
            </figcaption>
          </figure>
        </section>
      </article>

      <% if (erroSeguro) { %>
        <section class="md:col-span-12 bg-red-50 text-error rounded-3xl p-5 font-bold text-center" role="alert">
          <%= erroSeguro %>
        </section>
      <% } %>

      <% if (sucessoSeguro) { %>
        <section class="md:col-span-12 bg-green-50 text-green-700 rounded-3xl p-5 font-bold text-center" role="status">
          <%= sucessoSeguro %>
        </section>
      <% } %>

      <section class="md:col-span-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-6 shadow-sm flex items-center gap-4">
          <figure class="w-14 h-14 rounded-2xl bg-primary/10 text-primary flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">mark_unread_chat_alt</i>
          </figure>

          <section>
            <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Pendentes</p>
            <strong class="text-3xl font-black headline text-on-surface"><%= estatisticasSeguras.pendentes || 0 %></strong>
          </section>
        </article>

        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-6 shadow-sm flex items-center gap-4">
          <figure class="w-14 h-14 rounded-2xl bg-secondary/10 text-secondary flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">chat</i>
          </figure>

          <section>
            <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Conversas</p>
            <strong class="text-3xl font-black headline text-on-surface"><%= estatisticasSeguras.total_conversas || 0 %></strong>
          </section>
        </article>

        <article class="card-mobile bg-surface-container-lowest rounded-3xl p-6 shadow-sm flex items-center gap-4">
          <figure class="w-14 h-14 rounded-2xl bg-tertiary-fixed/20 text-on-tertiary-fixed flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">rate_review</i>
          </figure>

          <section>
            <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Feedbacks</p>
            <strong class="text-3xl font-black headline text-on-surface"><%= estatisticasSeguras.total_feedbacks || 0 %></strong>
          </section>
        </article>

        <article class="card-mobile bg-primary rounded-3xl p-6 shadow-xl shadow-primary/20 flex items-center gap-4 text-white">
          <figure class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center m-0">
            <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">reply_all</i>
          </figure>

          <section>
            <p class="text-xs font-black uppercase tracking-widest text-white/70">Respostas</p>
            <strong class="text-3xl font-black headline text-white"><%= estatisticasSeguras.total_respostas || 0 %></strong>
          </section>
        </article>
      </section>

      <section class="card-mobile md:col-span-12 bg-surface-container-lowest rounded-3xl p-8 shadow-sm">
        <header class="flex flex-col lg:flex-row lg:items-center justify-between gap-4">
          <hgroup>
            <h2 class="text-2xl font-extrabold headline text-on-surface">Filtrar feedbacks</h2>
            <p class="text-sm text-on-surface-variant mt-1">
              Busque por aluno, e-mail ou conteúdo da mensagem.
            </p>
          </hgroup>

          <form action="/feedbackprofessor" method="GET" class="flex flex-col md:flex-row gap-3 w-full lg:w-auto">
            <input
              name="busca"
              value="<%= filtrosSeguros.busca %>"
              type="search"
              placeholder="Buscar feedback"
              class="rounded-full border-none bg-surface-container-low px-5 py-3 focus:ring-2 focus:ring-primary min-w-[240px]"
            />

            <select name="status" class="rounded-full border-none bg-surface-container-low px-5 py-3 focus:ring-2 focus:ring-primary">
              <option value="pendentes" <%= filtrosSeguros.status === 'pendentes' ? 'selected' : '' %>>Pendentes</option>
              <option value="respondidos" <%= filtrosSeguros.status === 'respondidos' ? 'selected' : '' %>>Respondidos</option>
              <option value="todos" <%= filtrosSeguros.status === 'todos' ? 'selected' : '' %>>Todos</option>
            </select>

            <button type="submit" class="bg-primary text-white rounded-full px-6 py-3 font-bold active:scale-95 transition-transform">
              Filtrar
            </button>
          </form>
        </header>
      </section>

      <section class="md:col-span-5 card-mobile bg-surface-container-low rounded-3xl p-6 shadow-sm">
        <header class="mb-5">
          <h2 class="text-2xl font-extrabold headline text-on-surface">Conversas</h2>
          <p class="text-sm text-on-surface-variant mt-1">
            Selecione um aluno para ver o histórico.
          </p>
        </header>

        <% if (conversasSeguras.length > 0) { %>
          <section class="lista-scroll flex flex-col gap-3 pr-1">
            <% conversasSeguras.forEach(function(conversa) { %>
              <a
                href="/feedbackprofessor?aluno=<%= conversa.id_aluno %>&status=<%= filtrosSeguros.status %>&busca=<%= encodeURIComponent(filtrosSeguros.busca || '') %>"
                class="block rounded-3xl p-4 transition-all <%= conversaAtualSegura && conversaAtualSegura.id_aluno === conversa.id_aluno ? 'bg-primary text-white shadow-lg shadow-primary/20' : 'bg-surface-container-lowest hover:bg-surface-container-highest text-on-surface' %>"
              >
                <article class="flex items-start gap-3">
                  <figure class="w-12 h-12 rounded-2xl overflow-hidden m-0 avatar-placeholder flex items-center justify-center shrink-0">
                    <% if (conversa.foto_perfil) { %>
                      <img src="<%= conversa.foto_perfil %>" alt="Foto de <%= conversa.aluno_nome %>" class="w-full h-full object-cover">
                    <% } else { %>
                      <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
                    <% } %>
                  </figure>

                  <section class="min-w-0 flex-1">
                    <header class="flex items-start justify-between gap-3">
                      <h3 class="font-black truncate"><%= conversa.aluno_nome %></h3>

                      <% if (Number(conversa.mensagens_pendentes) > 0) { %>
                        <span class="min-w-6 h-6 px-2 rounded-full bg-error text-white text-xs font-black flex items-center justify-center">
                          <%= conversa.mensagens_pendentes %>
                        </span>
                      <% } %>
                    </header>

                    <p class="<%= conversaAtualSegura && conversaAtualSegura.id_aluno === conversa.id_aluno ? 'text-white/75' : 'text-on-surface-variant' %> text-xs truncate mt-1">
                      <%= conversa.ultima_mensagem || 'Sem mensagem' %>
                    </p>

                    <footer class="flex items-center justify-between gap-2 mt-3">
                      <strong class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= conversaAtualSegura && conversaAtualSegura.id_aluno === conversa.id_aluno ? 'bg-white/20 text-white' : badgePlanoClasse(conversa.plano) %>">
                        <%= conversa.plano || 'Plano' %>
                      </strong>

                      <time class="<%= conversaAtualSegura && conversaAtualSegura.id_aluno === conversa.id_aluno ? 'text-white/70' : 'text-on-surface-variant' %> text-[10px] font-bold">
                        <%= dataCurta(conversa.ultima_data) %>
                      </time>
                    </footer>
                  </section>
                </article>
              </a>
            <% }) %>
          </section>
        <% } else { %>
          <section class="bg-surface-container-lowest rounded-3xl p-8 text-center">
            <i class="material-symbols-outlined text-primary text-6xl not-italic mb-3" aria-hidden="true">forum</i>
            <h3 class="text-xl font-black headline">Nenhum feedback encontrado</h3>
            <p class="text-sm text-on-surface-variant mt-2">
              Quando um aluno enviar feedback, ele aparecerá aqui.
            </p>
          </section>
        <% } %>
      </section>

      <section class="md:col-span-7 card-mobile bg-surface-container-lowest rounded-3xl p-6 shadow-sm flex flex-col">
        <% if (conversaAtualSegura) { %>
          <header class="flex items-center justify-between gap-4 pb-5 border-b border-surface-container">
            <article class="flex items-center gap-3 min-w-0">
              <figure class="w-14 h-14 rounded-2xl overflow-hidden m-0 avatar-placeholder flex items-center justify-center shrink-0">
                <% if (conversaAtualSegura.foto_perfil) { %>
                  <img src="<%= conversaAtualSegura.foto_perfil %>" alt="Foto de <%= conversaAtualSegura.aluno_nome %>" class="w-full h-full object-cover">
                <% } else { %>
                  <i class="material-symbols-outlined text-5xl not-italic" aria-hidden="true">account_circle</i>
                <% } %>
              </figure>

              <hgroup class="min-w-0">
                <h2 class="text-xl font-black headline truncate"><%= conversaAtualSegura.aluno_nome %></h2>
                <p class="text-sm text-on-surface-variant truncate"><%= conversaAtualSegura.aluno_email %></p>
              </hgroup>
            </article>

            <strong class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= badgePlanoClasse(conversaAtualSegura.plano) %>">
              <%= conversaAtualSegura.plano || 'Plano' %>
            </strong>
          </header>

          <section id="chat-area" class="chat-scroll py-6 flex flex-col gap-4">
            <% mensagensSeguras.forEach(function(msg) { %>
              <% const isProfessor = msg.remetente === 'professor' %>

              <article class="flex <%= isProfessor ? 'justify-end' : 'justify-start' %>">
                <section class="max-w-[85%] rounded-3xl px-5 py-4 <%= isProfessor ? 'bg-primary text-white rounded-br-md' : 'bg-surface-container-low text-on-surface rounded-bl-md' %>">
                  <header class="flex flex-wrap items-center gap-2 mb-2">
                    <strong class="text-xs uppercase tracking-widest">
                      <%= isProfessor ? 'Você' : conversaAtualSegura.aluno_nome %>
                    </strong>

                    <time class="<%= isProfessor ? 'text-white/70' : 'text-on-surface-variant' %> text-[10px] font-bold">
                      <%= dataFormatada(msg.enviado_em) %>
                    </time>
                  </header>

                  <p class="text-sm leading-relaxed whitespace-pre-wrap"><%= msg.texto %></p>

                  <% if (!isProfessor && (msg.intensidade || msg.nivel_cansaco)) { %>
                    <footer class="flex flex-wrap gap-2 mt-3">
                      <% if (msg.intensidade) { %>
                        <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest <%= intensidadeClasse(msg.intensidade) %>">
                          Intensidade: <%= msg.intensidade %>
                        </span>
                      <% } %>

                      <% if (msg.nivel_cansaco) { %>
                        <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-surface-container-highest text-on-surface-variant">
                          Cansaço: <%= msg.nivel_cansaco %>/10
                        </span>
                      <% } %>
                    </footer>
                  <% } %>
                </section>
              </article>
            <% }) %>
          </section>

          <form id="responder-feedback" action="/feedbackresposta" method="POST" class="pt-5 border-t border-surface-container">
            <input type="hidden" name="id-aluno" value="<%= conversaAtualSegura.id_aluno %>">

            <label for="resposta" class="sr-only">Resposta ao aluno</label>

            <section class="bg-surface-container-low rounded-3xl p-3 flex flex-col gap-3">
              <textarea
                id="resposta"
                name="resposta"
                rows="4"
                required
                placeholder="Escreva uma resposta para o aluno..."
                class="w-full bg-transparent border-none focus:ring-0 resize-none text-sm"
              ></textarea>

              <footer class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
                <p class="text-xs text-on-surface-variant px-2">
                  Sua resposta ficará registrada no histórico do aluno.
                </p>

                <button type="submit" class="bg-primary text-white rounded-full px-8 py-3 font-black shadow-lg shadow-primary/20 active:scale-95 transition-transform inline-flex items-center justify-center gap-2">
                  Enviar resposta
                  <i class="material-symbols-outlined not-italic" aria-hidden="true">send</i>
                </button>
              </footer>
            </section>
          </form>
        <% } else { %>
          <section class="min-h-[520px] flex flex-col items-center justify-center text-center">
            <i class="material-symbols-outlined text-primary text-7xl not-italic mb-4" aria-hidden="true">forum</i>
            <h2 class="text-2xl font-black headline text-on-surface">Nenhuma conversa selecionada</h2>
            <p class="text-on-surface-variant max-w-md mt-2">
              Selecione uma conversa ao lado para visualizar o histórico de feedback e responder o aluno.
            </p>
          </section>
        <% } %>
      </section>

    </section>
  </main>

  <nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex justify-around items-end px-4 pb-6 pt-2 bg-[#f7f5ff]/90 backdrop-blur-lg shadow-[0_-10px_40px_rgba(35,44,81,0.08)] rounded-t-[32px]" aria-label="Navegação mobile">
    <a href="/painelprofessor" class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">dashboard</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Início</em>
    </a>

    <a href="/todosalunos" class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">groups</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Alunos</em>
    </a>

    <a href="#responder-feedback" class="bg-primary text-white w-14 h-14 rounded-full shadow-lg shadow-primary/40 -mt-8 flex items-center justify-center active:scale-95 transition-transform" aria-label="Responder feedback">
      <i class="material-symbols-outlined text-3xl not-italic" aria-hidden="true">reply</i>
    </a>

    <a href="/todosvideos" class="flex flex-col items-center justify-center text-[#232c51] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">video_library</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Vídeos</em>
    </a>

    <a href="/feedbackprofessor" class="flex flex-col items-center justify-center text-[#0058ba] opacity-100 p-3 rounded-[18px] bg-[#d5dbff]" aria-current="page">
      <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">forum</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Feedback</em>
    </a>
  </nav>

  <script>
    const chatArea = document.getElementById('chat-area')

    if (chatArea) {
      chatArea.scrollTop = chatArea.scrollHeight
    }
  </script>

</body>
</html>