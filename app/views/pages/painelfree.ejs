  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .logo-header {
      font-size: 2.7rem;
      line-height: 1;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    .avatar-placeholder .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    .video-card-link {
      color: inherit;
      text-decoration: none;
      display: flex;
      width: 100%;
      height: 100%;
    }

    @media (max-width: 768px) {
      html,
      body {
        width: 100%;
        overflow-x: hidden;
      }

      body {
        background: #f7f5ff;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      header.fixed strong.logo-header {
        font-size: 1.45rem;
        line-height: 1;
      }

      header.fixed menu {
        gap: 8px;
      }

      header.fixed button,
      header.fixed a {
        padding: 8px;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 16px 135px !important;
      }

      main section.max-w-6xl {
        gap: 18px;
      }

      article.md\:col-span-12 {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.md\:col-span-12 section {
        align-items: flex-start !important;
        gap: 28px !important;
      }

      article.md\:col-span-12 h1 {
        font-size: 2rem !important;
        line-height: 1.1 !important;
        margin-left: 0 !important;
      }

      article.md\:col-span-12 p {
        font-size: 0.95rem !important;
      }

      article.md\:col-span-12 mark {
        font-size: 0.65rem !important;
        padding: 6px 12px !important;
      }

      article.md\:col-span-12 figure {
        max-width: 220px;
        width: 100% !important;
        margin: 0 auto !important;
        padding: 20px !important;
      }

      article.md\:col-span-12 svg {
        width: 112px !important;
        height: 112px !important;
        overflow: visible;
      }

      section.md\:col-span-5 article {
        padding: 24px !important;
        border-radius: 26px !important;
      }

      section.md\:col-span-5 h2 {
        font-size: 1.35rem !important;
      }

      section.md\:col-span-5 strong {
        font-size: 2.6rem !important;
      }

      section.md\:col-span-7 {
        padding: 22px !important;
        border-radius: 26px !important;
      }

      section.md\:col-span-7 > header {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
      }

      section.md\:col-span-7 h2 {
        font-size: 1.35rem !important;
      }

      section.md\:col-span-7 li {
        height: auto !important;
        min-height: 115px;
      }

      section.md\:col-span-7 figure {
        width: 115px !important;
      }

      section.md\:col-span-7 h3 {
        font-size: 0.95rem;
        line-height: 1.2;
      }

      section.md\:col-span-7 p {
        font-size: 0.72rem;
      }

      section.md\:col-span-12.mt-8 {
        margin-top: 20px !important;
      }

      section.md\:col-span-12.mt-8 > h2 {
        font-size: 1.65rem !important;
        line-height: 1.15 !important;
        margin-bottom: 22px !important;
      }

      section.md\:col-span-12 li {
        padding: 24px !important;
        border-radius: 28px !important;
      }

      section.md\:col-span-12 li p.text-4xl {
        font-size: 2rem !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 64px;
        border-radius: 18px;
      }

      nav[aria-label="Navegação mobile"] a[aria-current="page"] {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
      }

      nav[aria-label="Navegação mobile"] a:hover {
        color: #0058ba !important;
        opacity: 1 !important;
      }
    }

    @media (max-width: 420px) {
      main {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }

      article.md\:col-span-12 h1 {
        font-size: 1.75rem !important;
      }

      section.md\:col-span-7 figure {
        width: 95px !important;
      }

      section.md\:col-span-7 hgroup {
        padding: 12px !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding-left: 6px !important;
        padding-right: 6px !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 58px;
        padding: 10px 6px !important;
      }

      nav[aria-label="Navegação mobile"] em {
        font-size: 8px !important;
      }
    }
  </style>
</head>

<body class="bg-surface text-on-surface">

  <!-- Header -->
  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">

    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <strong class="font-headline logo-font logo-header text-primary">PlanoB</strong>
    </nav>

    <menu class="flex items-center gap-4 p-0 m-0">
      <li>
        <button class="p-2 rounded-full hover:bg-surface-container transition-colors active:scale-95" aria-label="Notificações">
          <i class="material-symbols-outlined text-on-background not-italic" aria-hidden="true">notifications</i>
        </button>
      </li>

      <li>
        <a href="/perfilaluno"
          class="p-2 rounded-full hover:bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center"
          aria-label="Perfil">
          <i class="material-symbols-outlined text-on-background not-italic" aria-hidden="true">account_circle</i>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <!-- Sidebar Desktop -->
  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] dark:bg-[#12141c] flex-col gap-2 py-8 z-40 mt-16">

    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <picture>
          <% if (typeof aluno !== 'undefined' && aluno.foto) { %>
            <img
              class="w-12 h-12 rounded-full object-cover"
              src="<%= aluno.foto %>"
              alt="Foto de perfil do aluno"
            />
          <% } else { %>
            <span class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden" aria-label="Aluno sem foto">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </span>
          <% } %>
        </picture>

        <figcaption>
          <p class="text-sm font-bold text-on-surface">Portal do Aluno</p>
          <p class="text-xs text-on-surface-variant">Bem-vindo de volta</p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="/painelfree" aria-current="page">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">fitness_center</i>
        <em class="not-italic">início</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/videosfree">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">play_circle</i>
        <em class="not-italic">Vídeos</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="#planos">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">payments</i>
        <em class="not-italic">Planos</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/perfilaluno">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">person</i>
        <em class="not-italic">Perfil</em>
      </a>
    </nav>

  </aside>

  <!-- Main -->
  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <!-- Hero -->
      <article class="md:col-span-12 relative overflow-hidden rounded-3xl bg-primary p-8 md:p-12 text-white shadow-2xl">

        <section class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">

          <hgroup class="max-w-xl">
            <mark class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md text-xs font-bold uppercase tracking-widest mb-4 text-white">
              Teste Gratuito Ativo
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              SUA JORNADA ESTÁ APENAS COMEÇANDO.
            </h1>

            <p class="text-lg opacity-90 max-w-md">
              Você está aproveitando o poder do PlanoB. Mantenha o ritmo para transformar seu corpo e mente.
            </p>
          </hgroup>

          <figure class="flex flex-col items-center gap-4 bg-white/10 backdrop-blur-xl p-6 md:p-8 rounded-3xl border border-white/10 w-full max-w-[220px] mx-auto md:mx-0 md:w-auto m-0">
            <svg
              class="w-28 h-28 md:w-32 md:h-32 -rotate-90 overflow-visible"
              viewBox="0 0 128 128"
              fill="none"
              role="img"
              aria-label="6 de 7 dias restantes"
            >
              <circle
                class="text-white/20"
                cx="64"
                cy="64"
                r="54"
                stroke="currentColor"
                stroke-width="8"
              />

              <circle
                class="text-white"
                cx="64"
                cy="64"
                r="54"
                stroke="currentColor"
                stroke-width="8"
                stroke-linecap="round"
                stroke-dasharray="339.3"
                stroke-dashoffset="48.5"
              />

              <text
                x="64"
                y="58"
                text-anchor="middle"
                dominant-baseline="middle"
                fill="white"
                font-size="28"
                font-weight="900"
                font-family="Lexend"
                transform="rotate(90, 64, 64)"
              >
                6
              </text>

              <text
                x="64"
                y="76"
                text-anchor="middle"
                dominant-baseline="middle"
                fill="white"
                font-size="8"
                font-weight="700"
                font-family="Manrope"
                letter-spacing="1"
                transform="rotate(90, 64, 64)"
              >
                DIAS RESTANTES
              </text>
            </svg>

            <p class="text-sm font-medium opacity-80 italic text-center">de 7 dias totais</p>
          </figure>

        </section>

        <b class="absolute -right-20 -bottom-20 w-96 h-96 bg-secondary-fixed opacity-10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        <b class="absolute -left-20 -top-20 w-64 h-64 bg-white opacity-5 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
      </article>

      <!-- Avisos -->
      <section class="md:col-span-5 flex flex-col gap-6">

        <article class="bg-surface-container-lowest rounded-3xl p-8 shadow-sm flex flex-col gap-6 relative overflow-hidden">
          <i class="material-symbols-outlined text-error text-4xl opacity-20 not-italic absolute top-0 right-0 p-4" aria-hidden="true">warning</i>

          <hgroup class="flex flex-col gap-2">
            <h2 class="text-2xl font-extrabold headline text-on-surface">Aviso de Encerramento</h2>
            <p class="text-on-surface-variant leading-relaxed">
              Seu acesso gratuito expira em breve. Após este período, suas métricas e planos personalizados ficarão bloqueados.
            </p>
          </hgroup>

          <a href="/painelfree#planos" class="w-full bg-primary text-white py-4 rounded-full font-bold shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all text-center">
            Fazer Upgrade
          </a>
        </article>

        <article class="bg-surface-container rounded-3xl p-8 flex flex-col gap-4">
          <p class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">Próximo Acesso Gratuito</p>

          <p class="flex items-end gap-2">
            <strong class="text-5xl font-black text-primary">06</strong>
            <em class="text-xl font-bold text-on-surface-variant mb-1 not-italic">Meses</em>
          </p>

          <p class="text-xs text-on-surface-variant italic">
            Os benefícios do plano gratuito são renovados semestralmente.
          </p>
        </article>

      </section>

      <!-- Vídeos -->
      <section class="md:col-span-7 bg-surface-container-low rounded-3xl p-8 flex flex-col gap-6">

        <header class="flex items-center justify-between">
          <h2 class="text-2xl font-extrabold headline text-on-surface">Vídeos Demonstrativos</h2>

          <mark class="px-3 py-1 bg-surface-container-highest rounded-full text-[10px] font-bold uppercase text-on-surface-variant">
            3 de 15 liberados
          </mark>
        </header>

        <ul role="list" class="grid grid-cols-1 gap-4 list-none p-0 m-0">

          <li class="group relative rounded-2xl overflow-hidden bg-surface-container-lowest h-32 flex items-center cursor-pointer transition-transform hover:scale-[1.01]">
            <a href="/execucaoexercicios?video=agachamento" class="video-card-link">
              <figure class="w-40 h-full relative m-0 shrink-0">
                <img
                  class="w-full h-full object-cover"
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuDo-fkwrI2vN175z62Qq2gtPN-gdAd45gJquHcF0ZyrskfDFnSeAOf9qOhdizqb5DBMp13lLNffweE1YO5GUZ3viG9nx3MFst660mShuHltw7_RvBzPduY5hMovRZvbapvnBuzg-XYEdMKaWK9kN3V28Y2an46LQ9E2pTycTtnHgEHfZDIpEX568pGUlfrSTwT46rRNZXGn9VgpeNGF0sq_dR0rO3fExyys5u2-rmWN5MnFUS8r-kbm68aDMtPi_IV3RtycExLYFKWZ"
                  alt="Demonstração de agachamento"
                />

                <figcaption class="absolute inset-0 bg-primary/20 flex items-center justify-center">
                  <i class="material-symbols-outlined text-white text-3xl not-italic" aria-hidden="true">play_circle</i>
                </figcaption>
              </figure>

              <hgroup class="p-4 flex-1">
                <h3 class="font-bold text-on-surface">Fundamentos do Agachamento</h3>
                <p class="text-xs text-on-surface-variant">Duração: 08:45 • Nível Iniciante</p>
              </hgroup>
            </a>
          </li>

          <li class="group relative rounded-2xl overflow-hidden bg-surface-container-lowest h-32 flex items-center cursor-pointer transition-transform hover:scale-[1.01]">
            <a href="/execucaoexercicios?video=cardio-10-minutos" class="video-card-link">
              <figure class="w-40 h-full relative m-0 shrink-0">
                <img
                  class="w-full h-full object-cover"
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuCjgvCFuIJdPrEMcolFmqhwO_PBewj-gbMz37PihA1HWzsWFP_PbNVgEQTi-OeHMr7imOcIebYDzZmlos5ZFu7gEVZT3Buue-qMWf6VjoNywEnrFfQ20PLGYKk5BGVGdoZXdmuIih5JJ2QtUgPlv-u4civPcntZgkgLa9-FRldHUsj0GNPdUsylv_RvoleCGxb3cF1wLrpG25h-zBmU7-tH4g7XcRjP7udlVDOvPOg9HAdXhy56YsgnyQ0sKyrhfUjXrZ09Q9YiKkci"
                  alt="Pessoa realizando cardio"
                />

                <figcaption class="absolute inset-0 bg-primary/20 flex items-center justify-center">
                  <i class="material-symbols-outlined text-white text-3xl not-italic" aria-hidden="true">play_circle</i>
                </figcaption>
              </figure>

              <hgroup class="p-4 flex-1">
                <h3 class="font-bold text-on-surface">Cardio de 10 minutos</h3>
                <p class="text-xs text-on-surface-variant">Duração: 10:00 • Nível Iniciante</p>
              </hgroup>
            </a>
          </li>

          <li class="group relative rounded-2xl overflow-hidden bg-surface-container-lowest h-32 flex items-center cursor-pointer transition-transform hover:scale-[1.01]">
            <a href="/execucaoexercicios?video=mobilidade-basica" class="video-card-link">
              <figure class="w-40 h-full relative m-0 shrink-0">
                <img
                  class="w-full h-full object-cover"
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuBznhSUh7EuakqvmDPkaRGFV73qpdMbNqGjupfUsEPKslvaPKPMxVzKR_aJSFaeMmJ_2d5spIjxtp5u6OmeUgVi0r8nBTmiwTS-deyShfHpHjhV71lKrBcpzjbcUls7bAzawG7bYq2Ny5cObCsJIBmy3FaAdg6ZAEB6_V53u32BKizMc-hpx1CT3d27UQtgZG10Y50ZAGOHXFsnmw77CfTeEA0B52gG80kv8UZ6XLGwFN6NJyiZfTjlCYOxW-Wd42UbAXl_sBOxS3w5"
                  alt="Pessoa realizando mobilidade"
                />

                <figcaption class="absolute inset-0 bg-primary/20 flex items-center justify-center">
                  <i class="material-symbols-outlined text-white text-3xl not-italic" aria-hidden="true">play_circle</i>
                </figcaption>
              </figure>

              <hgroup class="p-4 flex-1">
                <h3 class="font-bold text-on-surface">Mobilidade Básica</h3>
                <p class="text-xs text-on-surface-variant">Duração: 12:30 • Nível Iniciante</p>
              </hgroup>
            </a>
          </li>

        </ul>

        <a href="/videosfree" class="mt-2 text-primary font-bold text-sm flex items-center gap-2 hover:translate-x-1 transition-transform">
          Ver todos os vídeos demonstrativos
          <i class="material-symbols-outlined not-italic" aria-hidden="true">arrow_forward</i>
        </a>

      </section>

      <!-- Planos -->
      <section id="planos" class="md:col-span-12 mt-8 scroll-mt-24">

        <h2 class="text-3xl font-black headline text-on-surface mb-8">
          NÃO PARE AGORA. ESCOLHA SEU PRÓXIMO NÍVEL.
        </h2>

        <ul class="grid grid-cols-1 md:grid-cols-3 gap-6 list-none p-0 m-0" role="list" aria-label="Planos disponíveis">

          <li class="bg-surface-container-low rounded-[2rem] p-8 flex flex-col gap-6">
