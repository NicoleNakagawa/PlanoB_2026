<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PlanoB - Feedback do Treino</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "primary-dim": "#004da4",
            "primary-container": "#6c9fff",
            "error-container": "#fb5151",
            "on-primary-fixed-variant": "#002a60",
            "error-dim": "#9f0519",
            "surface-dim": "#cad2ff",
            "surface-variant": "#d5dbff",
            "inverse-on-surface": "#929bc6",
            "error": "#b31b25",
            "surface-container-lowest": "#ffffff",
            "on-background": "#232c51",
            "primary": "#0058ba",
            "on-tertiary-fixed": "#453900",
            "on-tertiary": "#fff2cd",
            "secondary-dim": "#00576c",
            "outline": "#6c759e",
            "on-secondary": "#e2f6ff",
            "tertiary-fixed-dim": "#efc900",
            "surface-tint": "#0058ba",
            "on-primary": "#f0f2ff",
            "secondary": "#00647b",
            "on-error-container": "#570008",
            "inverse-primary": "#4a8eff",
            "surface-container-low": "#efefff",
            "on-secondary-container": "#004e61",
            "on-secondary-fixed": "#003a48",
            "surface-bright": "#f7f5ff",
            "primary-fixed": "#6c9fff",
            "tertiary-fixed": "#ffd709",
            "tertiary-container": "#ffd709",
            "inverse-surface": "#020a2f",
            "on-tertiary-fixed-variant": "#665500",
            "on-secondary-fixed-variant": "#00586d",
            "on-primary-fixed": "#000000",
            "secondary-fixed-dim": "#37d4ff",
            "outline-variant": "#a2abd7",
            "tertiary-dim": "#5e4e00",
            "on-surface": "#232c51",
            "surface-container-high": "#dde1ff",
            "background": "#f7f5ff",
            "tertiary": "#6c5a00",
            "primary-fixed-dim": "#5091ff",
            "on-tertiary-container": "#5b4b00",
            "on-primary-container": "#00214e",
            "surface-container-highest": "#d5dbff",
            "surface": "#f7f5ff",
            "on-error": "#ffefee",
            "surface-container": "#e4e7ff",
            "on-surface-variant": "#505a81",
            "secondary-fixed": "#80deff",
            "secondary-container": "#80deff",
          },
          borderRadius: {
            DEFAULT: "0.25rem",
            lg: "0.5rem",
            xl: "0.75rem",
            full: "9999px",
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"],
            label: ["Manrope"],
          },
        },
      },
    };
  </script>
  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    body { font-family: 'Manrope', sans-serif; }
    h1, h2, h3 { font-family: 'Lexend', sans-serif; }
  </style>
</head>

<body class="bg-surface text-on-surface min-h-screen pb-24 md:pb-0">

  <!-- ===== Top App Bar ===== -->
  <header class="bg-[#f7f5ff]/80 dark:bg-slate-950/80 backdrop-blur-xl fixed top-0 w-full z-50">
    <nav class="flex justify-between items-center px-6 py-4 w-full max-w-screen-2xl mx-auto relative" aria-label="Navegação principal">

      <a href="#" aria-label="PlanoB – Início">
        <strong class="text-2xl font-black text-blue-700 dark:text-blue-400 italic font-['Lexend'] tracking-tight">PlanoB</strong>
      </a>

      <menu class="hidden md:flex items-center gap-8 list-none p-0 m-0">
        <li><a class="text-slate-600 dark:text-slate-400 hover:text-blue-500 transition-colors font-['Manrope'] font-semibold uppercase tracking-wider text-xs" href="#">Treino</a></li>
        <li><a class="text-blue-700 dark:text-blue-400 font-bold hover:text-blue-500 transition-colors font-['Manrope'] font-semibold uppercase tracking-wider text-xs" href="#" aria-current="page">Feedback</a></li>
        <li><a class="text-slate-600 dark:text-slate-400 hover:text-blue-500 transition-colors font-['Manrope'] font-semibold uppercase tracking-wider text-xs" href="#">Métricas</a></li>
        <li><a class="text-slate-600 dark:text-slate-400 hover:text-blue-500 transition-colors font-['Manrope'] font-semibold uppercase tracking-wider text-xs" href="#">Perfil</a></li>
      </menu>

      <aside class="flex items-center gap-3">
        <button class="p-2 text-on-surface-variant hover:bg-surface-container rounded-full transition-colors" aria-label="Notificações">
          <i class="material-symbols-outlined" aria-hidden="true">notifications</i>
        </button>
        <button class="p-2 text-on-surface-variant hover:bg-surface-container rounded-full transition-colors" aria-label="Conta">
          <i class="material-symbols-outlined" aria-hidden="true">account_circle</i>
        </button>
      </aside>

      <hr class="bg-gradient-to-r from-blue-600/10 to-transparent h-[1px] w-full absolute bottom-0 left-0 border-0" aria-hidden="true" />
    </nav>
  </header>

  <!-- ===== Main Content ===== -->
  <main class="pt-24 pb-12 px-6 max-w-4xl mx-auto">

    <!-- Hero Header -->
    <section class="mb-12 relative" aria-labelledby="hero-title">
      <aside class="absolute -top-10 -left-10 w-48 h-48 bg-primary/5 rounded-full blur-3xl" aria-hidden="true"></aside>
      <h1 id="hero-title" class="text-4xl md:text-5xl font-black text-on-surface leading-tight tracking-tighter mb-4">
        Como foi seu <em class="text-primary italic">treino hoje?</em>
      </h1>
      <p class="text-on-surface-variant text-lg max-w-xl">
        Sua percepção é fundamental para ajustarmos sua evolução. Leva menos de 1 minuto!
      </p>
    </section>

    <!-- Feedback Form -->
    <form class="space-y-8" novalidate>

      <!-- 01 · Intensity Selector -->
      <article class="bg-surface-container-lowest p-8 rounded-[32px] shadow-[0_-8px_30px_rgb(0,0,0,0.02)] relative overflow-hidden" aria-labelledby="intensity-title">
        <aside class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-bl-[100px]" aria-hidden="true"></aside>

        <h2 id="intensity-title" class="text-xl font-bold mb-8 flex items-center gap-2">
          <mark class="w-8 h-8 rounded-full bg-primary/10 text-primary flex items-center justify-center text-sm">01</mark>
          Qual foi a intensidade do esforço?
        </h2>

        <fieldset>
          <legend class="sr-only">Intensidade do esforço</legend>
          <ol class="grid grid-cols-5 gap-4 list-none p-0 m-0">
            <li>
              <label class="flex flex-col items-center gap-3 p-4 rounded-3xl hover:bg-surface-container transition-all group cursor-pointer">
                <input type="radio" name="intensity" value="leve" class="sr-only" />
                <b class="text-4xl group-hover:scale-110 transition-transform">😅</b>
                <b class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">Leve</b>
              </label>
            </li>
            <li>
              <label class="flex flex-col items-center gap-3 p-4 rounded-3xl hover:bg-surface-container transition-all group cursor-pointer">
                <input type="radio" name="intensity" value="moderado" class="sr-only" />
                <b class="text-4xl group-hover:scale-110 transition-transform">😊</b>
                <b class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">Moderado</b>
              </label>
            </li>
            <li>
              <label class="flex flex-col items-center gap-3 p-4 rounded-3xl bg-primary text-white shadow-xl shadow-primary/30 transform scale-105 transition-all cursor-pointer">
                <input type="radio" name="intensity" value="intenso" class="sr-only" checked />
                <b class="text-4xl">🔥</b>
                <b class="text-[10px] font-bold uppercase tracking-widest">Intenso</b>
              </label>
            </li>
            <li>
              <label class="flex flex-col items-center gap-3 p-4 rounded-3xl hover:bg-surface-container transition-all group cursor-pointer">
                <input type="radio" name="intensity" value="pesado" class="sr-only" />
                <b class="text-4xl group-hover:scale-110 transition-transform">🥵</b>
                <b class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">Pesado</b>
              </label>
            </li>
            <li>
              <label class="flex flex-col items-center gap-3 p-4 rounded-3xl hover:bg-surface-container transition-all group cursor-pointer">
                <input type="radio" name="intensity" value="exaustivo" class="sr-only" />
                <b class="text-4xl group-hover:scale-110 transition-transform">💀</b>
                <b class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">Exaustivo</b>
              </label>
            </li>
          </ol>
        </fieldset>
      </article>

      <!-- 02 · Context Details Grid -->
      <section class="grid md:grid-cols-2 gap-8" aria-label="Detalhes do treino">

        <!-- Tiredness Level -->
        <article class="bg-surface-container-low p-8 rounded-[32px]" aria-labelledby="tiredness-title">
          <h2 id="tiredness-title" class="text-xl font-bold mb-6 flex items-center gap-2">
            <mark class="w-8 h-8 rounded-full bg-primary/10 text-primary flex items-center justify-center text-sm">02</mark>
            Nível de Cansaço
          </h2>

          <section class="space-y-6">
            <label for="tiredness-range" class="sr-only">Nível de cansaço de 1 a 10</label>
            <input id="tiredness-range"
                   class="w-full h-2 bg-surface-container-highest rounded-lg appearance-none cursor-pointer accent-primary"
                   max="10" min="1" step="1" type="range" />

            <dl class="flex justify-between text-xs font-bold text-on-surface-variant uppercase tracking-tighter">
              <dt class="sr-only">Mínimo</dt>
              <dd>Bateria 100%</dd>
              <dt class="sr-only">Máximo</dt>
              <dd>Esgotado</dd>
            </dl>

            <aside class="bg-surface-container-lowest p-4 rounded-2xl flex items-center gap-4">
              <i class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">bolt</i>
              <p class="text-sm font-medium">Você terminou o treino com energia residual para o dia.</p>
            </aside>
          </section>
        </article>

        <!-- Motivational Image -->
        <figure class="relative rounded-[32px] overflow-hidden min-h-[240px] group m-0">
          <img alt="Pessoa atlética sentada em um banco de academia segurando uma garrafa de água após o treino, iluminação natural cinematográfica"
               class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
               src="https://lh3.googleusercontent.com/aida-public/AB6AXuCQBTHoGiF15gXtelwNfg6QaxoWw4EINtajYto6DeVhSi6AOMFtPOubfz3q1o1zDlG7Spf9TJQTBXiLV-Vmq9CoKA89BppqeHRHaoJEXeb7mD7an7caLsQ0sEgz6CFm_xcx8_BkXfAHwyJ8rKSJcizajJ_6ARK6ZqzGYpNzD_2ox8hisn-ZXu2llA3trdE61ot4-etyhHcpxtRj62WOVFNGhbHxFpf8a5KR4covzhCbU6TuVZPRNg0wr_wRHvb3slN-VwPFGfNkLfiZ" />
          <aside class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent" aria-hidden="true"></aside>
          <figcaption class="absolute bottom-6 left-6 right-6">
            <p class="text-white font-['Lexend'] text-lg font-bold leading-tight">Mantenha o ritmo!</p>
            <p class="text-white/80 text-sm">Sua constância é o que traz o resultado real.</p>
          </figcaption>
        </figure>
      </section>

      <!-- 03 · Message to Trainer -->
      <article class="bg-surface-container-highest p-8 rounded-[32px]" aria-labelledby="message-title">
        <h2 id="message-title" class="text-xl font-bold mb-6 flex items-center gap-2">
          <mark class="w-8 h-8 rounded-full bg-white text-primary flex items-center justify-center text-sm">03</mark>
          Mensagem para o Professor
        </h2>

        <label for="trainer-message" class="sr-only">Mensagem para o professor</label>
        <p class="relative m-0">
          <textarea id="trainer-message"
                    class="w-full bg-surface-container-lowest border-none rounded-2xl p-4 text-on-surface placeholder:text-on-surface-variant/50 focus:ring-2 focus:ring-primary transition-all"
                    placeholder="Sentiu alguma dor? O peso estava ok? Conte para nós..."
                    rows="4"></textarea>
          <i class="material-symbols-outlined text-primary/30 absolute bottom-4 right-4 pointer-events-none" aria-hidden="true">edit_note</i>
        </p>
      </article>

      <!-- Final Submission -->
      <section class="pt-6 flex flex-col md:flex-row items-center justify-between gap-6" aria-label="Enviar feedback">

        <figure class="flex items-center gap-3 m-0">
          <picture class="w-12 h-12 rounded-full overflow-hidden bg-surface-container block">
            <img alt="Foto do treinador Ricardo Silva"
                 class="w-full h-full object-cover"
                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuAKCwt1nanN5sVXKEaeZdXtYhJFFmCAEzVrI4ibfOfcsUQgy5MPB3bEa6heZ7fA7DIewsrgOY0gdExl2U2cGoxd3rnlR6d3VDMuc8W2AUM10w1S3F1LUuJxWYFYRA8K3PiRWQ00_4OIR85_S86FnBWbmcWnpSf3NJjWCvq8Fp5rtWmoB89biCPTrmdKkd53IXPa18jjI62TqxL6jTzlAjmJZyxK_rUU1oO5S2yGGcJRdYsuaokhr4QNQ5Kwen3ZUjtFYnSAKN_MNnaL" />
          </picture>
          <figcaption>
            <p class="text-xs font-bold text-on-surface-variant uppercase">Seu Treinador</p>
            <p class="font-bold">Ricardo Silva</p>
          </figcaption>
        </figure>

        <button type="submit"
                class="w-full md:w-auto bg-gradient-to-br from-primary to-primary-container text-white px-12 py-5 rounded-full font-['Manrope'] font-bold text-lg shadow-xl shadow-primary/30 hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center gap-3">
          Enviar Feedback
          <i class="material-symbols-outlined" aria-hidden="true">send</i>
        </button>
      </section>

    </form>
  </main>

  <!-- ===== Bottom Nav Bar (Mobile Only) ===== -->
  <footer class="md:hidden fixed bottom-0 left-0 w-full z-50">
    <nav class="bg-[#f7f5ff]/90 backdrop-blur-2xl rounded-t-[32px] shadow-[0_-8px_30px_rgb(0,0,0,0.04)] px-4 pb-6 pt-2 flex justify-around items-end" aria-label="Navegação mobile">

      <a class="flex flex-col items-center justify-center text-slate-400 p-2 hover:bg-blue-50 transition-all rounded-full" href="#">
        <i class="material-symbols-outlined" aria-hidden="true">fitness_center</i>
        <b class="font-['Manrope'] text-[10px] font-semibold uppercase tracking-wider mt-1">Treino</b>
      </a>

      <a class="flex flex-col items-center justify-center bg-blue-600 text-white rounded-full p-3 mb-2 shadow-lg shadow-blue-500/40 active:scale-90 transition-transform duration-200" href="#" aria-current="page" aria-label="Feedback (atual)">
        <i class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">chat_bubble</i>
      </a>

      <a class="flex flex-col items-center justify-center text-slate-400 p-2 hover:bg-blue-50 transition-all rounded-full" href="#">
        <i class="material-symbols-outlined" aria-hidden="true">insights</i>
        <b class="font-['Manrope'] text-[10px] font-semibold uppercase tracking-wider mt-1">Métricas</b>
      </a>

      <a class="flex flex-col items-center justify-center text-slate-400 p-2 hover:bg-blue-50 transition-all rounded-full" href="#">
        <i class="material-symbols-outlined" aria-hidden="true">person</i>
        <b class="font-['Manrope'] text-[10px] font-semibold uppercase tracking-wider mt-1">Perfil</b>
      </a>

    </nav>
  </footer>

</body>
</html>