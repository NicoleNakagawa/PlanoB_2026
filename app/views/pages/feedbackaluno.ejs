<!DOCTYPE html>
<html class="light" lang="pt-BR">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>PlanoB - Feedback do Aluno</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface": "#f7f5ff",
            "primary": "#0058ba",
            "on-surface": "#232c51",
            "on-surface-variant": "#505a81",
            "surface-container-lowest": "#ffffff",
            "surface-container-low": "#efefff",
            "surface-container": "#e4e7ff",
            "surface-container-highest": "#d5dbff",
            "outline-variant": "#a2abd7",
            "tertiary-fixed": "#ffd709",
            "error": "#b31b25"
          },
          borderRadius: {
            DEFAULT: "0.25rem",
            lg: "0.5rem",
            xl: "0.75rem",
            full: "9999px"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"],
            label: ["Manrope"]
          }
        }
      }
    }
  </script>

  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .logo-header {
      font-size: 2.7rem;
      line-height: 1;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    .avatar-placeholder .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    .radio-card input:checked + span {
      background: #0058ba;
      color: white;
      transform: scale(1.04);
      box-shadow: 0 18px 35px rgba(0, 88, 186, 0.22);
    }

    @media (max-width: 768px) {
      html,
      body {
        width: 100%;
        overflow-x: hidden;
      }

      body {
        background: #f7f5ff;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      header.fixed a.logo-header {
        font-size: 1.45rem;
        line-height: 1;
      }

      header.fixed menu {
        gap: 8px;
      }

      header.fixed button,
      header.fixed a {
        padding: 8px;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 16px 135px !important;
      }

      article.hero-feedback {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.hero-feedback h1 {
        font-size: 2rem !important;
        line-height: 1.1 !important;
      }

      section.card-mobile,
      article.card-mobile {
        padding: 22px !important;
        border-radius: 26px !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 64px;
        border-radius: 18px;
      }

      nav[aria-label="Navegação mobile"] a[aria-current="page"] {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
      }
    }

    @media (max-width: 420px) {
      main {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }

      article.hero-feedback h1 {
        font-size: 1.75rem !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 58px;
        padding: 10px 6px !important;
      }

      nav[aria-label="Navegação mobile"] em {
        font-size: 8px !important;
      }
    }
  </style>
</head>

<body class="bg-surface text-on-surface">

  <%
    const planoAluno = typeof aluno !== 'undefined' && aluno.id_plano ? Number(aluno.id_plano) : 2

    const painelCorreto = typeof linkPainelAluno !== 'undefined'
      ? linkPainelAluno
      : planoAluno === 3
        ? '/paineldiamante'
        : planoAluno === 2
          ? '/painellazuli'
          : '/painelfree'

    const videosCorreto = typeof linkVideosAluno !== 'undefined'
      ? linkVideosAluno
      : planoAluno >= 2
        ? '/videos'
        : '/videosfree'

    const nomePlanoAluno = planoAluno === 3 ? 'Diamante' : planoAluno === 2 ? 'Lazuli' : 'Free'
    const professor = typeof professorResponsavel !== 'undefined' && professorResponsavel ? professorResponsavel : null
  %>

  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">
    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <a href="<%= painelCorreto %>" class="font-headline logo-font logo-header text-primary no-underline">PlanoB</a>
    </nav>

    <menu class="flex items-center gap-4 p-0 m-0 list-none">
      <li>
        <button class="p-2 rounded-full hover:bg-surface-container transition-colors active:scale-95" aria-label="Notificações">
          <i class="material-symbols-outlined text-on-surface not-italic" aria-hidden="true">notifications</i>
        </button>
      </li>

      <li>
        <a href="/perfilaluno" class="p-2 rounded-full hover:bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center" aria-label="Perfil">
          <i class="material-symbols-outlined text-on-surface not-italic" aria-hidden="true">account_circle</i>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] dark:bg-[#12141c] flex-col gap-2 py-8 z-40 mt-16">
    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <picture>
          <% if (typeof aluno !== 'undefined' && aluno.foto) { %>
            <img class="w-12 h-12 rounded-full object-cover" src="<%= aluno.foto %>" alt="Foto de perfil do aluno" />
          <% } else { %>
            <span class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden" aria-label="Aluno sem foto">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </span>
          <% } %>
        </picture>

        <figcaption>
          <p class="text-sm font-bold text-on-surface">Portal <%= nomePlanoAluno %></p>
          <p class="text-xs text-on-surface-variant">Plano premium ativo</p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">
      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="<%= painelCorreto %>">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">fitness_center</i>
        <em class="not-italic">Treinos</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="<%= videosCorreto %>">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">play_circle</i>
        <em class="not-italic">Vídeos</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/progressosemanal">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">monitoring</i>
        <em class="not-italic">Progresso</em>
      </a>

      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="/feedbackaluno" aria-current="page">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
        <em class="not-italic">Feedback</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/perfilaluno">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">person</i>
        <em class="not-italic">Perfil</em>
      </a>
    </nav>
  </aside>

  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <article class="hero-feedback md:col-span-12 relative overflow-hidden rounded-3xl bg-primary p-8 md:p-12 text-white shadow-2xl">
        <section class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
          <hgroup class="max-w-2xl">
            <mark class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md text-xs font-bold uppercase tracking-widest mb-4 text-white">
              Feedback do Treino
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              COMO FOI SEU TREINO?
            </h1>

            <p class="text-lg opacity-90 max-w-xl">
              Envie sua percepção para o professor acompanhar sua evolução e ajustar seus treinos.
            </p>
          </hgroup>

          <figure class="flex flex-col items-center gap-4 bg-white/10 backdrop-blur-xl p-6 md:p-8 rounded-3xl border border-white/10 w-full max-w-[240px] mx-auto md:mx-0 md:w-auto m-0">
            <span class="w-28 h-28 rounded-full bg-white/15 flex items-center justify-center">
              <i class="material-symbols-outlined text-white text-7xl not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">forum</i>
            </span>

            <figcaption class="text-sm font-black uppercase tracking-widest text-center">
              Plano <%= nomePlanoAluno %>
            </figcaption>
          </figure>
        </section>

        <b class="absolute -right-20 -bottom-20 w-96 h-96 bg-[#80deff] opacity-10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        <b class="absolute -left-20 -top-20 w-64 h-64 bg-white opacity-5 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
      </article>

      <% if (typeof erro !== 'undefined' && erro) { %>
        <section class="md:col-span-12 bg-red-50 text-error rounded-3xl p-5 font-bold text-center" role="alert">
          <%= erro %>
        </section>
      <% } %>

      <% if (typeof sucesso !== 'undefined' && sucesso) { %>
        <section class="md:col-span-12 bg-green-50 text-green-700 rounded-3xl p-5 font-bold text-center" role="status">
          <%= sucesso %>
        </section>
      <% } %>

      <section class="card-mobile md:col-span-8 bg-surface-container-lowest rounded-3xl p-8 shadow-sm">
        <form action="/feedbackaluno" method="POST" class="flex flex-col gap-8">

          <fieldset class="flex flex-col gap-4">
            <legend class="text-2xl font-extrabold headline text-on-surface mb-2">
              Intensidade do esforço
            </legend>

            <section class="grid grid-cols-2 md:grid-cols-5 gap-4">
              <label class="radio-card cursor-pointer">
                <input type="radio" name="intensity" value="leve" class="sr-only" />
                <span class="h-full bg-surface-container-low rounded-3xl p-4 flex flex-col items-center gap-3 transition-all">
                  <b class="text-4xl">😅</b>
                  <em class="not-italic text-xs font-black uppercase tracking-widest">Leve</em>
                </span>
              </label>

              <label class="radio-card cursor-pointer">
                <input type="radio" name="intensity" value="moderado" class="sr-only" />
                <span class="h-full bg-surface-container-low rounded-3xl p-4 flex flex-col items-center gap-3 transition-all">
                  <b class="text-4xl">😊</b>
                  <em class="not-italic text-xs font-black uppercase tracking-widest">Moderado</em>
                </span>
              </label>

              <label class="radio-card cursor-pointer">
                <input type="radio" name="intensity" value="intenso" class="sr-only" checked />
                <span class="h-full bg-surface-container-low rounded-3xl p-4 flex flex-col items-center gap-3 transition-all">
                  <b class="text-4xl">🔥</b>
                  <em class="not-italic text-xs font-black uppercase tracking-widest">Intenso</em>
                </span>
              </label>

              <label class="radio-card cursor-pointer">
                <input type="radio" name="intensity" value="pesado" class="sr-only" />
                <span class="h-full bg-surface-container-low rounded-3xl p-4 flex flex-col items-center gap-3 transition-all">
                  <b class="text-4xl">🥵</b>
                  <em class="not-italic text-xs font-black uppercase tracking-widest">Pesado</em>
                </span>
              </label>

              <label class="radio-card cursor-pointer">
                <input type="radio" name="intensity" value="exaustivo" class="sr-only" />
                <span class="h-full bg-surface-container-low rounded-3xl p-4 flex flex-col items-center gap-3 transition-all">
                  <b class="text-4xl">💀</b>
                  <em class="not-italic text-xs font-black uppercase tracking-widest">Exaustivo</em>
                </span>
              </label>
            </section>
          </fieldset>

          <section class="bg-surface-container-low rounded-3xl p-6">
            <label for="tiredness-range" class="text-xl font-extrabold headline block mb-5">
              Nível de cansaço
            </label>

            <input id="tiredness-range" name="tiredness-range" value="5" max="10" min="1" step="1" type="range" class="w-full accent-primary" />

            <section class="flex justify-between text-xs font-black uppercase tracking-widest text-on-surface-variant mt-3">
              <span>Leve</span>
              <span>Moderado</span>
              <span>Esgotado</span>
            </section>
          </section>

          <section>
            <label for="trainer-message" class="text-xl font-extrabold headline block mb-5">
              Mensagem para o professor
            </label>

            <textarea
              id="trainer-message"
              name="trainer-message"
              rows="6"
              class="w-full bg-surface-container-low border-none rounded-3xl p-5 text-on-surface placeholder:text-on-surface-variant/60 focus:ring-2 focus:ring-primary transition-all resize-none"
              placeholder="Conte se sentiu dor, dificuldade, cansaço, se o treino foi leve ou pesado..."
              required
            ></textarea>
          </section>

          <button type="submit" class="w-full md:w-auto md:self-end bg-primary text-white px-10 py-5 rounded-full font-black shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all inline-flex items-center justify-center gap-3">
            Enviar feedback
            <i class="material-symbols-outlined not-italic" aria-hidden="true">send</i>
          </button>

        </form>
      </section>

      <aside class="card-mobile md:col-span-4 bg-surface-container-low rounded-3xl p-8 flex flex-col gap-6">
        <header>
          <h2 class="text-2xl font-extrabold headline text-on-surface">Professor responsável</h2>
          <p class="text-sm text-on-surface-variant mt-1">
            Seu feedback será enviado para o professor associado à sua ficha ativa.
          </p>
        </header>

        <figure class="bg-surface-container-lowest rounded-3xl p-6 flex items-center gap-4 m-0">
          <% if (professor && professor.foto_perfil) { %>
            <img src="<%= professor.foto_perfil %>" alt="Foto do professor" class="w-16 h-16 rounded-full object-cover">
          <% } else { %>
            <span class="w-16 h-16 rounded-full avatar-placeholder flex items-center justify-center">
              <i class="material-symbols-outlined text-5xl not-italic" aria-hidden="true">account_circle</i>
            </span>
          <% } %>

          <figcaption>
            <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Seu treinador</p>
            <p class="font-black text-on-surface">
              <%= professor ? professor.nome : 'Nenhum professor vinculado' %>
            </p>
            <% if (professor && professor.cref) { %>
              <p class="text-xs text-primary font-bold mt-1">CREF <%= professor.cref %></p>
            <% } %>
          </figcaption>
        </figure>

        <% if (!professor) { %>
          <section class="bg-red-50 text-error rounded-3xl p-5">
            <p class="font-bold text-sm">
              Para enviar feedback, sua conta precisa estar vinculada a uma ficha de treino com professor.
            </p>
          </section>
        <% } else { %>
          <section class="bg-primary rounded-3xl p-6 text-white">
            <i class="material-symbols-outlined text-4xl not-italic mb-3" aria-hidden="true">verified</i>
            <p class="font-black text-lg">Canal ativo</p>
            <p class="text-sm text-white/80 mt-1">
              Seu feedback será salvo no chat de acompanhamento.
            </p>
          </section>
        <% } %>

        <a href="/progressosemanal" class="w-full bg-surface-container-highest text-on-surface py-4 rounded-full font-bold text-center active:scale-95 transition-transform">
          Ver progresso semanal
        </a>
      </aside>

    </section>
  </main>

  <nav class="md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-2 bg-[#f7f5ff]/90 dark:bg-[#1a1b26]/90 backdrop-blur-lg shadow-[0_-10px_40px_rgba(35,44,81,0.08)] rounded-t-[32px]" aria-label="Navegação mobile">

    <a href="<%= painelCorreto %>" class="flex flex-col items-center justify-center text-[#232c51] dark:text-[#d5dbff] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">fitness_center</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Treinos</em>
    </a>

    <a href="<%= videosCorreto %>" class="flex flex-col items-center justify-center text-[#232c51] dark:text-[#d5dbff] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">play_circle</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Vídeos</em>
    </a>

    <a href="/feedbackaluno" class="flex flex-col items-center justify-center text-[#0058ba] dark:text-[#d5dbff] opacity-100 p-3 rounded-[18px] bg-[#d5dbff] hover:opacity-100 transition-opacity" aria-current="page">
      <i class="material-symbols-outlined not-italic" style="font-variation-settings:'FILL' 1" aria-hidden="true">forum</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Feedback</em>
    </a>

    <a href="/perfilaluno" class="flex flex-col items-center justify-center text-[#232c51] dark:text-[#d5dbff] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">person</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Perfil</em>
    </a>

  </nav>

</body>
</html>