<!DOCTYPE html>
<html class="light" lang="pt-BR">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>PlanoB - Biblioteca de Vídeos</title>

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface-bright": "#f7f5ff",
            "tertiary-dim": "#5e4e00",
            "error": "#b31b25",
            "surface-dim": "#cad2ff",
            "outline-variant": "#a2abd7",
            "on-secondary": "#e2f6ff",
            "surface-container-highest": "#d5dbff",
            "inverse-primary": "#4a8eff",
            "surface": "#f7f5ff",
            "primary": "#0058ba",
            "outline": "#6c759e",
            "inverse-on-surface": "#929bc6",
            "error-container": "#fb5151",
            "surface-variant": "#d5dbff",
            "primary-fixed": "#6c9fff",
            "primary-container": "#6c9fff",
            "secondary-fixed-dim": "#37d4ff",
            "on-error": "#ffefee",
            "on-tertiary": "#fff2cd",
            "on-surface-variant": "#505a81",
            "tertiary-fixed-dim": "#efc900",
            "surface-container-high": "#dde1ff",
            "secondary-dim": "#00576c",
            "on-secondary-fixed-variant": "#00586d",
            "on-tertiary-container": "#5b4b00",
            "tertiary-fixed": "#ffd709",
            "on-primary-fixed": "#000000",
            "on-primary": "#f0f2ff",
            "on-error-container": "#570008",
            "secondary-fixed": "#80deff",
            "secondary-container": "#80deff",
            "on-tertiary-fixed": "#453900",
            "primary-fixed-dim": "#5091ff",
            "surface-container": "#e4e7ff",
            "primary-dim": "#004da4",
            "on-background": "#232c51",
            "surface-container-lowest": "#ffffff",
            "inverse-surface": "#020a2f",
            "tertiary-container": "#ffd709",
            "on-tertiary-fixed-variant": "#665500",
            "on-primary-container": "#00214e",
            "surface-container-low": "#efefff",
            "secondary": "#00647b",
            "on-primary-fixed-variant": "#002a60",
            "on-secondary-container": "#004e61",
            "on-surface": "#232c51",
            "surface-tint": "#0058ba",
            "background": "#f7f5ff",
            "on-secondary-fixed": "#003a48",
            "error-dim": "#9f0519",
            "tertiary": "#6c5a00"
          },
          borderRadius: {
            DEFAULT: "0.25rem",
            lg: "0.5rem",
            xl: "0.75rem",
            full: "9999px"
          },
          fontFamily: {
            headline: ["Lexend"],
            body: ["Manrope"],
            label: ["Manrope"]
          }
        }
      }
    }
  </script>

  <style>
    @font-face {
      font-family: 'Baumans';
      src: url('/fonts/Baumans-Regular.ttf') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    .logo-font {
      font-family: 'Baumans', sans-serif !important;
      font-weight: 400 !important;
      letter-spacing: 0.02em;
    }

    .logo-header {
      font-size: 2.7rem;
      line-height: 1;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    body {
      font-family: 'Manrope', sans-serif;
    }

    h1,
    h2,
    h3,
    .headline {
      font-family: 'Lexend', sans-serif;
    }

    .avatar-placeholder {
      background: linear-gradient(180deg, #ffffff 0%, #d5dbff 100%);
      color: #0058ba;
      border: 2px solid rgba(255, 255, 255, 0.75);
      box-shadow: inset 0 0 0 1px rgba(0, 88, 186, 0.08);
    }

    .avatar-placeholder .material-symbols-outlined {
      font-variation-settings: 'FILL' 1, 'wght' 300, 'GRAD' 0, 'opsz' 48;
    }

    .video-card-link {
      color: inherit;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      width: 100%;
      height: 100%;
    }

    .video-card-link:hover img {
      transform: scale(1.08);
    }

    @media (max-width: 768px) {
      html,
      body {
        width: 100%;
        overflow-x: hidden;
      }

      body {
        background: #f7f5ff;
      }

      header.fixed {
        padding: 14px 16px;
        min-height: 68px;
      }

      header.fixed strong.logo-header {
        font-size: 1.45rem;
        line-height: 1;
      }

      header.fixed menu {
        gap: 8px;
      }

      header.fixed button,
      header.fixed a {
        padding: 8px;
      }

      main {
        margin-left: 0 !important;
        padding: 92px 16px 135px !important;
      }

      main section.max-w-6xl {
        gap: 18px;
      }

      article.hero-videos {
        padding: 28px 20px !important;
        border-radius: 28px !important;
      }

      article.hero-videos > section {
        align-items: flex-start !important;
        gap: 28px !important;
      }

      article.hero-videos h1 {
        font-size: 2rem !important;
        line-height: 1.1 !important;
        margin-left: 0 !important;
      }

      article.hero-videos p {
        font-size: 0.95rem !important;
      }

      article.hero-videos figure {
        max-width: 220px;
        width: 100% !important;
        margin: 0 auto !important;
        padding: 20px !important;
      }

      section.card-mobile,
      article.card-mobile {
        padding: 22px !important;
        border-radius: 26px !important;
      }

      section.card-mobile h2,
      article.card-mobile h2 {
        font-size: 1.35rem !important;
      }

      section.video-grid ul {
        grid-template-columns: 1fr !important;
      }

      nav[aria-label="Filtros de vídeo"] {
        overflow-x: auto;
        padding-bottom: 8px;
      }

      nav[aria-label="Filtros de vídeo"] button {
        white-space: nowrap;
      }

      nav[aria-label="Navegação mobile"] {
        padding: 10px 8px 22px !important;
        border-radius: 28px 28px 0 0 !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 64px;
        border-radius: 18px;
      }

      nav[aria-label="Navegação mobile"] a[aria-current="page"] {
        color: #0058ba !important;
        opacity: 1 !important;
        background: #d5dbff;
      }

      nav[aria-label="Navegação mobile"] a:hover {
        color: #0058ba !important;
        opacity: 1 !important;
      }
    }

    @media (max-width: 420px) {
      main {
        padding-left: 12px !important;
        padding-right: 12px !important;
      }

      article.hero-videos h1 {
        font-size: 1.75rem !important;
      }

      nav[aria-label="Navegação mobile"] {
        padding-left: 6px !important;
        padding-right: 6px !important;
      }

      nav[aria-label="Navegação mobile"] a {
        min-width: 58px;
        padding: 10px 6px !important;
      }

      nav[aria-label="Navegação mobile"] em {
        font-size: 8px !important;
      }
    }
  </style>
</head>

<body class="bg-surface text-on-surface">

  <%
    const planoAluno = typeof aluno !== 'undefined' && aluno.id_plano ? Number(aluno.id_plano) : 2

    const painelCorreto = typeof linkPainelAluno !== 'undefined'
      ? linkPainelAluno
      : planoAluno === 3
        ? '/paineldiamante'
        : planoAluno === 2
          ? '/painellazuli'
          : '/painelfree'

    const videosCorreto = '/videos'

    const nomePlanoAluno = planoAluno === 3
      ? 'Diamante'
      : planoAluno === 2
        ? 'Lazuli'
        : 'Free'

    const planoPago = planoAluno >= 2

    const imagensPremium = {
      'agachamento': 'https://images.unsplash.com/photo-1599058917212-d750089bc07e?auto=format&fit=crop&w=1200&q=80',
      'cardio-10-minutos': 'https://images.unsplash.com/photo-1605296867304-46d5465a13f1?auto=format&fit=crop&w=1200&q=80',
      'mobilidade-basica': 'https://images.unsplash.com/photo-1599901860904-17e6ed7083a0?auto=format&fit=crop&w=1200&q=80',
      'flexao-perfeita': 'https://images.unsplash.com/photo-1598971639058-fab3c3109a00?auto=format&fit=crop&w=1200&q=80',
      'afundo-explosivo': 'https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=1200&q=80',
      'prancha-isometrica': 'https://images.unsplash.com/photo-1566241142559-40e1dab266c6?auto=format&fit=crop&w=1200&q=80'
    }

    const iconesCategoria = {
      'Fundamentos': 'fitness_center',
      'Cardio': 'directions_run',
      'Flexibilidade': 'self_improvement',
      'Braços': 'exercise',
      'Pernas': 'directions_walk',
      'Core': 'accessibility_new'
    }

    const videosBase = typeof videosFree !== 'undefined' && videosFree.length > 0 ? videosFree : []

    const videosPremium = videosBase.map(function(video) {
      return {
        ...video,
        capaPremium: imagensPremium[video.slug] || video.capa,
        icone: iconesCategoria[video.categoria] || 'play_circle'
      }
    })

    const totalVideos = videosPremium.length
  %>

  <header class="fixed top-0 w-full z-50 bg-[#f7f5ff]/80 backdrop-blur-xl flex justify-between items-center px-6 py-4">

    <nav class="flex items-center gap-4" aria-label="Navegação principal">
      <strong class="font-headline logo-font logo-header text-primary">PlanoB</strong>
    </nav>

    <menu class="flex items-center gap-4 p-0 m-0">
      <li>
        <button class="p-2 rounded-full hover:bg-surface-container transition-colors active:scale-95" aria-label="Notificações">
          <i class="material-symbols-outlined text-on-background not-italic" aria-hidden="true">notifications</i>
        </button>
      </li>

      <li>
        <a href="/perfilaluno"
          class="p-2 rounded-full hover:bg-surface-container transition-colors active:scale-95 inline-flex items-center justify-center"
          aria-label="Perfil">
          <i class="material-symbols-outlined text-on-background not-italic" aria-hidden="true">account_circle</i>
        </a>
      </li>
    </menu>

    <b class="absolute bottom-0 left-0 w-full h-[1px] bg-[#d5dbff] font-normal" aria-hidden="true"></b>
  </header>

  <aside class="hidden md:flex h-screen w-64 fixed left-0 top-0 bg-[#efefff] dark:bg-[#12141c] flex-col gap-2 py-8 z-40 mt-16">

    <header class="px-6 mb-8">
      <figure class="flex items-center gap-3 mb-2 m-0">
        <picture>
          <% if (typeof aluno !== 'undefined' && aluno.foto) { %>
            <img
              class="w-12 h-12 rounded-full object-cover"
              src="<%= aluno.foto %>"
              alt="Foto de perfil do aluno"
            />
          <% } else { %>
            <span class="w-12 h-12 rounded-full avatar-placeholder flex items-center justify-center overflow-hidden" aria-label="Aluno sem foto">
              <i class="material-symbols-outlined text-4xl not-italic" aria-hidden="true">account_circle</i>
            </span>
          <% } %>
        </picture>

        <figcaption>
          <p class="text-sm font-bold text-on-surface">Portal <%= nomePlanoAluno %></p>
          <p class="text-xs text-on-surface-variant">
            <%= planoPago ? 'Plano premium ativo' : 'Plano gratuito ativo' %>
          </p>
        </figcaption>
      </figure>
    </header>

    <nav class="flex flex-col gap-1" aria-label="Menu lateral">

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="<%= painelCorreto %>">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">fitness_center</i>
        <em class="not-italic">Treinos</em>
      </a>

      <a class="bg-primary text-white rounded-full mx-2 shadow-lg shadow-[#0058ba]/20 px-4 py-3 flex items-center gap-3 active:scale-95" href="/videos" aria-current="page">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">play_circle</i>
        <em class="not-italic">Vídeos</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/progressosemanal">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">monitoring</i>
        <em class="not-italic">Progresso</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/feedbackaluno">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">forum</i>
        <em class="not-italic">Feedback</em>
      </a>

      <a class="text-[#232c51] dark:text-[#a2abd7] hover:bg-[#d5dbff]/50 dark:hover:bg-[#232c51] rounded-full mx-2 px-4 py-3 flex items-center gap-3 hover:translate-x-1 transition-all active:scale-95" href="/perfilaluno">
        <i class="material-symbols-outlined not-italic" aria-hidden="true">person</i>
        <em class="not-italic">Perfil</em>
      </a>

    </nav>

  </aside>

  <main class="md:ml-64 pt-24 pb-32 md:pb-12 px-6 min-h-screen">
    <section class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">

      <article class="hero-videos md:col-span-12 relative overflow-hidden rounded-3xl bg-primary p-8 md:p-12 text-white shadow-2xl">

        <section class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">

          <hgroup class="max-w-2xl">
            <mark class="inline-block px-4 py-1 rounded-full bg-white/20 backdrop-blur-md text-xs font-bold uppercase tracking-widest mb-4 text-white">
              Biblioteca Premium
            </mark>

            <h1 class="text-4xl md:text-6xl font-black headline leading-tight mb-4 -ml-1">
              VÍDEOS DO PLANO <%= nomePlanoAluno.toUpperCase() %>.
            </h1>

            <p class="text-lg opacity-90 max-w-xl">
              Acesse exercícios, treinos guiados e aulas especiais liberadas para alunos dos planos Lazuli e Diamante.
            </p>
          </hgroup>

          <figure class="flex flex-col items-center gap-4 bg-white/10 backdrop-blur-xl p-6 md:p-8 rounded-3xl border border-white/10 w-full max-w-[240px] mx-auto md:mx-0 md:w-auto m-0">
            <span class="w-28 h-28 rounded-full bg-white/15 flex items-center justify-center">
              <i class="material-symbols-outlined text-white text-7xl not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 48" aria-hidden="true">play_circle</i>
            </span>

            <figcaption class="text-sm font-black uppercase tracking-widest text-center">
              <%= totalVideos %> vídeos liberados
            </figcaption>
          </figure>

        </section>

        <b class="absolute -right-20 -bottom-20 w-96 h-96 bg-secondary-fixed opacity-10 rounded-full blur-3xl font-normal" aria-hidden="true"></b>
        <b class="absolute -left-20 -top-20 w-64 h-64 bg-white opacity-5 rounded-full blur-2xl font-normal" aria-hidden="true"></b>
      </article>

      <section class="card-mobile md:col-span-12 bg-surface-container-lowest rounded-3xl p-8 shadow-sm flex flex-col gap-6">

        <header class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <hgroup>
            <h2 class="text-2xl font-extrabold headline text-on-surface">Biblioteca de exercícios</h2>
            <p class="text-sm text-on-surface-variant mt-1">
              Escolha um vídeo para abrir a tela de execução com nome, capa e informações do exercício.
            </p>
          </hgroup>

          <a href="<%= painelCorreto %>" class="inline-flex items-center justify-center gap-2 bg-primary text-white px-6 py-3 rounded-full font-bold shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all">
            Voltar ao painel
            <i class="material-symbols-outlined not-italic" aria-hidden="true">arrow_forward</i>
          </a>
        </header>

        <nav class="flex items-center gap-3" aria-label="Filtros de vídeo">
          <button class="bg-primary text-white px-6 py-3 rounded-full font-bold text-sm shadow-lg shadow-primary/20 active:scale-95 transition-transform">
            Todos
          </button>
          <button class="bg-surface-container-low text-on-surface-variant px-6 py-3 rounded-full font-bold text-sm hover:bg-surface-container-highest active:scale-95 transition-transform">
            Força
          </button>
          <button class="bg-surface-container-low text-on-surface-variant px-6 py-3 rounded-full font-bold text-sm hover:bg-surface-container-highest active:scale-95 transition-transform">
            Cardio
          </button>
          <button class="bg-surface-container-low text-on-surface-variant px-6 py-3 rounded-full font-bold text-sm hover:bg-surface-container-highest active:scale-95 transition-transform">
            Mobilidade
          </button>
          <button class="bg-surface-container-low text-on-surface-variant px-6 py-3 rounded-full font-bold text-sm hover:bg-surface-container-highest active:scale-95 transition-transform">
            Core
          </button>
        </nav>

      </section>

      <section class="video-grid md:col-span-12">
        <% if (videosPremium.length > 0) { %>
          <ul class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 list-none p-0 m-0" role="list" aria-label="Vídeos disponíveis">

            <% videosPremium.forEach(function(video, index) { %>
              <li class="group bg-surface-container-lowest rounded-3xl overflow-hidden shadow-sm border border-outline-variant/10 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">

                <a href="/execucaoexercicios?video=<%= video.slug %>" class="video-card-link">

                  <figure class="relative aspect-video overflow-hidden m-0">
                    <img
                      class="w-full h-full object-cover transition-transform duration-500"
                      src="<%= video.capaPremium %>"
                      alt="Imagem do exercício <%= video.titulo %>"
                    />

                    <b class="absolute inset-0 bg-gradient-to-t from-[#020a2f]/80 via-[#020a2f]/20 to-transparent block font-normal" aria-hidden="true"></b>

                    <figcaption class="absolute left-4 bottom-4 right-4 flex items-center justify-between gap-3">
                      <span class="inline-flex items-center gap-1 bg-white/20 backdrop-blur-md text-white px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest">
                        <i class="material-symbols-outlined text-sm not-italic" aria-hidden="true"><%= video.icone %></i>
                        <%= video.categoria %>
                      </span>

                      <time class="inline-flex items-center gap-1 text-white text-xs font-bold" datetime="PT<%= video.duracaoMin || 10 %>M">
                        <i class="material-symbols-outlined text-sm not-italic" aria-hidden="true">schedule</i>
                        <%= video.duracao %>
                      </time>
                    </figcaption>

                    <span class="absolute inset-0 flex items-center justify-center">
                      <span class="w-16 h-16 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center text-white scale-90 group-hover:scale-110 transition-transform">
                        <i class="material-symbols-outlined text-4xl not-italic" style="font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 32" aria-hidden="true">play_arrow</i>
                      </span>
                    </span>

                    <% if (index < 2) { %>
                      <mark class="absolute top-4 left-4 bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest">
                        Destaque
                      </mark>
                    <% } %>
                  </figure>

                  <article class="p-6 flex flex-col gap-4 flex-1">
                    <header>
                      <h3 class="text-xl font-extrabold headline text-on-surface mb-2">
                        <%= video.titulo %>
                      </h3>

                      <p class="text-sm text-on-surface-variant leading-relaxed line-clamp-2">
                        <%= video.descricao %>
                      </p>
                    </header>

                    <ul class="grid grid-cols-2 gap-3 list-none p-0 m-0 mt-auto">
                      <li class="bg-surface-container-low rounded-2xl p-3">
                        <p class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant">Nível</p>
                        <strong class="text-sm text-primary"><%= video.nivel %></strong>
                      </li>

                      <li class="bg-surface-container-low rounded-2xl p-3">
                        <p class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant">Duração</p>
                        <strong class="text-sm text-primary"><%= video.duracao %></strong>
                      </li>
                    </ul>

                    <footer class="pt-2 flex items-center justify-between">
                      <span class="text-xs font-black uppercase tracking-widest text-primary">
                        Plano <%= nomePlanoAluno %>
                      </span>

                      <span class="inline-flex items-center gap-1 text-primary text-sm font-bold">
                        Assistir
                        <i class="material-symbols-outlined text-sm not-italic" aria-hidden="true">arrow_forward</i>
                      </span>
                    </footer>
                  </article>

                </a>

              </li>
            <% }) %>

          </ul>
        <% } else { %>
          <section class="bg-surface-container-lowest rounded-3xl p-10 text-center shadow-sm">
            <i class="material-symbols-outlined text-primary text-6xl not-italic mb-4" aria-hidden="true">video_library</i>
            <h2 class="text-2xl font-black headline text-on-surface">Nenhum vídeo encontrado</h2>
            <p class="text-on-surface-variant mt-2">
              Verifique se o router está enviando a lista <strong>videosFree</strong> para esta página.
            </p>
          </section>
        <% } %>
      </section>

    </section>
  </main>

  <nav class="md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-2 bg-[#f7f5ff]/90 dark:bg-[#1a1b26]/90 backdrop-blur-lg shadow-[0_-10px_40px_rgba(35,44,81,0.08)] rounded-t-[32px]"
       aria-label="Navegação mobile">

    <a href="<%= painelCorreto %>"
       class="flex flex-col items-center justify-center text-[#232c51] dark:text-[#d5dbff] opacity-60 p-3 hover:opacity-100 transition-opacity">
      <i class="material-symbols-outlined not-italic" aria-hidden="true">fitness_center</i>
      <em class="text-[10px] font-semibold tracking-wide uppercase mt-1 not-italic">Treinos</em>
    </a>

    <a href="/videos"
